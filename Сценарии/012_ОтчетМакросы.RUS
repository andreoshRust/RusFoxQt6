ПРОЦЕДУРА Старт()
    // Устанавливаем порт и флаг для ручного запуска веб-сервера
    УстановитьПорт(8080);
    УстановитьФлагВебСервера(ИСТИНА);
    
    УстановитьЗаголовокГлавногоОкна("SmartGrid - Система отчётов (JSON + Макросы)");
    ЗадатьРазмерыГлавногоОкна(1024, 768);
    ЦентрироватьГлавноеОкно();
    
    СоздатьСтраницы("Главная", 1, "Система отчётов");
    
    // ========== ПАНЕЛЬ СТАТУСА ==========
    ДобавитьОбъектНаСтранице(1, "Группа", "statusGroup", {
        "Лево": 20, "Верх": 20, "Ширина": 980, "Высота": 100,
        "Заголовок": "📊 Статус серверов",
        "Стиль": "QGroupBox { background-color: #0f3460; border-radius: 8px; color: #e94560; }"
    });
    
    ДобавитьОбъектНаСтранице(1, "Надпись", "lblLOStatus", {
