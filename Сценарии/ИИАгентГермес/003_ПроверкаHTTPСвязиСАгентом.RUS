// Проверено 29.06.2026
//╔═══════════════════════════════════════════════════════════════════╗
//║              ОТПРАВКА ЗАПРОСА К HERMES AGENT                       ║
//╚═══════════════════════════════════════════════════════════════════╝

ПРОЦЕДУРА Старт()
    ПодавитьВыводОкна(ИСТИНА)
    СкрытьГлавноеОкно()
    ОчиститьКонсоль()
    
    УстановитьЦветКонсоли("cyan")
    ВывестиСтрокуВКонсоль("╔═══════════════════════════════════════════════════════════════════╗")
    ВывестиСтрокуВКонсоль("║              ОТПРАВКА ЗАПРОСА К HERMES AGENT                       ║")
    ВывестиСтрокуВКонсоль("╚═══════════════════════════════════════════════════════════════════╝")
    СброситьЦветКонсоли()
    ВывестиСтрокуВКонсоль("")

    // ============================================================
    // 1. ОТПРАВКА ЗАПРОСА ЧЕРЕЗ СИНХРОННЫЙ HTTP
    // ============================================================
    УстановитьЦветКонсоли("yellow")
    ВывестиСтрокуВКонсоль("--- 1. Отправка запроса ---")
    СброситьЦветКонсоли()
    
    сообщение = "Привет! Расскажи, что ты умеешь, коротко (2-3 предложения)."
    ВывестиСтрокуВКонсоль("📤 " + сообщение)
    ВывестиСтрокуВКонсоль("")

    // Устанавливаем заголовки
    Попытка
        УстановитьHTTPЗаголовок("Authorization", "Bearer Hermes_O")
        УстановитьHTTPЗаголовок("Content-Type", "application/json")
        ВывестиСтрокуВКонсоль("✅ Заголовки установлены")
    Исключение
        УстановитьЦветКонсоли("red")
        ВывестиСтрокуВКонсоль("❌ Ошибка установки заголовков: " + e)
        СброситьЦветКонсоли()
        Пауза(5000)
        ЗавершитьПрограмму(0)
    КонецПопытки

    // Устанавливаем таймаут (30 секунд)
    Попытка
        УстановитьHTTPТаймаут(30000)
        ВывестиСтрокуВКонсоль("✅ Таймаут установлен: 30 сек")
    Исключение
        УстановитьЦветКонсоли("red")
        ВывестиСтрокуВКонсоль("❌ Ошибка установки таймаута: " + e)
        СброситьЦветКонсоли()
        Пауза(5000)
        ЗавершитьПрограмму(0)
    КонецПопытки

    // Формируем JSON тело запроса
    jsonТело = "{\"model\":\"hermes-agent\",\"messages\":[{\"role\":\"user\",\"content\":\"" + сообщение + "\"}],\"stream\":false}"
    
    ВывестиСтрокуВКонсоль("⏳ Выполнение запроса...")
    ВывестиСтрокуВКонсоль("")

    // Отправляем синхронный POST запрос
    Попытка
        url = "http://localhost:8643/v1/chat/completions"
        ответ = СинхронныйPOST(url, jsonТело)
        
        УстановитьЦветКонсоли("green")
        ВывестиСтрокуВКонсоль("✅ Запрос выполнен успешно")
        СброситьЦветКонсоли()
        ВывестиСтрокуВКонсоль("")

        // Очищаем заголовки после использования
        Попытка
            ОчиститьHTTPЗаголовки()
        Исключение
            // Игнорируем
        КонецПопытки

        // Парсим JSON ответ
        Если ответ != "" И ответ.length > 0 Тогда
            Попытка
                данные = JSON_ИзСтроки(ответ)
                
                Если данные.error Тогда
                    УстановитьЦветКонсоли("red")
                    ВывестиСтрокуВКонсоль("❌ ОШИБКА API: " + данные.error.message)
                    СброситьЦветКонсоли()
                ИначеЕсли данные.choices И данные.choices.length > 0 Тогда
                    содержимое = данные.choices[0].message.content
                    
                    УстановитьЦветКонсоли("green")
                    ВывестиСтрокуВКонсоль("📝 ОТВЕТ АГЕНТА:")
                    ВывестиСтрокуВКонсоль(содержимое)
                    СброситьЦветКонсоли()
                    ВывестиСтрокуВКонсоль("")
                    
                    Если данные.usage Тогда
                        ВывестиСтрокуВКонсоль("📊 Токены: prompt=" + данные.usage.prompt_tokens + 
                            ", completion=" + данные.usage.completion_tokens + 
                            ", total=" + данные.usage.total_tokens)
                    КонецЕсли
                Иначе
                    УстановитьЦветКонсоли("yellow")
                    ВывестиСтрокуВКонсоль("⚠️ Неожиданный формат ответа")
                    ВывестиСтрокуВКонсоль(ответ)
                    СброситьЦветКонсоли()
                КонецЕсли
            Исключение
                УстановитьЦветКонсоли("red")
                ВывестиСтрокуВКонсоль("❌ Ошибка парсинга JSON: " + e)
                ВывестиСтрокуВКонсоль("Данные: " + ответ)
                СброситьЦветКонсоли()
            КонецПопытки
        Иначе
            УстановитьЦветКонсоли("red")
            ВывестиСтрокуВКонсоль("❌ Получен пустой ответ от сервера")
            СброситьЦветКонсоли()
        КонецЕсли
        
    Исключение
        УстановитьЦветКонсоли("red")
        ВывестиСтрокуВКонсоль("❌ Ошибка при выполнении запроса: " + e)
        СброситьЦветКонсоли()
        
        // Пытаемся очистить заголовки
        Попытка
            ОчиститьHTTPЗаголовки()
        Исключение
            // Игнорируем
        КонецПопытки
    КонецПопытки
    
    // ============================================================
    // 2. ЗАВЕРШЕНИЕ
    // ============================================================
    ВывестиСтрокуВКонсоль("")
    УстановитьЦветКонсоли("yellow")
    ВывестиСтрокуВКонсоль("--- 2. Завершение ---")
    СброситьЦветКонсоли()

    УстановитьЦветКонсоли("cyan")
    ВывестиСтрокуВКонсоль("╔═══════════════════════════════════════════════════════════════════╗")
    ВывестиСтрокуВКонсоль("║                    СЦЕНАРИЙ ЗАВЕРШЕН                             ║")
    ВывестиСтрокуВКонсоль("╚═══════════════════════════════════════════════════════════════════╝")
    СброситьЦветКонсоли()
    
    Пауза(3000)
    ЗавершитьПрограмму(0)
КОНЕЦПРОЦЕДУРЫ

