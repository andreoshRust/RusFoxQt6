ПРОЦЕДУРА Старт()
    ПодавитьВыводОкна(ИСТИНА)
    СкрытьГлавноеОкно()
    ОчиститьКонсоль()
    
    УстановитьЦветКонсоли("cyan")
    ВывестиСтрокуВКонсоль("╔═══════════════════════════════════════════════════════════════════╗")
    ВывестиСтрокуВКонсоль("║              ОТПРАВКА ЗАПРОСА К HERMES AGENT                       ║")
    ВывестиСтрокуВКонсоль("╚═══════════════════════════════════════════════════════════════════╝")
    СброситьЦветКонсоли()
    ВывестиСтрокуВКонсоль("")

    // ============================================================
    // 1. ОТПРАВКА ЗАПРОСА ЧЕРЕЗ CURL (с BAT-файлом)
    // ============================================================
    УстановитьЦветКонсоли("yellow")
    ВывестиСтрокуВКонсоль("--- 1. Отправка запроса ---")
    СброситьЦветКонсоли()
    
    сообщение = "Привет! Расскажи, что ты умеешь, коротко (2-3 предложения)."
    ВывестиСтрокуВКонсоль("📤 " + сообщение)
    ВывестиСтрокуВКонсоль("")

    // Формируем JSON тело
    jsonТело = "{\"model\":\"hermes-agent\",\"messages\":[{\"role\":\"user\",\"content\":\"" + сообщение + "\"}],\"stream\":false}"
    
    // Используем каталог Q:\temp
    файлJson = "Q:\\temp\\hermes_request.json"
    
    // Записываем JSON в файл
    Попытка
        файл = Новый QtФайл()
        файл.УстановитьИмяФайла(файлJson)
        
        Попытка
            Если файл.Существует() Тогда
                файл.Удалить()
            КонецЕсли
        Исключение
            // Игнорируем
        КонецПопытки
        
        режим = файл.Режим_ТолькоЗапись() | файл.Режим_Текст() | файл.Режим_Очистка()
        файл.Открыть(режим)
        файл.ЗаписатьСтроку(jsonТело)
        файл.Закрыть()
        
        ВывестиСтрокуВКонсоль("✅ JSON записан в файл: " + файлJson)
    Исключение
        УстановитьЦветКонсоли("red")
        ВывестиСтрокуВКонсоль("❌ Ошибка записи файла: " + e)
        СброситьЦветКонсоли()
        Пауза(5000)
        ЗавершитьПрограмму(0)
    КонецПопытки
    
    // Создаём BAT-файл с командой curl
    batФайл = "Q:\\temp\\curl_command.bat"
    batСодержимое = "@echo off\n" +
                    "curl -X POST http://localhost:8643/v1/chat/completions -H \"Authorization: Bearer Hermes_O\" -H \"Content-Type: application/json\" -d @" + файлJson + "\n"
    
    Попытка
        batФайлObj = Новый QtФайл()
        batФайлObj.УстановитьИмяФайла(batФайл)
        режим = batФайлObj.Режим_ТолькоЗапись() | batФайлObj.Режим_Текст() | batФайлObj.Режим_Очистка()
        batФайлObj.Открыть(режим)
        batФайлObj.ЗаписатьСтроку(batСодержимое)
        batФайлObj.Закрыть()
        ВывестиСтрокуВКонсоль("✅ BAT-файл создан: " + batФайл)
    Исключение
        УстановитьЦветКонсоли("red")
        ВывестиСтрокуВКонсоль("❌ Ошибка записи BAT-файла: " + e)
        СброситьЦветКонсоли()
        Пауза(5000)
        ЗавершитьПрограмму(0)
    КонецПопытки
    
    ВывестиСтрокуВКонсоль("⏳ Выполнение запроса...")

    // Запускаем BAT-файл
    процесс = Новый QtПроцесс()
    процесс.УстановитьРежимКаналов(процесс.ОбъединенныеКаналы())
    процесс.Запустить("cmd", ["/c", batФайл])
    
    // Ждём завершения (максимум 30 секунд)
    Если процесс.ОжидатьЗавершения(30000) Тогда
        вывод = процесс.ПрочитатьТекст()
        код = процесс.КодВыхода()
        
        // Удаляем временные файлы
        Попытка
            файл.УстановитьИмяФайла(файлJson)
            Если файл.Существует() Тогда
                файл.Удалить()
            КонецЕсли
        Исключение
            // Игнорируем
        КонецПопытки
        
        Попытка
            batФайлObj.УстановитьИмяФайла(batФайл)
            Если batФайлObj.Существует() Тогда
                batФайлObj.Удалить()
            КонецЕсли
        Исключение
            // Игнорируем
        КонецПопытки
        
        УстановитьЦветКонсоли("green")
        ВывестиСтрокуВКонсоль("✅ Команда выполнена (код: " + код + ")")
        СброситьЦветКонсоли()
        
        Если вывод != "" Тогда
            // Находим начало JSON
            начало = вывод.indexOf("{")
            Если начало > -1 Тогда
                чистыйВывод = вывод.substring(начало)
                
                Попытка
                    ответ = JSON.parse(чистыйВывод)
                    
                    Если ответ.error Тогда
                        УстановитьЦветКонсоли("red")
                        ВывестиСтрокуВКонсоль("❌ ОШИБКА API: " + ответ.error.message)
                        СброситьЦветКонсоли()
                    ИначеЕсли ответ.choices И ответ.choices.length > 0 Тогда
                        содержимое = ответ.choices[0].message.content
                        
                        УстановитьЦветКонсоли("green")
                        ВывестиСтрокуВКонсоль("📝 ОТВЕТ АГЕНТА:")
                        ВывестиСтрокуВКонсоль(содержимое)
                        СброситьЦветКонсоли()
                        
                        Если ответ.usage Тогда
                            ВывестиСтрокуВКонсоль("📊 Токены: prompt=" + ответ.usage.prompt_tokens + 
                                ", completion=" + ответ.usage.completion_tokens + 
                                ", total=" + ответ.usage.total_tokens)
                        КонецЕсли
                    Иначе
                        УстановитьЦветКонсоли("yellow")
                        ВывестиСтрокуВКонсоль("⚠️ Неожиданный формат ответа")
                        ВывестиСтрокуВКонсоль(чистыйВывод)
                        СброситьЦветКонсоли()
                    КонецЕсли
                Исключение
                    УстановитьЦветКонсоли("red")
                    ВывестиСтрокуВКонсоль("❌ Ошибка парсинга JSON: " + e)
                    ВывестиСтрокуВКонсоль("Данные: " + чистыйВывод)
                    СброситьЦветКонсоли()
                КонецПопытки
            Иначе
                УстановитьЦветКонсоли("red")
                ВывестиСтрокуВКонсоль("❌ JSON не найден в выводе")
                СброситьЦветКонсоли()
            КонецЕсли
        Иначе
            УстановитьЦветКонсоли("red")
            ВывестиСтрокуВКонсоль("❌ Нет вывода от команды")
            СброситьЦветКонсоли()
        КонецЕсли
    Иначе
        УстановитьЦветКонсоли("red")
        ВывестиСтрокуВКонсоль("❌ Таймаут! Процесс не завершился за 30 секунд")
        процесс.Завершить()
        СброситьЦветКонсоли()
    КонецЕсли
    
    // ============================================================
    // 2. ЗАВЕРШЕНИЕ
    // ============================================================
    УстановитьЦветКонсоли("yellow")
    ВывестиСтрокуВКонсоль("")
    ВывестиСтрокуВКонсоль("--- 2. Завершение ---")
    СброситьЦветКонсоли()

    УстановитьЦветКонсоли("cyan")
    ВывестиСтрокуВКонсоль("╔═══════════════════════════════════════════════════════════════════╗")
    ВывестиСтрокуВКонсоль("║                    СЦЕНАРИЙ ЗАВЕРШЕН                             ║")
    ВывестиСтрокуВКонсоль("╚═══════════════════════════════════════════════════════════════════╝")
    СброситьЦветКонсоли()
    
    Пауза(3000)
    ЗавершитьПрограмму(0)
