    });
    
    ДобавитьОбъектНаСтранице(1, "Кнопка", "btnReport4", {
        "Лево": 260, "Верх": 180, "Ширина": 220, "Высота": 40,
        "Заголовок": "📅 Отчёт по датам",
        "Родитель": "reportGroup",
