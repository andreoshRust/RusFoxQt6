// ============================================================
// РАБОТА СО СТРУКТУРАМИ (аналог JavaScript объектов)
// ============================================================

Пусть Тест = Структура(["Имя,лет", "Андрей", 30]);
Сообщить("Имя: " + Тест.Имя);
Сообщить("Возраст: " + Тест.лет);

// Способ 1: Перечисление ключей и значений
Пусть Пустое = Структура([]);
Пусть Время = Структура(["Часы,Минуты,Секунды", 12, 45, 33]);
Сообщить("Время " + Время.Часы + ":" + Время.Минуты + ":" + Время.Секунды);

// Способ 2: Пары ключ-значение
Пусть Человек = Структура(["Имя", "Иван", "Возраст", 30, "Город", "Москва"]);
Сообщить(Человек.Имя + ", " + Человек.Возраст + " года, город: " + Человек.Город);

// Способ 3: Клонирование объекта
Пусть Копия = Структура(Человек);
Копия.Имя = "Петр";
Сообщить("Оригинал: " + Человек.Имя + ", Копия: " + Копия.Имя);

// Способ 4: Пустая структура (словарь)
Пусть Данные = Структура([]);
Данные.НовыйКлюч = "Новое значение";
Данные.Число = 42;
Сообщить("Значение: " + Данные.НовыйКлюч + ", Число: " + Данные.Число);

// ============================================================
// РАБОТА С КЛЮЧАМИ И ЗНАЧЕНИЯМИ СТРУКТУРЫ
// ============================================================

Пусть Человек2 = Структура(["Имя,Возраст,Город", "Анна", 28, "Казань"]);

// Получение списка ключей
Пусть Ключи = СтруктураКлючи(Человек2);
Сообщить("Ключи структуры: " + Ключи.присоединить(", "));

// Получение списка значений
Пусть Значения = СтруктураЗначения(Человек2);
Сообщить("Значения структуры: " + Значения.присоединить(", "));

// Перебор всех полей структуры (ИСПРАВЛЕНО - используем обычный for)
Сообщить("Перебор структуры:");
Пусть ключи = СтруктураКлючи(Человек2);  Пусть Кол = 0;
Для (Пусть i = 0; i < ключи.length; i++) {
    Пусть ключ = ключи[i];
    Сообщить("  " + ключ + " = " + Человек2[ключ]);
    Кол = i
}
Если Кол НеРавно 2 Тогда Сообщить("??? Ошибка перебора структуры. "+Кол) Иначе Сообщить("Перебор структуры успешен !!!") КонецЕсли;


// ============================================================
// ПРИМЕРЫ ИСПОЛЬЗОВАНИЯ В РЕАЛЬНЫХ ЗАДАЧАХ
// ============================================================

// Пример 1: Настройки приложения
Пусть Настройки = Структура(["Тема,Язык,Автосохранение", "Темная", "Русский", ИСТИНА]);
Сообщить("Тема: " + Настройки.Тема + ", Язык: " + Настройки.Язык);

// Пример 2: Данные пользователя
Пусть Пользователь = Структура(["Логин,Пароль,Активен,Роль",    "admin", "12345", ИСТИНА, "Администратор" ]);

Если (Пользователь.Активен) Тогда
    Сообщить("Пользователь " + Пользователь.Логин + " активен. Роль: " + Пользователь.Роль);
КонецЕсли;

// Пример 3: Товар в каталоге
Пусть Товар = Структура(["Код,Название,Цена,Количество", 1001, "Ноутбук", 45000, 10]);
Товар.Количество = 8;
Сообщить("Товар: " + Товар.Название + ", Цена: " + Товар.Цена + " руб., Остаток: " + Товар.Количество + " шт.");

// Пример 4: Массив структур
Пусть Сотрудники = [];

Сотрудники[0] = Структура(["Имя,Отдел,Оклад", "Иванов", "IT", 80000]);
Сотрудники[1] = Структура(["Имя,Отдел,Оклад", "Петрова", "Бухгалтерия", 70000]);
Сотрудники[2] = Структура(["Имя,Отдел,Оклад", "Сидоров", "IT", 85000]);

Сообщить("Список сотрудников:");
Для (Пусть i = 0; i < Сотрудники.длина; i++) {
    Пусть сотр = Сотрудники[i];
    Сообщить("  " + сотр.Имя + " - " + сотр.Отдел + " - " + сотр.Оклад + " руб.");
}

// Подсчет суммарного оклада IT отдела
Пусть Итого = 0;
Для (Пусть i = 0; i < Сотрудники.длина; i++) {
    Если (Сотрудники[i].Отдел === "IT") Тогда
        Итого = Итого + Сотрудники[i].Оклад;
    КонецЕсли;
}
Сообщить("Суммарный оклад IT отдела: " + Итого + " руб.");

// Пример 5: Вложенные структуры
Пусть Организация = Структура([]);
Организация.Название = "ООО Ромашка";
Организация.Адрес = Структура(["Город,Улица,Дом", "Москва", "Тверская", 15]);
Организация.Директор = Структура(["ФИО,Телефон,Email", "Петров И.И.", "+7(495)123-45-67", "director@romashka.ru"]);

Сообщить("Организация: " + Организация.Название);
Сообщить("Адрес: г." + Организация.Адрес.Город + ", ул." + Организация.Адрес.Улица + ", д." + Организация.Адрес.Дом);
Сообщить("Директор: " + Организация.Директор.ФИО + ", тел." + Организация.Директор.Телефон);



