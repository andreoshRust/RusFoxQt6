// 1С  Соответствие
// ============================================================
  // Создание соответствия
    Пусть Цвета = Соответствие(["Красный", "#FF0000", "Зеленый", "#00FF00", "Синий", "#0000FF"]);
    
    // Добавление элемента
    Цвета.добавить("Желтый", "#FFFF00");
    
    // Получение значения
    Пусть код = Цвета.получить("Красный");
    Сообщить("Красный: " + код);
    
    // Проверка наличия
    Если Цвета.есть("Зеленый") Тогда
        Сообщить("Зеленый есть в словаре")
    КонецЕсли
    
    // Количество элементов
    Сообщить("Всего цветов: " + Цвета.количество());
    
    // Получение всех ключей и значений (используем другие имена)
    Пусть всеКлючи = КлючиСоответствия(Цвета);
    Пусть всеЗначения = ЗначенияСоответствия(Цвета);
    
    // Обход
    Для (Пусть i = 0; i < всеКлючи.длина; i++) {
        Сообщить(всеКлючи[i] + " = " + всеЗначения[i]);
    }
    
    // Удаление элемента
    Цвета.удалить("Зеленый");
    Сообщить("После удаления: " + Цвета.Количество());
    
    // Очистка
    Цвета.очистить();
    Сообщить("После очистки: " + Цвета.Количество());
    
    // Пустое соответствие
    Пусть Пустое2 = Соответствие([]);
    Пустое2.вставить("Ключ", "Значение");
    Сообщить("Пустое.Количество(): " + Пустое2.Количество());
    
// ============================================================
