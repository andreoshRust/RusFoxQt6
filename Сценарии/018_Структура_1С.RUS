// 1С  ТаблицаЗначений
// ============================================================
        // Создание таблицы значений
    Пусть Таблица = ТаблицаЗначений({});
    
    // Добавление колонок
    Таблица.ДобавитьКолонку("ID", "number", 50);
    Таблица.ДобавитьКолонку("ФИО", "string", 200);
    Таблица.ДобавитьКолонку("Возраст", "number", 80);
    Таблица.ДобавитьКолонку("Активен", "boolean", 80);
    
    // Добавление строк
    Пусть строка1 = Таблица.ДобавитьСтроку();
    Таблица.УстановитьЗначение(строка1, "ID", 1);
    Таблица.УстановитьЗначение(строка1, "ФИО", "Иванов Иван");
    Таблица.УстановитьЗначение(строка1, "Возраст", 30);
    Таблица.УстановитьЗначение(строка1, "Активен", true);
    
    Пусть строка2 = Таблица.ДобавитьСтроку();
    Таблица.УстановитьЗначение(строка2, "ID", 2);
    Таблица.УстановитьЗначение(строка2, "ФИО", "Петров Петр");
    Таблица.УстановитьЗначение(строка2, "Возраст", 25);
    Таблица.УстановитьЗначение(строка2, "Активен", true);
    
