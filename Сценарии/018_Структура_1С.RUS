    Месяцы.Вставить(0, 0, "-- Выберите --");
    
    // Получение информации
    Для (Пусть i = 0; i < Месяцы.Количество(); i++) {
        Пусть значение = Месяцы.ПолучитьЗначение(i);
        Пусть представление = Месяцы.ПолучитьПредставление(i);
        Пусть пометка = Месяцы.ПолучитьПометку(i);
        Пусть отметка = Месяцы.ПолучитьОтметку(i);
        Сообщить(i + ": " + представление + " (" + значение + 
                 ") пометка=" + пометка + " отметка=" + отметка);
    }
    
    // Поиск
    Пусть idx = Месяцы.НайтиПоЗначению(3);
    Сообщить("Индекс марта: " + idx);
    

