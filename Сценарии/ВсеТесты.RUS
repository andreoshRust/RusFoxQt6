//#Область Тест SQLite

Пусть Глоб_путьБД_SQLite = "test.db"

Функция СоздатьОкноSQLite()
    Пусть имяОкна = "ОкноSQLite"
    СоздатьПодокноMDI(Глоб_mdi, имяОкна, 10, 10, 920, 680)  // Создаём MDI окно
    СоздатьВкладки("ВкладкиSQLite", { "Лево": 5, "Верх": 5, "Ширина": 880, "Высота": 610, "Вкладки": "SQLite-тест" }, имяОкна)
        
    // ========== ГРУППА 1: ИНИЦИАЛИЗАЦИЯ ==========    
    ДобавитьОбъектНаСтранице(1, "Группа", "Группа1", { "Лево": 10, "Верх": 10, "Ширина": 280, "Высота": 80, "Заголовок": "1. Инициализация", "Родитель": "ВкладкиSQLite" })
    ДобавитьОбъектНаСтранице(1, "Кнопка", "КнопкаИнициализация", { "Лево": 10, "Верх": 30, "Ширина": 260, "Высота": 35, "Заголовок": "Создать БД и таблицу", "Родитель": "Группа1" })
       ПриНажатииКнопки("КнопкаИнициализация", Функция() {
        ДобавитьВЛогSQLite("Инициализация...")
        ИнициализироватьБазуSQLite()
    })   
    
    // ========== ГРУППА 2: ДОБАВЛЕНИЕ ДАННЫХ ==========
    ДобавитьОбъектНаСтранице(1, "Группа", "Группа2", { "Лево": 300, "Верх": 10, "Ширина": 280, "Высота": 130, "Заголовок": "2. Добавление данных", "Родитель": "ВкладкиSQLite" })
    ДобавитьОбъектНаСтранице(1, "Кнопка", "КнопкаДобавить", {  "Лево": 10, "Верх": 30, "Ширина": 260, "Высота": 35,  "Заголовок": "Добавить одного", "Родитель": "Группа2" })
      ПриНажатииКнопки("КнопкаДобавить", Функция() {
          ДобавитьСотрудникаSQLite("Иван Петров", "Инженер", 85000, "IT", "01.04.2023")
          ПоказатьВсехSQLite()
      })
    ДобавитьОбъектНаСтранице(1, "Кнопка", "КнопкаМассово", { "Лево": 10, "Верх": 75, "Ширина": 260, "Высота": 35, "Заголовок": "Добавить 4 записи", "Родитель": "Группа2" })
      ПриНажатииКнопки("КнопкаМассово", Функция() {
          МассоваяВставкаSQLite()
          ПоказатьВсехSQLite()
      }) 
    
    // ========== ГРУППА 3: ПРОСМОТР ==========
    ДобавитьОбъектНаСтранице(1, "Группа", "Группа3", { "Лево": 590, "Верх": 10, "Ширина": 280, "Высота": 80, "Заголовок": "3. Просмотр данных", "Родитель": "ВкладкиSQLite" })
    ДобавитьОбъектНаСтранице(1, "Кнопка", "КнопкаПоказать", { "Лево": 10, "Верх": 30, "Ширина": 260, "Высота": 35,  "Заголовок": "Показать всех", "Родитель": "Группа3" })
       ПриНажатииКнопки("КнопкаПоказать", Функция() {   ПоказатьВсехSQLite()    })     

    // ========== ГРУППА 4: УДАЛЕНИЕ ==========
    ДобавитьОбъектНаСтранице(1, "Группа", "Группа4", { "Лево": 10, "Верх": 110, "Ширина": 280, "Высота": 80, "Заголовок": "4. Удаление данных", "Родитель": "ВкладкиSQLite" })
    ДобавитьОбъектНаСтранице(1, "Кнопка", "КнопкаУдалитьВсех", { "Лево": 10, "Верх": 30, "Ширина": 260, "Высота": 35, "Заголовок": "Удалить всех", "Родитель": "Группа4" })
      ПриНажатииКнопки("КнопкаУдалитьВсех", Функция() {    УдалитьВсехSQLite()  })
    
    // ========== ГРУППА 5: РЕЗУЛЬТАТЫ  ==========
    ДобавитьОбъектНаСтранице(1, "Группа", "ГруппаРезультаты", { "Лево": 10, "Верх": 200, "Ширина": 860, "Высота": 420, "Заголовок": "Результаты", "Родитель": "ВкладкиSQLite" })
    ДобавитьОбъектНаСтранице(1, "ТекстоваяОбласть", "РезультатSQLite", { "Лево": 10, "Верх": 25, "Ширина": 840, "Высота": 375, "Значение": "Нажмите 'Создать БД и таблицу' для начала",
        "Родитель": "ГруппаРезультаты" })

КонецФункции

Функция ОбновитьРезультатSQLite(текст)
    Пусть область = ПолучитьВиджет("РезультатSQLite")
    Если область Тогда
        область.установитьПростойТекст(текст)
    КонецЕсли;
    Возврат ИСТИНА
КонецФункции

Функция ДобавитьВЛогSQLite(текст)
    Пусть область = ПолучитьВиджет("РезультатSQLite")
    Если область Тогда
        Пусть текущий = область.простойТекст
        область.установитьПростойТекст(текущий + "\n" + текст)
    КонецЕсли;
    Возврат ИСТИНА
КонецФункции

Функция ИнициализироватьБазуSQLite()
    Если ОткрытьБазуДанных(Глоб_путьБД_SQLite) Тогда
        ДобавитьВЛогSQLite("[OK] База данных открыта")
        
        Пусть sql = "CREATE TABLE IF NOT EXISTS employees (" +
                    "id INTEGER PRIMARY KEY AUTOINCREMENT, " +
                    "name TEXT NOT NULL, " +
                    "position TEXT, " +
                    "salary INTEGER, " +
                    "department TEXT, " +
                    "hire_date TEXT)"
        
        Если ВыполнитьЗапрос(sql) Тогда
            ДобавитьВЛогSQLite("[OK] Таблица 'employees' создана")
        Иначе
            ДобавитьВЛогSQLite("[ERR] Ошибка: " + ПоследняяОшибка())
        КонецЕсли;
        
        ЗакрытьБазуДанных()
        Возврат ИСТИНА
    Иначе
        ДобавитьВЛогSQLite("[ERR] Ошибка открытия: " + ПоследняяОшибка())
        Возврат ЛОЖЬ
    КонецЕсли;
КонецФункции

Функция ДобавитьСотрудникаSQLite(имя, должность, зарплата, отдел, дата)
    Если ОткрытьБазуДанных(Глоб_путьБД_SQLite) Тогда
        ПодготовитьЗапрос("INSERT INTO employees (name, position, salary, department, hire_date) VALUES (:name, :position, :salary, :department, :hire_date)")
        СвязатьЗначение("name", имя)
        СвязатьЗначение("position", должность)
        СвязатьЗначение("salary", зарплата)
        СвязатьЗначение("department", отдел)
        СвязатьЗначение("hire_date", дата)
        
        Если ВыполнитьПодготовленный() Тогда
            ДобавитьВЛогSQLite("[OK] Добавлен: " + имя)
            ЗакрытьБазуДанных()
            Возврат ИСТИНА
        Иначе
            ДобавитьВЛогSQLite("[ERR] Ошибка: " + ПоследняяОшибка())
            ЗакрытьБазуДанных()
            Возврат ЛОЖЬ
        КонецЕсли;
    КонецЕсли;
    Возврат ЛОЖЬ
КонецФункции

Функция ПоказатьВсехSQLite()
    Если ОткрытьБазуДанных(Глоб_путьБД_SQLite) Тогда
        Пусть результат = ВыполнитьЗапросСРезультатом("SELECT * FROM employees ORDER BY id")
        
        Если результат.length > 0 Тогда
            Пусть текст = "=== СПИСОК СОТРУДНИКОВ ===\n"
            текст = текст + "-------------------------------\n"
            
            Для i = 0 По результат.length - 1 Цикл
                Пусть row = результат[i]
                текст = текст + "ID: " + row.id + "\n"
                текст = текст + "  Имя: " + row.name + "\n"
                текст = текст + "  Должность: " + row.position + "\n"
                текст = текст + "  Зарплата: " + row.salary + " руб.\n"
                текст = текст + "  Отдел: " + row.department + "\n"
                текст = текст + "  Дата приема: " + row.hire_date + "\n"
                текст = текст + "-------------------------------\n"
            КонецЦикла;
            текст = текст + "Всего: " + результат.length
            ОбновитьРезультатSQLite(текст)
        Иначе
            ОбновитьРезультатSQLite("Нет сотрудников. Добавьте их через кнопки.")
        КонецЕсли;
        
        ЗакрытьБазуДанных()
        Возврат результат.length
    КонецЕсли;
    Возврат 0
КонецФункции

Функция МассоваяВставкаSQLite()
    Если ОткрытьБазуДанных(Глоб_путьБД_SQLite) Тогда
        НачатьТранзакцию()
        
        Пусть данные = [
            {"name": "Анна Смирнова", "position": "Менеджер", "salary": 75000, "department": "Продажи", "hire_date": "15.03.2021"},
            {"name": "Дмитрий Козлов", "position": "Разработчик", "salary": 90000, "department": "IT", "hire_date": "10.01.2022"},
            {"name": "Елена Морозова", "position": "Аналитик", "salary": 80000, "department": "Аналитика", "hire_date": "20.06.2021"},
            {"name": "Сергей Новиков", "position": "Тестировщик", "salary": 65000, "department": "IT", "hire_date": "05.09.2022"}
        ]
        
        Пусть успех = ИСТИНА
        Для i = 0 По данные.length - 1 Цикл
            Пусть d = данные[i]
            ПодготовитьЗапрос("INSERT INTO employees (name, position, salary, department, hire_date) VALUES (:name, :position, :salary, :department, :hire_date)")
            СвязатьЗначение("name", d.name)
            СвязатьЗначение("position", d.position)
            СвязатьЗначение("salary", d.salary)
            СвязатьЗначение("department", d.department)
            СвязатьЗначение("hire_date", d.hire_date)
            
            Если НЕ ВыполнитьПодготовленный() Тогда
                успех = ЛОЖЬ
                ДобавитьВЛогSQLite("[ERR] Ошибка: " + d.name)
                Прервать;
            КонецЕсли;
        КонецЦикла;
        
        Если успех Тогда
            ПодтвердитьТранзакцию()
            ДобавитьВЛогSQLite("[OK] Массовая вставка: добавлено " + данные.length + " записей")
        Иначе
            ОткатитьТранзакцию()
            ДобавитьВЛогSQLite("[ERR] Массовая вставка отменена")
        КонецЕсли;
        
        ЗакрытьБазуДанных()
    КонецЕсли;
КонецФункции

Функция УдалитьВсехSQLite()
    Если Подтвердить("Удалить всех сотрудников?") Тогда
        Если ОткрытьБазуДанных(Глоб_путьБД_SQLite) Тогда
            Если ВыполнитьЗапрос("DELETE FROM employees") Тогда
                ДобавитьВЛогSQLite("[OK] Таблица очищена")
                ОбновитьРезультатSQLite("Таблица очищена")
            Иначе
                ДобавитьВЛогSQLite("[ERR] Ошибка: " + ПоследняяОшибка())
            КонецЕсли;
            ЗакрытьБазуДанных()
        КонецЕсли;
    КонецЕсли;
КонецФункции


//#КонецОбласти

//#Область Тест Python
Функция СоздатьОкноТестPython()
    Пусть имяОкна = "ОкноТестPython"
    СоздатьПодокноMDI(Глоб_mdi, имяОкна, 10, 10, 820, 680)  // Создаём MDI окно
    СоздатьВкладки("ВкладкиТестPython", { "Лево": 5, "Верх": 5, "Ширина": 880, "Высота": 610, "Вкладки": "Python-тест" }, имяОкна)
    
    // ========== ГРУППА ДЛЯ КОДА PYTHON ==========
    ДобавитьОбъектНаСтранице(1, "Группа", "ГруппаКод", { "Лево": 10, "Верх": 10, "Ширина": 620, "Высота": 150, "Заголовок": "Python код", "Родитель": "ВкладкиТестPython" })
    ДобавитьОбъектНаСтранице(1, "ТекстоваяОбласть", "ПолеКода", {   "Лево": 10, "Верх": 25, "Ширина": 600, "Высота": 110,
        "Значение": "print('Hello from Python!')\nprint('Second line')\nprint('Third line')",  "Родитель": "ГруппаКод" })
    
    // ========== ГРУППА ДЛЯ КНОПОК ==========
    ДобавитьОбъектНаСтранице(1, "Группа", "ГруппаКнопки", { "Лево": 10, "Верх": 170, "Ширина": 620, "Высота": 150, "Заголовок": "Управление", "Родитель": "ВкладкиТестPython" })
    ДобавитьОбъектНаСтранице(1, "Кнопка", "КнопкаВыполнить", { "Лево": 10, "Верх": 30, "Ширина": 190, "Высота": 35, "Заголовок": "Выполнить Python", "Родитель": "ГруппаКнопки" })
        ПриНажатииКнопки("КнопкаВыполнить", Функция() { ВыполнитьPythonТест()  })
    ДобавитьОбъектНаСтранице(1, "Кнопка", "КнопкаОчистить", { "Лево": 210, "Верх": 30, "Ширина": 190, "Высота": 35, "Заголовок": "Очистить вывод", "Родитель": "ГруппаКнопки" })
        ПриНажатииКнопки("КнопкаОчистить", Функция() {   ОчиститьРезультатPython()   })
    ДобавитьОбъектНаСтранице(1, "Кнопка", "КнопкаПример", {  "Лево": 410, "Верх": 30, "Ширина": 190, "Высота": 35, "Заголовок": "Загрузить пример", "Родитель": "ГруппаКнопки" })
        ПриНажатииКнопки("КнопкаПример", Функция() {    ЗагрузитьПримерPython()    })
    
    // ========== ГРУППА ДЛЯ РЕЗУЛЬТАТА ==========
    ДобавитьОбъектНаСтранице(1, "Группа", "ГруппаРезультат", { "Лево": 10, "Верх": 300, "Ширина": 620, "Высота": 270, "Заголовок": "Результат выполнения", "Родитель": "ВкладкиТестPython" })
    ДобавитьОбъектНаСтранице(1, "ТекстоваяОбласть", "РезультатPython", { "Лево": 10, "Верх": 25, "Ширина": 600, "Высота": 250, 
        "Значение": "Нажмите 'Выполнить Python' для запуска кода", "Родитель": "ГруппаРезультат" })
КонецФункции

Функция ВыполнитьPythonТест()
    Сообщить("=== Выполнение Python кода ===")
    Пусть код = ПолучитьЗначениеВиджета("ПолеКода")   // Получаем код из текстовой области через специальную функцию
    Сообщить("Код длина: " + код.длина)
    Если код.длина == 0 Тогда
        ПоказатьСообщение("Введите Python код для выполнения!")
        Возврат ЛОЖЬ
    КонецЕсли;
    Пусть результат = ВыполнитьPython(код)   // Выполняем Python код
    УстановитьЗначениеВиджета("РезультатPython", результат)   // Выводим в текстовую область через специальную функцию
    Возврат ИСТИНА
КонецФункции

Функция ДобавитьВРезультат(текст)
    Пусть область = ПолучитьВиджет("РезультатPython")
    Если область Тогда
        область.добавлять(текст)
    КонецЕсли;
    Возврат ИСТИНА
КонецФункции

Функция ОчиститьРезультатPython()
    Пусть область = ПолучитьВиджет("РезультатPython")
    Если область Тогда
        область.установитьПростойТекст("Результат очищен. Нажмите 'Выполнить Python' для нового запуска.")
    КонецЕсли;
    ПоказатьСообщение("Результат очищен")
    Возврат ИСТИНА
КонецФункции

Функция ЗагрузитьПримерPython()
    Пусть примерКода = "print('=== ПРИМЕР РАБОТЫ PYTHON ===')\n" +
                       "print()\n" +
                       "# Простые вычисления\n" +
                       "a = 10\n" +
                       "b = 20\n" +
                       "print(f'Сумма: {a} + {b} = {a + b}')\n" +
                       "print()\n" +
                       "# Работа со списком\n" +
                       "numbers = [1, 2, 3, 4, 5]\n" +
                       "print(f'Список: {numbers}')\n" +
                       "print(f'Сумма элементов: {sum(numbers)}')\n" +
                       "print()\n" +
                       "# Условный оператор\n" +
                       "x = 42\n" +
                       "if x > 0:\n" +
                       "    print(f'Число {x} положительное')\n" +
                       "else:\n" +
                       "    print(f'Число {x} отрицательное')\n" +
                       "print()\n" +
                       "# Цикл\n" +
                       "for i in range(3):\n" +
                       "    print(f'Итерация {i+1}')\n" +
                       "print()\n" +
                       "print('=== ВЫПОЛНЕНИЕ ЗАВЕРШЕНО ===')"
    
    Пусть полеКода = ПолучитьВиджет("ПолеКода")
    Если полеКода Тогда
        полеКода.установитьПростойТекст(примерКода)
        ПоказатьСообщение("Пример кода загружен! Нажмите 'Выполнить Python'")
    КонецЕсли;
    
    Возврат ИСТИНА
КонецФункции


