// Глобальные переменные
Пусть Глоб_mdi

Пусть Глоб_СерверЗапущен = ЛОЖЬ
Пусть Глоб_ЛогБуфер_LO = ""
Пусть Глоб_ТестБуфер = ""
Пусть Глоб_СчетчикТаймера = 0

ПРОЦЕДУРА Старт()
//#ОтладкаПрепроцессора
    Пусть mainWindow = ПолучитьГлавноеОкно()   // Получаем главное окно
    ОкноСуществует(mainWindow)
    ЗадатьРазмерыГлавногоОкна(1350,750)
    СоздатьМенюПрограммы(mainWindow)
    Глоб_mdi = ДобавитьОбластьMDI("mdiArea1", { "Ширина": 1300, "Высота": 1000 })  // ========== СОЗДАНИЕ MDI ОБЛАСТИ ==========
   
    // ========== СОЗДАНИЕ НАЧАЛЬНЫХ ОКОН ==========
    //СоздатьОкно("ОкноВиджеты");   
    //СоздатьОкно("Окно2");      СоздатьОкно("Окно3");
    
    ПоказатьГлавноеОкно()   // Показываем главное окно
КОНЕЦПРОЦЕДУРЫ

Функция СоздатьМенюПрограммы(mainWindow)   // ========== СОЗДАНИЕ МЕНЮ ==========
    Пусть menuBar = СоздатьСтрокуМеню(mainWindow)
    УстановитьМеню(menuBar)
    
    // =======================  Окна  =======================================================
    Пусть windowsMenu = СоздатьМеню("Окна", mainWindow)
        ДобавитьПунктМеню(menuBar, windowsMenu)
    Пусть ОкноВиджеты = СоздатьДействие("Тест виджетов", mainWindow)
        ДобавитьДействиеМеню(windowsMenu, ОкноВиджеты)
        УстановитьГорячуюКлавишу(ОкноВиджеты, "Ctrl+1")
        ОкноВиджеты.УстановитьДействие( Функция() { СоздатьОкно("ОкноВиджеты") })
    Пусть ОкноЖурналИзменений = СоздатьДействие("Изменения в программе", mainWindow)
        ДобавитьДействиеМеню(windowsMenu, ОкноЖурналИзменений)
        УстановитьГорячуюКлавишу(ОкноЖурналИзменений, "Ctrl+2")
        ОкноЖурналИзменений.УстановитьДействие( Функция() { СоздатьОкно("ОкноЖурналИзменений") })
    Пусть ОкноHTTP = СоздатьДействие("Тест HTTP", mainWindow)
        ДобавитьДействиеМеню(windowsMenu, ОкноHTTP)
        УстановитьГорячуюКлавишу(ОкноHTTP, "Ctrl+3")
        ОкноHTTP.УстановитьДействие( Функция() { СоздатьОкноHTTP() })
    Пусть ОкноSQLite = СоздатьДействие("Тест SQLite", mainWindow)
        ДобавитьДействиеМеню(windowsMenu, ОкноSQLite)
        УстановитьГорячуюКлавишу(ОкноSQLite, "Ctrl+4")
        ОкноSQLite.УстановитьДействие( Функция() { СоздатьОкноSQLite() })
    Пусть ОкноТестPython = СоздатьДействие("Тест Python", mainWindow)
        ДобавитьДействиеМеню(windowsMenu, ОкноТестPython)
        УстановитьГорячуюКлавишу(ОкноТестPython, "Ctrl+5")
        ОкноТестPython.УстановитьДействие( Функция() { СоздатьОкноТестPython() })
    Пусть ОкноLibraOffice = СоздатьДействие("Сервер отчетов LibraOffice", mainWindow)
        ДобавитьДействиеМеню(windowsMenu, ОкноLibraOffice)
        УстановитьГорячуюКлавишу(ОкноLibraOffice, "Ctrl+6")
        ОкноLibraOffice.УстановитьДействие( Функция() { СоздатьОкноLibraOffice() })
    Пусть ОкноТестФункции1С = СоздатьДействие("Тест функций 1С", mainWindow)
        ДобавитьДействиеМеню(windowsMenu, ОкноТестФункции1С)
        УстановитьГорячуюКлавишу(ОкноТестФункции1С, "Ctrl+7")
        ОкноТестФункции1С.УстановитьДействие( Функция() { СоздатьОкноТестФункции1С() })
        
    ДобавитьЧертуРазделителяМеню(windowsMenu)

    Пусть ДействиеЗакрытьВсеОкна = СоздатьДействие("Закрыть все окна", mainWindow)
        ДобавитьДействиеМеню(windowsMenu, ДействиеЗакрытьВсеОкна)
        УстановитьГорячуюКлавишу(ДействиеЗакрытьВсеОкна, "Ctrl+Shift+W")
        ДействиеЗакрытьВсеОкна.УстановитьДействие( Функция() {   ЗакрытьВсеОкна()     })
    Пусть СписокОкон = СоздатьДействие("Список окон", mainWindow)
        ДобавитьДействиеМеню(windowsMenu, СписокОкон)
        УстановитьГорячуюКлавишу(СписокОкон, "Ctrl+S")
        СписокОкон.УстановитьДействие( Функция() {  Пусть окна = СписокMDIОкон()  
            Если окна.length > 0 Тогда      ПоказатьСообщение("Открытые окна:\n" + окна.join("\n"));     
            Иначе    ПоказатьСообщение("Нет открытых окон")
            КонецЕсли;    })
    Пусть ОкнаПлиткой = СоздатьДействие("Расположить Плиткой", mainWindow)
        ДобавитьДействиеМеню(windowsMenu, ОкнаПлиткой)
        ОкнаПлиткой.УстановитьДействие( Функция() {  Глоб_mdi.РасположитьПлиткой() })
    Пусть ОкнаКаскадом = СоздатьДействие("Расположить Каскадом", mainWindow)
        ДобавитьДействиеМеню(windowsMenu, ОкнаКаскадом)
        ОкнаКаскадом.УстановитьДействие( Функция() {  Глоб_mdi.РасположитьКаскадом() })
    

    // =======================  Тесты Qt-объектов  ===========================================
    Пусть QtMenu = СоздатьМеню("Тесты Qt-объектов", mainWindow)
        ДобавитьПунктМеню(menuBar, QtMenu)
    Пусть ОкноТестQtФайл = СоздатьДействие("ТестQt Файлы и Каталоги", QtMenu)
        ДобавитьДействиеМеню(QtMenu, ОкноТестQtФайл)
        УстановитьГорячуюКлавишу(ОкноТестQtФайл, "Ctrl+8")
        ОкноТестQtФайл.УстановитьДействие( Функция() { СоздатьОкноТестQtФайл() })
    Пусть ОкноТестQtТаймер = СоздатьДействие("ТестQt Таймер и Настройки", QtMenu)
        ДобавитьДействиеМеню(QtMenu, ОкноТестQtТаймер)
        УстановитьГорячуюКлавишу(ОкноТестQtТаймер, "Ctrl+9")
        ОкноТестQtТаймер.УстановитьДействие( Функция() { СоздатьОкноТестQtТаймер() })
    Пусть ОкноТестQtКонтейнеры = СоздатьДействие("ТестQt Контейнеры", QtMenu)
        ДобавитьДействиеМеню(QtMenu, ОкноТестQtКонтейнеры)
        ОкноТестQtКонтейнеры.УстановитьДействие( Функция() { СоздатьОкноТестQtКонтейнеры() })

    Возврат ИСТИНА
КонецФункции    

Функция ОкноСуществует(имя)   // ========== ФУНКЦИЯ ПРОВЕРКИ СУЩЕСТВОВАНИЯ ОКНА ========== 
    Пусть список = СписокMDIОкон()
    Пусть i = 0
    Пока i < список.length Цикл
        Если список[i] == имя Тогда
            Возврат ИСТИНА
        КонецЕсли;
        i = i + 1
    КонецЦикла;
    Возврат ЛОЖЬ
КонецФункции

Функция СоздатьОкно(имя)   // ========== ФУНКЦИЯ СОЗДАНИЯ ОКНА ==========
    Если ОкноСуществует(имя) Тогда      АктивироватьMDIОкно(имя);   Возврат     КонецЕсли;
    Если имя == "ОкноВиджеты" Тогда СоздатьОкноВиджеты();   Возврат  КонецЕсли;
    Если имя == "ОкноЖурналИзменений" Тогда СоздатьОкноЖурналИзменений();   Возврат  КонецЕсли;
    Если имя == "Окно3" Тогда СоздатьОкно3();   Возврат  КонецЕсли;
КонецФункции

//#Область Тестирование виджетов
Функция СоздатьОкноВиджеты()
    Пусть ИмяОкна = "ОкноВиджеты"
    СоздатьПодокноMDI(Глоб_mdi, ИмяОкна, 10, 10, 1050, 700)
    
    СоздатьВкладки("Вкладки1", {  "Лево": 10, "Верх": 10, "Ширина": 1000, "Высота": 650, "Вкладки": "Кнопки,Текст,Списки,Числа,Даты,Таблица,Контейнеры" }, ИмяОкна)
    
    // Заполнение страниц виджетами
//ПоказатьСообщение("СоздатьОкноВиджеты")
    Страница1_КнопкиИПереключатели("Вкладки1",0)
    Страница2_ТекстовыеВиджеты("Вкладки1",1)
    Страница3_Списки("Вкладки1",2)
    Страница4_ЧисловыеВиджеты("Вкладки1",3)
    Страница5_ДатаВремя("Вкладки1",4)
    Страница6_ТаблицаДанных("Вкладки1",5)
    Страница7_Контейнеры("Вкладки1",6)
    
КонецФункции

// ----------------------------------------------------------------------------
// СТРАНИЦА 1: КНОПКИ И ПЕРЕКЛЮЧАТЕЛИ
// ----------------------------------------------------------------------------
Функция Страница1_КнопкиИПереключатели(ИмяВкладок, НомерВкладки)
    СверхуОтступ = 20
    
    // ========== ГРУППА ЦВЕТНЫХ КНОПОК ==========
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Группа", "ГруппаЦветныеКнопки", { "Лево": 10, "Верх": 30, "Ширина": 500, "Высота": 220, 
                           "Заголовок": "🎨 Цветные кнопки с эффектами" })
    
    ДобавитьОбъектНаСтранице(0, "Кнопка", "КнопкаКрасная", { "Лево": 20, "Верх": 30, "Ширина": 140, "Высота": 40, "Заголовок": "❤️ Красная" }, "ГруппаЦветныеКнопки")
    УстановитьСтиль("КнопкаКрасная", "QPushButton { background-color: #e74c3c; color: white; font-weight: bold; border-radius: 8px; } "+
                                       "QPushButton:hover { background-color: #c0392b; } QPushButton:pressed { background-color: #a93226; }")
        ПриНажатииКнопки("КнопкаКрасная", Функция() { ПоказатьСообщение("🔴 Красная кнопка нажата!") })
    
    ДобавитьОбъектНаСтранице(0, "Кнопка", "КнопкаЗеленая", { "Лево": 180, "Верх": 30, "Ширина": 140, "Высота": 40, "Заголовок": "✅ Зеленая" }, "ГруппаЦветныеКнопки")
    УстановитьСтиль("КнопкаЗеленая", "QPushButton { background-color: #2ecc71; color: white; font-weight: bold; border-radius: 8px; } "+
                                       "QPushButton:hover { background-color: #27ae60; } QPushButton:pressed { background-color: #1e8449; }")
        ПриНажатииКнопки("КнопкаЗеленая", Функция() { ПоказатьСообщение("🟢 Зеленая кнопка нажата!") })
    
    ДобавитьОбъектНаСтранице(0, "Кнопка", "КнопкаСиняя", { "Лево": 340, "Верх": 30, "Ширина": 140, "Высота": 40, "Заголовок": "💙 Синяя" }, "ГруппаЦветныеКнопки")
    УстановитьСтиль("КнопкаСиняя", "QPushButton { background-color: #3498db; color: white; font-weight: bold; border-radius: 8px; } "+
                                       "QPushButton:hover { background-color: #2980b9; } QPushButton:pressed { background-color: #1f618d; }")
        ПриНажатииКнопки("КнопкаСиняя", Функция() { ПоказатьСообщение("🔵 Синяя кнопка нажата!") })
    
    ДобавитьОбъектНаСтранице(0, "Кнопка", "КнопкаЖелтая", { "Лево": 20, "Верх": 90, "Ширина": 140, "Высота": 40, "Заголовок": "⭐ Желтая" }, "ГруппаЦветныеКнопки")
    УстановитьСтиль("КнопкаЖелтая", "QPushButton { background-color: #f1c40f; color: #2c3e50; font-weight: bold; border-radius: 8px; } "+
                                        "QPushButton:hover { background-color: #f39c12; } QPushButton:pressed { background-color: #e67e22; }")
        ПриНажатииКнопки("КнопкаЖелтая", Функция() { ПоказатьСообщение("🟡 Желтая кнопка нажата!") })
    
    ДобавитьОбъектНаСтранице(0, "Кнопка", "КнопкаПурпурная", { "Лево": 180, "Верх": 90, "Ширина": 140, "Высота": 40, "Заголовок": "💜 Пурпурная" }, "ГруппаЦветныеКнопки")
    УстановитьСтиль("КнопкаПурпурная", "QPushButton { background-color: #9b59b6; color: white; font-weight: bold; border-radius: 8px; } "+
                                       "QPushButton:hover { background-color: #8e44ad; } QPushButton:pressed { background-color: #7d3c98; }")
        ПриНажатииКнопки("КнопкаПурпурная", Функция() { ПоказатьСообщение("🟣 Пурпурная кнопка нажата!") })
    
    ДобавитьОбъектНаСтранице(0, "Кнопка", "КнопкаБирюзовая", { "Лево": 340, "Верх": 90, "Ширина": 140, "Высота": 40, "Заголовок": "💚 Бирюзовая" }, "ГруппаЦветныеКнопки")
    УстановитьСтиль("КнопкаБирюзовая", "QPushButton { background-color: #1abc9c; color: white; font-weight: bold; border-radius: 8px; } "+
                                        "QPushButton:hover { background-color: #16a085; } QPushButton:pressed { background-color: #117a65; }")
        ПриНажатииКнопки("КнопкаБирюзовая", Функция() { ПоказатьСообщение("🟢 Бирюзовая кнопка нажата!") })
    
    // ========== ГРУППА КНОПОК С ЭФФЕКТАМИ ==========
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Группа", "ГруппаЭффекты", { "Лево": 520, "Верх": 30, "Ширина": 470, "Высота": 220, "Заголовок": "✨ Кнопки с эффектами" })
    
    ДобавитьОбъектНаСтранице(0, "Кнопка", "КнопкаТень", { "Лево": 20, "Верх": 30, "Ширина": 200, "Высота": 40, "Заголовок": "🌑 С эффектом тени" }, "ГруппаЭффекты")
    УстановитьСтиль("КнопкаТень", "QPushButton { background-color: #34495e; color: white; border-radius: 10px; box-shadow: 3px 3px 5px rgba(0,0,0,0.3); } "+
                                "QPushButton:hover { background-color: #2c3e50; }")
        ПриНажатииКнопки("КнопкаТень", Функция() { ПоказатьСообщение("Кнопка с тенью нажата!") })
    
    ДобавитьОбъектНаСтранице(0, "Кнопка", "КнопкаГрадиент", { "Лево": 250, "Верх": 30, "Ширина": 200, "Высота": 40, "Заголовок": "🌈 С градиентом" }, "ГруппаЭффекты")
    УстановитьСтиль("КнопкаГрадиент", "QPushButton { background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #f7971e, stop:1 #ffd200); color: #2c3e50; "+
                     "font-weight: bold; border-radius: 10px; } QPushButton:hover { background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #ffd200, stop:1 #f7971e); }")
        ПриНажатииКнопки("КнопкаГрадиент", Функция() { ПоказатьСообщение("Градиентная кнопка нажата!") })
    
    ДобавитьОбъектНаСтранице(0, "Кнопка", "КнопкаРамка", { "Лево": 20, "Верх": 90, "Ширина": 200, "Высота": 40, "Заголовок": "🖼️ С цветной рамкой" }, "ГруппаЭффекты")
    УстановитьСтиль("КнопкаРамка", "QPushButton { background-color: white; color: #2980b9; border: 2px solid #2980b9; border-radius: 8px; font-weight: bold; } QPushButton:hover { background-color: #2980b9; color: white; }")
        ПриНажатииКнопки("КнопкаРамка", Функция() { ПоказатьСообщение("Кнопка с рамкой нажата!") })
    
    ДобавитьОбъектНаСтранице(0, "Кнопка", "КнопкаЗакругление", { "Лево": 250, "Верх": 90, "Ширина": 200, "Высота": 40, "Заголовок": "⚪ Сильно закругленная" }, "ГруппаЭффекты")
    УстановитьСтиль("КнопкаЗакругление", "QPushButton { background-color: #e67e22; color: white; border-radius: 20px; font-weight: bold; } "+
                        "QPushButton:hover { background-color: #d35400; }")
        ПриНажатииКнопки("КнопкаЗакругление", Функция() { ПоказатьСообщение("Закругленная кнопка нажата!") })
    
    ДобавитьОбъектНаСтранице(0, "Кнопка", "КнопкаНевидимка", { "Лево": 20, "Верх": 150, "Ширина": 200, "Высота": 40, "Заголовок": "👻 Кнопка-невидимка" }, "ГруппаЭффекты")
    УстановитьСтиль("КнопкаНевидимка", "QPushButton { background-color: transparent; color: #7f8c8d; border: 1px dashed #bdc3c7; border-radius: 8px; } "+
                        "QPushButton:hover { background-color: #95a5a6; color: white; border: 1px solid #95a5a6; }")
        ПриНажатииКнопки("КнопкаНевидимка", Функция() { ПоказатьСообщение("Невидимка проявилась и нажата!") })
    
    ДобавитьОбъектНаСтранице(0, "Кнопка", "КнопкаАнимация", { "Лево": 250, "Верх": 150, "Ширина": 200, "Высота": 40, "Заголовок": "🎬 Анимированная" }, "ГруппаЭффекты")
    УстановитьСтиль("КнопкаАнимация", "QPushButton { background-color: #2c3e50; color: #ecf0f1; border-radius: 8px; font-weight: bold; } "+
              "QPushButton:hover { background-color: #34495e; }")
    ПриНажатииКнопки("КнопкаАнимация", Функция() { 
        УстановитьСтиль("КнопкаАнимация", "QPushButton { background-color: #e74c3c; color: white; border-radius: 8px; font-weight: bold; }")
        Пауза(200)
        УстановитьСтиль("КнопкаАнимация", "QPushButton { background-color: #2c3e50; color: #ecf0f1; border-radius: 8px; font-weight: bold; }")
        ПоказатьСообщение("🎉 Анимация сработала!") 
    })
    
    // ========== ГРУППА ОБЫЧНЫХ КНОПОК (исходная) ==========
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Группа", "ГруппаКнопки", { "Лево": 10, "Верх": 250, "Ширина": 480, "Высота": 170, "Заголовок": "📌 Обычные кнопки" })
    
    ДобавитьОбъектНаСтранице(0, "Кнопка", "Кнопка1", { "Лево": 20, "Верх": 30, "Ширина": 140, "Высота": 35, "Заголовок": "Первая кнопка" }, "ГруппаКнопки")
    ПриНажатииКнопки("Кнопка1", Функция() { ПоказатьСообщение("Первая кнопка нажата! Привет, мир!") })
    
    ДобавитьОбъектНаСтранице(0, "Кнопка", "Кнопка2", { "Лево": 20, "Верх": 80, "Ширина": 140, "Высота": 35, "Заголовок": "Вторая кнопка" }, "ГруппаКнопки")
    ПриНажатииКнопки("Кнопка2", Функция() { ПоказатьСообщение("Вторая кнопка нажата! Добро пожаловать в RusFoxQt6 !") })
    
    ДобавитьОбъектНаСтранице(0, "Кнопка", "Кнопка3", { "Лево": 20, "Верх": 130, "Ширина": 140, "Высота": 35, "Заголовок": "Третья кнопка" }, "ГруппаКнопки")
    ПриНажатииКнопки("Кнопка3", Функция() { 
        УстановитьТекст("Надпись1", "Третья кнопка изменила эту надпись!")
        ПоказатьСообщение("Надпись изменена!") 
    })
    
    ДобавитьОбъектНаСтранице(0, "Надпись", "Надпись1", { "Лево": 200, "Верх": 30, "Ширина": 400, "Высота": 25, "Заголовок": "Здесь будет меняться текст" }, "ГруппаКнопки")
    
    // ========== ГРУППА ПЕРЕКЛЮЧАТЕЛЕЙ ==========
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Группа", "ГруппаПереключатели", { "Лево": 520, "Верх": 250, "Ширина": 470, "Высота": 170, "Заголовок": "🔘 Переключатели (RadioButton)" })
    
    ДобавитьОбъектНаСтранице(0, "Переключатель", "Радио1", { "Лево": 40, "Верх": 30, "Ширина": 200, "Высота": 25, "Заголовок": "Вариант первый" }, "ГруппаПереключатели")
        ПриВыбореПереключателя("Радио1", Функция(включен) { Если включен Тогда ПоказатьСообщение("Выбран первый вариант") КонецЕсли; })
    ДобавитьОбъектНаСтранице(0, "Переключатель", "Радио2", { "Лево": 40, "Верх": 60, "Ширина": 200, "Высота": 25, "Заголовок": "Вариант второй" }, "ГруппаПереключатели")
        ПриВыбореПереключателя("Радио2", Функция(включен) { Если включен Тогда ПоказатьСообщение("Выбран второй вариант") КонецЕсли; })
    ДобавитьОбъектНаСтранице(0, "Переключатель", "Радио3", { "Лево": 40, "Верх": 90, "Ширина": 200, "Высота": 25, "Заголовок": "Вариант третий" }, "ГруппаПереключатели")
        ПриВыбореПереключателя("Радио3", Функция(включен) { Если включен Тогда ПоказатьСообщение("Выбран третий вариант") КонецЕсли; })
    
    // ========== ГРУППА ФЛАЖКОВ ==========
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Группа", "ГруппаФлажки", { "Лево": 10, "Верх": 450, "Ширина": 480, "Высота": 150, "Заголовок": "☑️ Флажки (CheckBox)" })
    
    ДобавитьОбъектНаСтранице(0, "Флажок", "Чек1", { "Лево": 20, "Верх": 30, "Ширина": 200, "Высота": 25, "Заголовок": "Включить опцию 1" }, "ГруппаФлажки")
    ПриИзмененииФлажка("Чек1", Функция(включен) {
        Если включен Тогда ПоказатьСообщение("Опция 1 включена")
        Иначе ПоказатьСообщение("Опция 1 выключена")
        КонецЕсли;
    })
    
    ДобавитьОбъектНаСтранице(0, "Флажок", "Чек2", { "Лево": 20, "Верх": 60, "Ширина": 200, "Высота": 25, "Заголовок": "Включить опцию 2" }, "ГруппаФлажки")
    ПриИзмененииФлажка("Чек2", Функция(включен) {
        Если включен Тогда ПоказатьСообщение("Опция 2 включена")
        Иначе ПоказатьСообщение("Опция 2 выключена")
        КонецЕсли;
    })
    
    ДобавитьОбъектНаСтранице(0, "Флажок", "Чек3", { "Лево": 20, "Верх": 90, "Ширина": 200, "Высота": 25, "Заголовок": "Включить опцию 3" }, "ГруппаФлажки")
    ПриИзмененииФлажка("Чек3", Функция(включен) {
        Если включен Тогда ПоказатьСообщение("Опция 3 включена")
        Иначе ПоказатьСообщение("Опция 3 выключена")
        КонецЕсли;
    })
    
    // ========== ГРУППА КНОПОК СО СПЛАШ-ЭФФЕКТАМИ ==========
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Группа", "ГруппаСтильные", { "Лево": 520, "Верх": 450, "Ширина": 470, "Высота": 150, "Заголовок": "🎯 Стильные кнопки" })
    
    ДобавитьОбъектНаСтранице(0, "Кнопка", "СтильУспех", { "Лево": 20, "Верх": 30, "Ширина": 130, "Высота": 35, "Заголовок": "✓ Успех" }, "ГруппаСтильные")
    УстановитьСтиль("СтильУспех", "QPushButton { background-color: #27ae60; color: white; border-radius: 5px; } QPushButton:hover { background-color: #2ecc71; }")
    ПриНажатииКнопки("СтильУспех", Функция() { ПоказатьСообщение("Операция выполнена успешно!") })
    
    ДобавитьОбъектНаСтранице(0, "Кнопка", "СтильОшибка", { "Лево": 170, "Верх": 30, "Ширина": 130, "Высота": 35, "Заголовок": "✗ Ошибка" }, "ГруппаСтильные")
    УстановитьСтиль("СтильОшибка", "QPushButton { background-color: #c0392b; color: white; border-radius: 5px; } QPushButton:hover { background-color: #e74c3c; }")
    ПриНажатииКнопки("СтильОшибка", Функция() { ПоказатьСообщение("Произошла ошибка!") })
    
    ДобавитьОбъектНаСтранице(0, "Кнопка", "СтильПредупреждение", { "Лево": 320, "Верх": 30, "Ширина": 130, "Высота": 35, "Заголовок": "⚠ Предупреждение" }, "ГруппаСтильные")
    УстановитьСтиль("СтильПредупреждение", "QPushButton { background-color: #f39c12; color: #2c3e50; border-radius: 5px; font-weight: bold; } QPushButton:hover { background-color: #f1c40f; }")
    ПриНажатииКнопки("СтильПредупреждение", Функция() { ПоказатьСообщение("Будьте осторожны!") })
    
    ДобавитьОбъектНаСтранице(0, "Кнопка", "СтильИнформация", { "Лево": 20, "Верх": 80, "Ширина": 130, "Высота": 35, "Заголовок": "ℹ Информация" }, "ГруппаСтильные")
    УстановитьСтиль("СтильИнформация", "QPushButton { background-color: #2980b9; color: white; border-radius: 5px; } QPushButton:hover { background-color: #3498db; }")
    ПриНажатииКнопки("СтильИнформация", Функция() { ПоказатьСообщение("Информационное сообщение") })
    
    ДобавитьОбъектНаСтранице(0, "Кнопка", "СтильВопрос", { "Лево": 170, "Верх": 80, "Ширина": 130, "Высота": 35, "Заголовок": "❓ Вопрос" }, "ГруппаСтильные")
    УстановитьСтиль("СтильВопрос", "QPushButton { background-color: #16a085; color: white; border-radius: 5px; } QPushButton:hover { background-color: #1abc9c; }")
    ПриНажатииКнопки("СтильВопрос", Функция() { 
        ответ = Подтвердить("Вы уверены?")
        Если ответ Тогда ПоказатьСообщение("Подтверждено!") Иначе ПоказатьСообщение("Отменено!") КонецЕсли;
    })
КонецФункции

// ----------------------------------------------------------------------------
// СТРАНИЦА 2: ТЕКСТОВЫЕ ВИДЖЕТЫ
// ----------------------------------------------------------------------------
Функция Страница2_ТекстовыеВиджеты(ИмяВкладок, НомерВкладки)
    // Устанавливаем свето-зеленый цвет вкладки
    УстановитьСтиль(ИмяВкладок, "QTabWidget::pane { background-color: #e8f5e9; border: 1px solid #a5d6a7; } QTabBar::tab { background-color: #c8e6c9; "+
       "color: #2e7d32; padding: 8px 16px; border-radius: 4px; } QTabBar::tab:selected { background-color: #a5d6a7; color: #1b5e20; font-weight: bold; } "+
          "QTabBar::tab:hover { background-color: #b9f6ca; }")
    
    // ========== ГРУППА ОБЫЧНЫХ НАДПИСЕЙ ==========
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Группа", "ГруппаНадписи", { "Лево": 10, "Верх": 10, "Ширина": 400, "Высота": 220, "Заголовок": "📝 Текстовые метки (Label)" })
    
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Надпись", "Надпись1", { "Лево": 20, "Верх": 40, "Ширина": 250, "Высота": 25, "Заголовок": "Обычная надпись" })
        УстановитьСтиль("Надпись1", "QLabel { color: #2c3e50; }")
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Надпись", "Надпись2", { "Лево": 20, "Верх": 70, "Ширина": 250, "Высота": 25, "Заголовок": "Жирная надпись", "Жирный": ИСТИНА })
        УстановитьСтиль("Надпись2", "QLabel { font-weight: bold; color: #2980b9; }")
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Надпись", "Надпись3", { "Лево": 20, "Верх": 100, "Ширина": 250, "Высота": 30, "Заголовок": "Крупный текст", "РазмерШрифта": 16 })
        УстановитьСтиль("Надпись3", "QLabel { color: #e74c3c; font-weight: bold; }")
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Надпись", "Надпись4", { "Лево": 20, "Верх": 135, "Ширина": 250, "Высота": 25, "Заголовок": "Цветной текст" })
        УстановитьСтиль("Надпись4", "QLabel { color: #8e44ad; font-style: italic; background-color: #f3e5f5; padding: 3px; border-radius: 4px; }")
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Надпись", "Надпись5", { "Лево": 20, "Верх": 170, "Ширина": 250, "Высота": 30, "Заголовок": "✨ Стильная надпись" })
        УстановитьСтиль("Надпись5", "QLabel { background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #667eea, stop:1 #764ba2); color: white; padding: 5px; "+
             "border-radius: 8px; font-weight: bold; }")
    
    // ========== ГРУППА ПОЛЕЙ ВВОДА ==========
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Группа", "ГруппаПоляВвода", { "Лево": 420, "Верх": 10, "Ширина": 420, "Высота": 220, "Заголовок": "⌨️ Поля ввода (LineEdit)" })
    
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "ПолеВвода", "Поле1", { "Лево": 430, "Верх": 40, "Ширина": 250, "Высота": 30, "Подсказка": "Обычное поле ввода" })
    УстановитьСтиль("Поле1", "QLineEdit { border: 2px solid #bdc3c7; border-radius: 6px; padding: 5px; } QLineEdit:focus { border-color: #3498db; }")
    ПриИзмененииТекста("Поле1", Функция(текст) { Сообщить("📝 Введено: " + текст) })
    
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "ПолеВвода", "Поле2", { "Лево": 430, "Верх": 85, "Ширина": 250, "Высота": 30, "Значение": "Текст по умолчанию" })
    УстановитьСтиль("Поле2", "QLineEdit { border: 2px solid #2ecc71; border-radius: 6px; padding: 5px; background-color: #e8f8f5; }")
    
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "ПолеПароля", "ПолеПароль", { "Лево": 430, "Верх": 130, "Ширина": 250, "Высота": 30, "Подсказка": "Введите пароль" })
    УстановитьСтиль("ПолеПароль", "QLineEdit { border: 2px solid #e74c3c; border-radius: 6px; padding: 5px; } QLineEdit:focus { border-color: #c0392b; }")
    
    // Поле с иконкой (эмуляция через стиль)
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "ПолеВвода", "ПолеПоиск", { "Лево": 430, "Верх": 175, "Ширина": 250, "Высота": 30, "Подсказка": "🔍 Поиск..." })
    УстановитьСтиль("ПолеПоиск", "QLineEdit { border: 2px solid #9b59b6; border-radius: 15px; padding: 5px 15px; } QLineEdit:focus { border-color: #8e44ad; }")
    
    // Кнопки управления текстом
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Кнопка", "КнопкаОчиститьПоле", { "Лево": 700, "Верх": 40, "Ширина": 120, "Высота": 30, "Заголовок": "🗑️ Очистить" })
    УстановитьСтиль("КнопкаОчиститьПоле", "QPushButton { background-color: #e74c3c; color: white; border-radius: 6px; font-weight: bold; } QPushButton:hover { background-color: #c0392b; } QPushButton:pressed { background-color: #a93226; }")
    ПриНажатииКнопки("КнопкаОчиститьПоле", Функция() { 
        УстановитьТекст("Поле1", "")
        УстановитьТекст("Поле2", "")
        УстановитьТекст("ПолеПароль", "")
        ПоказатьСообщение("✨ Все поля очищены!")
    })
    
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Кнопка", "КнопкаУстановитьТекст", { "Лево": 700, "Верх": 85, "Ширина": 120, "Высота": 30, "Заголовок": "📋 Установить текст" })
    УстановитьСтиль("КнопкаУстановитьТекст", "QPushButton { background-color: #2ecc71; color: white; border-radius: 6px; font-weight: bold; } QPushButton:hover { background-color: #27ae60; } QPushButton:pressed { background-color: #1e8449; }")
    ПриНажатииКнопки("КнопкаУстановитьТекст", Функция() { 
        УстановитьТекст("Поле1", "Привет от RusFoxQt6 !")
        УстановитьТекст("Поле2", "Этот текст установлен программно")
        ПоказатьСообщение("✅ Текст установлен!") 
    })
    
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Кнопка", "КнопкаПоказатьПароль", { "Лево": 700, "Верх": 130, "Ширина": 120, "Высота": 30, "Заголовок": "👁️ Показать пароль" })
        УстановитьСтиль("КнопкаПоказатьПароль", "QPushButton { background-color: #3498db; color: white; border-radius: 6px; } QPushButton:hover { background-color: #2980b9; }")
            ПриНажатииКнопки("КнопкаПоказатьПароль", Функция() { 
                 пароль = ПолучитьЗначениеВиджета("ПолеПароль")
                 Если пароль == "" Тогда
                   ПоказатьСообщение("Пароль не введен!")
                Иначе
                   ПоказатьСообщение("🔐 Ваш пароль: " + пароль)
                КонецЕсли;
            })
    
    // ========== ГРУППА ТЕКСТОВЫХ ОБЛАСТЕЙ ==========
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Группа", "ГруппаТекст", { "Лево": 10, "Верх": 240, "Ширина": 400, "Высота": 340, "Заголовок": "📄 Текстовые области" })
    
    // Многострочное текстовое поле
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "ТекстоваяОбласть", "ТекстОбласть1", { "Лево": 20, "Верх": 270, "Ширина": 180, "Высота": 140, "Значение": "Многострочный текст\nВторая строка\nТретья строка" })
        УстановитьСтиль("ТекстОбласть1", "QTextEdit { border: 2px solid #bdc3c7; border-radius: 8px; padding: 5px; font-family: Consolas; } "+
            "QTextEdit:focus { border-color: #3498db; }")
    
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "ТекстовыйБраузер", "ТекстБраузер", { "Лево": 200, "Верх": 270, "Ширина": 180, "Высота": 140, "Заголовок": "<h2 style='color:#2ecc71'>Заголовок</h2><b>Жирный текст</b><br><i>Курсив</i><br><font color='#e74c3c'>Красный текст</font>" })
        УстановитьСтиль("ТекстБраузер", "QTextBrowser { border: 2px solid #9b59b6; border-radius: 8px; background-color: #f9f9f9; }")
            УстановитьЗначениеВиджета("ТекстБраузер", "Это Текстовый браузер")
    
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "ПлоскийСписок", "ПлейнТекст", { "Лево": 20, "Верх": 430, "Ширина": 350, "Высота": 130 })
            УстановитьСтиль("ПлейнТекст", "QPlainTextEdit { border: 2px solid #f39c12; border-radius: 8px; padding: 5px; font-family: "+
               "Consolas; background-color: #fff8e1; } QPlainTextEdit:focus { border-color: #e67e22; }")
    
    // ========== ОПИСАНИЕ CSS-ЭФФЕКТОВ ==========
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Группа", "ГруппаОписание", { "Лево": 450, "Верх": 240, "Ширина": 400, "Высота": 340, "Заголовок": "🎨 Используемые CSS-эффекты" })
    
    ДобавитьОбъектНаСтранице(0, "Надпись", "Описание1", { "Лево": 20, "Верх": 20, "Ширина": 250, "Высота": 25, "Заголовок": "● border-radius — скругление углов" }, "ГруппаОписание")
    ДобавитьОбъектНаСтранице(0, "Надпись", "Описание2", { "Лево": 20, "Верх": 40, "Ширина": 250, "Высота": 25, "Заголовок": "● box-shadow — тень" }, "ГруппаОписание")
    ДобавитьОбъектНаСтранице(0, "Надпись", "Описание3", { "Лево": 20, "Верх": 60, "Ширина": 280, "Высота": 25, "Заголовок": "● gradient — градиентная заливка" }, "ГруппаОписание")
    ДобавитьОбъектНаСтранице(0, "Надпись", "Описание4", { "Лево": 20, "Верх": 80, "Ширина": 250, "Высота": 25, "Заголовок": "● :hover — эффект при наведении" }, "ГруппаОписание")
    ДобавитьОбъектНаСтранице(0, "Надпись", "Описание5", { "Лево": 20, "Верх": 100, "Ширина": 250, "Высота": 25, "Заголовок": "● :pressed — эффект при нажатии" }, "ГруппаОписание")
    ДобавитьОбъектНаСтранице(0, "Надпись", "Описание6", { "Лево": 20, "Верх": 120, "Ширина": 280, "Высота": 25, "Заголовок": "● border — цветная рамка" }, "ГруппаОписание")
    ДобавитьОбъектНаСтранице(0, "Надпись", "Описание7", { "Лево": 20, "Верх": 140, "Ширина": 280, "Высота": 25, "Заголовок": "● transparent — прозрачность" }, "ГруппаОписание")
КонецФункции

// ----------------------------------------------------------------------------
// СТРАНИЦА 3: СПИСКИ, ЛИНИИ И ФРЕЙМЫ
// ----------------------------------------------------------------------------
Функция Страница3_Списки(ИмяВкладок, НомерВкладки)
    // Группа выпадающих списков
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Группа", "ГруппаСписки", { "Лево": 10, "Верх": 10, "Ширина": 400, "Высота": 200, "Заголовок": "Выпадающие списки (ComboBox)" })
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Список", "КомбоСписок1", { "Лево": 20, "Верх": 40, "Ширина": 200, "Высота": 30, "Элементы": "Пункт 1,Пункт 2,Пункт 3,Пункт 4,Пункт 5" })
      ПриВыбореИзСписка("КомбоСписок1", Функция(индекс) { ПоказатьСообщение("Выбран пункт " + (индекс + 1)) })
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Список", "КомбоСписок2", { "Лево": 20, "Верх": 80, "Ширина": 200, "Высота": 30, "Элементы": "Красный,Зеленый,Синий,Желтый", "Редактируемо": ИСТИНА })
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Шрифт", "ШрифтКомбо", { "Лево": 20, "Верх": 120, "Ширина": 200, "Высота": 30 })
    
    // Кнопки для работы со списком
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Кнопка", "КнопкаПоказатьВыбор", { "Лево": 20, "Верх": 160, "Ширина": 150, "Высота": 30, "Заголовок": "Показать выбранное" })
      ПриНажатииКнопки("КнопкаПоказатьВыбор", Функция() {       Пусть список = ПолучитьВиджет("КомбоСписок1")
           Если список Тогда           ПоказатьСообщение("Выбран: " + список.текущийТекст())        КонецЕсли;
      })
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Кнопка", "КнопкаДобавитьПункт", { "Лево": 200, "Верх": 160, "Ширина": 150, "Высота": 30, "Заголовок": "Добавить пункт" })
      ПриНажатииКнопки("КнопкаДобавитьПункт", Функция() {      Пусть список = ПолучитьВиджет("КомбоСписок1")
        Если список Тогда
            список.добавитьПункт("Новый пункт " + (список.количество() + 1))
            ПоказатьСообщение("Добавлен новый пункт!")
        КонецЕсли;
      })
    
    // Группа списков элементов
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Группа", "ГруппаСпискиЭлементов", { "Лево": 420, "Верх": 10, "Ширина": 420, "Высота": 200, "Заголовок": "Списки элементов (ListWidget)" })
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "СписокЭлементов", "СписокЭлем1", { "Лево": 430, "Верх": 40, "Ширина": 200, "Высота": 150, "Элементы": "Элемент A,Элемент B,Элемент C,Элемент D,Элемент E,Элемент F" })
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Кнопка", "КнопкаОчиститьСписок", { "Лево": 650, "Верх": 40, "Ширина": 150, "Высота": 30, "Заголовок": "Очистить список" })
    ПриНажатииКнопки("КнопкаОчиститьСписок", Функция() {
        Пусть список = ПолучитьВиджет("СписокЭлем1")
        Если список Тогда список.очистить(); КонецЕсли;
        ПоказатьСообщение("Список очищен!")
    })
    
    // Линии и фреймы
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Группа", "ГруппаЛинии", { "Лево": 10, "Верх": 230, "Ширина": 830, "Высота": 150, "Заголовок": "Линии и фреймы" })
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "ГоризонтальнаяЛиния", "ЛинияГор", { "Лево": 20, "Верх": 270, "Ширина": 350, "Высота": 5 })
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "ВертикальнаяЛиния", "ЛинияВерт", { "Лево": 400, "Верх": 260, "Ширина": 5, "Высота": 50 })
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Фрейм", "Фрейм1", { "Лево": 430, "Верх": 260, "Ширина": 150, "Высота": 50, "Рамка": "панель", "Тень": "выпуклая" })
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Надпись", "НадписьФрейм", { "Лево": 440, "Верх": 275, "Ширина": 130, "Высота": 20, "Заголовок": "Фрейм", "Выравнивание": "центр" })
КонецФункции

// ----------------------------------------------------------------------------
// СТРАНИЦА 4: ЧИСЛОВЫЕ ВИДЖЕТЫ
// ----------------------------------------------------------------------------
Функция Страница4_ЧисловыеВиджеты(ИмяВкладок, НомерВкладки)
    // Группа счетчиков
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Группа", "ГруппаСчетчики", { "Лево": 10, "Верх": 10, "Ширина": 400, "Высота": 150, "Заголовок": "Счетчики (SpinBox)" })
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Счетчик", "Счетчик1", { "Лево": 20, "Верх": 40, "Ширина": 120, "Высота": 30, "Минимум": 0, "Максимум": 100, "Значение": 50 })
       ПриИзмененииСчетчика("Счетчик1", Функция(значение) { Сообщить("Счетчик изменен на: " + значение) })
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "СчетчикДвойной", "Счетчик2", { "Лево": 20, "Верх": 80, "Ширина": 150, "Высота": 30, "Минимум": 0, "Максимум": 100, "Значение": 25, "Десятичных": 2, "Шаг": 0.5 })
    
    // Группа ползунков
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Группа", "ГруппаПолзунки", { "Лево": 420, "Верх": 10, "Ширина": 420, "Высота": 150, "Заголовок": "Ползунки (Slider)" })
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Ползунок", "Слайдер1", { "Лево": 430, "Верх": 40, "Ширина": 300, "Высота": 30, "Минимум": 0, "Максимум": 100, "Значение": 50 })
       ПриДвиженииПолзунка("Слайдер1", Функция(значение) { УстановитьТекст("НадписьСлайдер", "Значение: " + значение) })
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Надпись", "НадписьСлайдер", { "Лево": 430, "Верх": 80, "Ширина": 150, "Высота": 25, "Заголовок": "Значение: 50" })
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "ПолзунокВертикальный", "Слайдер2", { "Лево": 750, "Верх": 40, "Ширина": 30, "Высота": 100, "Минимум": 0, "Максимум": 100, "Значение": 75 })
    
    // Группа индикаторов прогресса
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Группа", "ГруппаПрогресс", { "Лево": 10, "Верх": 170, "Ширина": 400, "Высота": 120, "Заголовок": "Индикаторы прогресса" })
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Прогресс", "Прогресс1", { "Лево": 20, "Верх": 200, "Ширина": 380, "Высота": 25, "Минимум": 0, "Максимум": 100, "Значение": 65 })
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Прогресс", "Прогресс2", { "Лево": 20, "Верх": 235, "Ширина": 380, "Высота": 25, "Минимум": 0, "Максимум": 100, "Значение": 30 })
    
    // Кнопки управления
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Кнопка", "КнопкаОбновитьПрогресс", { "Лево": 20, "Верх": 270, "Ширина": 150, "Высота": 30, "Заголовок": "Обновить прогресс" })
      ПриНажатииКнопки("КнопкаОбновитьПрогресс", Функция() {
        Пусть счетчик = ПолучитьВиджет("Счетчик1")
        Пусть прогресс = ПолучитьВиджет("Прогресс1")
        Если счетчик И прогресс Тогда
            прогресс.установитьЗначение(счетчик.значение())
            ПоказатьСообщение("Прогресс обновлен до " + счетчик.значение() + "%")
        КонецЕсли;
      })
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Кнопка", "КнопкаУвеличитьСчетчик", { "Лево": 200, "Верх": 270, "Ширина": 150, "Высота": 30, "Заголовок": "Увеличить счетчик" })
      ПриНажатииКнопки("КнопкаУвеличитьСчетчик", Функция() {
        let счетчик = ПолучитьВиджет("Счетчик1")
        Если счетчик И счетчик.значение() < 100 Тогда
            счетчик.установитьЗначение(счетчик.значение() + 10)
            ПоказатьСообщение("Счетчик увеличен до " + счетчик.значение())
        КонецЕсли;
      })
    
    // Группа цифровых индикаторов
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Группа", "ГруппаИндикаторы", { "Лево": 420, "Верх": 170, "Ширина": 420, "Высота": 120, "Заголовок": "Цифровые индикаторы (LCD)" })
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Индикатор", "Индикатор1", { "Лево": 430, "Верх": 200, "Ширина": 100, "Высота": 50, "Формат": 5, "Значение": 12345 })
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Индикатор", "Индикатор2", { "Лево": 550, "Верх": 200, "Ширина": 100, "Высота": 50, "Формат": 3, "Значение": 987 })
КонецФункции

// ----------------------------------------------------------------------------
// СТРАНИЦА 5: ДАТА И ВРЕМЯ
// ----------------------------------------------------------------------------
Функция Страница5_ДатаВремя(ИмяВкладок, НомерВкладки)
    // Группа виджетов даты и времени
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Группа", "ГруппаДатаВремя", { "Лево": 10, "Верх": 10, "Ширина": 400, "Высота": 180, "Заголовок": "Дата и время" })
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "ДатаВремя", "ДТ1", { "Лево": 20, "Верх": 40, "Ширина": 200, "Высота": 30, "Формат": "dd.MM.yyyy HH:mm:ss" })
        ПриВыбореДаты("ДТ1", Функция(дата) { ПоказатьСообщение("Выбрано: " + дата) })
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Дата", "Дата1", { "Лево": 20, "Верх": 80, "Ширина": 180, "Высота": 30 })
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Время", "Время1", { "Лево": 20, "Верх": 120, "Ширина": 180, "Высота": 30 })
    
    // Группа календаря
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Группа", "ГруппаКалендарь", { "Лево": 420, "Верх": 10, "Ширина": 420, "Высота": 350, "Заголовок": "Календарь" })
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Календарь", "Календарь1", { "Лево": 430, "Верх": 40, "Ширина": 380, "Высота": 300 })
       ПриКликеКалендаря("Календарь1", Функция(дата) { ПоказатьСообщение("Выбрана дата: " + дата) })
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Кнопка", "КнопкаПоказатьДату", { "Лево": 20, "Верх": 160, "Ширина": 150, "Высота": 30, "Заголовок": "Показать выбранную дату" })
      ПриНажатииКнопки("КнопкаПоказатьДату", Функция() {
        let календарь = ПолучитьВиджет("Календарь1")
        Если календарь Тогда
            ПоказатьСообщение("Выбрана дата: " + календарь.selectedDate().toString("dd.MM.yyyy"))
        КонецЕсли;
      })
КонецФункции

// ----------------------------------------------------------------------------
// СТРАНИЦА 6: ТАБЛИЦА ДАННЫХ
// ----------------------------------------------------------------------------
Функция Страница6_ТаблицаДанных(ИмяВкладок, НомерВкладки)
    // Группа с таблицей
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Группа", "ГруппаТаблица", { "Лево": 10, "Верх": 10, "Ширина": 860, "Высота": 520, "Заголовок": "Таблица данных (SmartGrid)" })
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Таблица", "Таблица1", { "Лево": 20, "Верх": 80, "Ширина": 840, "Высота": 420 })
    
    // Настройка таблицы
    УстановитьКолонки("Таблица1", "id,Имя,Возраст,Город,Зарплата,Активен")
    УстановитьТипыКолонок("Таблица1", "number,string,number,string,number,boolean")
    УстановитьШиринуКолонок("Таблица1", "50,200,80,120,100,80")
    
    // Данные для таблицы
    Пусть данныеТаблицы = [
        {"id": 1, "Имя": "Иван Иванов", "Возраст": 25, "Город": "Москва", "Зарплата": 50000, "Активен": ИСТИНА},
        {"id": 2, "Имя": "Петр Петров", "Возраст": 30, "Город": "Санкт-Петербург", "Зарплата": 65000, "Активен": ИСТИНА},
        {"id": 3, "Имя": "Сидор Сидоров", "Возраст": 35, "Город": "Казань", "Зарплата": 45000, "Активен": ЛОЖЬ},
        {"id": 4, "Имя": "Анна Смирнова", "Возраст": 28, "Город": "Москва", "Зарплата": 55000, "Активен": ИСТИНА},
        {"id": 5, "Имя": "Дмитрий Козлов", "Возраст": 32, "Город": "Новосибирск", "Зарплата": 48000, "Активен": ИСТИНА}
    ]
    
    // Загрузка данных в таблицу
    ДобавитьСтрокиИзJSON("Таблица1", JSON_ВСтроку(данныеТаблицы))
    ПоказатьСтрокуИтогов("Таблица1", ИСТИНА)
    
    // Кнопки управления таблицей
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Кнопка", "КнопкаОчистить", { "Лево": 20, "Верх": 40, "Ширина": 120, "Высота": 30, "Заголовок": "Очистить таблицу" })
      ПриНажатииКнопки("КнопкаОчистить", Функция() {
        ОчиститьДанные("Таблица1")
        ПоказатьСообщение("Таблица очищена!")
      })
    
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Кнопка", "КнопкаФильтрМосква", { "Лево": 160, "Верх": 40, "Ширина": 130, "Высота": 30, "Заголовок": "Фильтр: Москва" })
      ПриНажатииКнопки("КнопкаФильтрМосква", Функция() {
        ФильтрПоКолонке("Таблица1", "Город", "Москва")
        ПоказатьСообщение("Применен фильтр по городу Москва")
      })
    
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Кнопка", "КнопкаСбросФильтра", { "Лево": 310, "Верх": 40, "Ширина": 130, "Высота": 30, "Заголовок": "Сбросить фильтры" })
      ПриНажатииКнопки("КнопкаСбросФильтра", Функция() {
        ОчиститьФильтры("Таблица1")
        ПоказатьСообщение("Фильтры сброшены")
      })
    
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Кнопка", "КнопкаСортировкаВозраст", { "Лево": 460, "Верх": 40, "Ширина": 160, "Высота": 30, "Заголовок": "Сортировать по возрасту" })
      ПриНажатииКнопки("КнопкаСортировкаВозраст", Функция() {
        СортироватьПоКолонке("Таблица1", "Возраст", ИСТИНА)
        ПоказатьСообщение("Отсортировано по возрасту")
      })
КонецФункции

// ----------------------------------------------------------------------------
// СТРАНИЦА 7: КОНТЕЙНЕРЫ (ВКЛАДКИ, ПАНЕЛИ, РАЗДЕЛИТЕЛЬ)
// ----------------------------------------------------------------------------
Функция Страница7_Контейнеры(ИмяВкладок, НомерВкладки)
    
    // ==================== ВКЛАДКИ (TABWIDGET) ====================
    // Группа для вкладок
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Группа", "ГруппаВкладки", { "Лево": 10, "Верх": 10, "Ширина": 420, "Высота": 400, "Заголовок": "Вкладки (TabWidget)" })

    // Создаём вложенные вкладки
    СоздатьВкладки("ВкладкиTABWIDGET", { "Лево": 20, "Верх": 40, "Ширина": 390, "Высота": 340, "Вкладки": "Главная,Настройки,Информация" }, "ГруппаВкладки")

    // Добавляем виджеты на ПЕРВУЮ вкладку (индекс 0)
    ДобавитьНаВкладку("ВкладкиTABWIDGET", 0, "Надпись", "НадписьВкладка1", { "Лево": 10, "Верх": 10, "Ширина": 350, "Высота": 25, "Заголовок": "=== ГЛАВНАЯ СТРАНИЦА ===", "Жирный": ИСТИНА })
    ДобавитьНаВкладку("ВкладкиTABWIDGET", 0, "Кнопка", "КнопкаВкладка1", { "Лево": 10, "Верх": 50, "Ширина": 150, "Высота": 30, "Заголовок": "Нажать здесь" })
        ПриНажатииКнопки("КнопкаВкладка1", Функция() {       ПоказатьСообщение("Кнопка на первой вкладке нажата!")  })
    ДобавитьНаВкладку("ВкладкиTABWIDGET", 0, "ПолеВвода", "ПолеВкладка1", { "Лево": 10, "Верх": 100, "Ширина": 200, "Высота": 30, "Подсказка": "Введите текст" })
    
    // Добавляем виджеты на ВТОРУЮ вкладку (индекс 1)
    ДобавитьНаВкладку("ВкладкиTABWIDGET", 1, "Надпись", "НадписьВкладка2", { "Лево": 10, "Верх": 10, "Ширина": 350, "Высота": 25, "Заголовок": "=== НАСТРОЙКИ ===", "Жирный": ИСТИНА })
    ДобавитьНаВкладку("ВкладкиTABWIDGET", 1, "Счетчик", "СчетчикВкладка2", { "Лево": 10, "Верх": 50, "Ширина": 120, "Высота": 30, "Минимум": 0, "Максимум": 100, "Значение": 50 })
    ДобавитьНаВкладку("ВкладкиTABWIDGET", 1, "Флажок", "ЧекВкладка2", { "Лево": 10, "Верх": 100, "Ширина": 150, "Высота": 25, "Заголовок": "Включить опцию" })
    
    // Добавляем виджеты на ТРЕТЬЮ вкладку (индекс 2)
    ДобавитьНаВкладку("ВкладкиTABWIDGET", 2, "Надпись", "НадписьВкладка3", { "Лево": 10, "Верх": 10, "Ширина": 350, "Высота": 25, "Заголовок": "=== ИНФОРМАЦИЯ ===", "Жирный": ИСТИНА })
    ДобавитьНаВкладку("ВкладкиTABWIDGET", 2, "ТекстоваяОбласть", "ТекстВкладка3", { "Лево": 10, "Верх": 50, "Ширина": 350, "Высота": 150, "Значение": "Информационная область\nМожно редактировать текст" })
    
    // ==================== ПАНЕЛИ (TOOLBOX) ====================
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Группа", "ГруппаПанели", { "Лево": 440, "Верх": 10, "Ширина": 420, "Высота": 400, "Заголовок": "Панели инструментов (ToolBox)" })
    
    // ТЕПЕРЬ используем ДобавитьВКонтейнер, так как ГруппаПанели существует в MDI-окне
    ДобавитьВКонтейнер("ГруппаПанели", "Панели", "Панели1", { "Лево": 20, "Верх": 40, "Ширина": 390, "Высота": 340, "Панели": "Основная,Дополнительная,Расширенная" })
    СоздатьВкладки("ВкладкиВнутренние", { "Лево": 20, "Верх": 40, "Ширина": 390, "Высота": 340, "Вкладки": "Главная,Настройки,Информация" }, "ГруппаВкладки")
    
    // Добавляем виджеты на ПЕРВУЮ панель (индекс 1)
    ДобавитьОбъектНаСтранице(0, "Надпись", "НадписьПанель1", { "Лево": 10, "Верх": 10, "Ширина": 350, "Высота": 25, "Заголовок": "=== ОСНОВНАЯ ПАНЕЛЬ ===", "Жирный": ИСТИНА, "Родитель": "Панели1", "Панель": 1 })
    ДобавитьОбъектНаСтранице(0, "Кнопка", "КнопкаПанельА", { "Лево": 10, "Верх": 50, "Ширина": 180, "Высота": 30, "Заголовок": "Действие в основной панели", "Родитель": "Панели1", "Панель": 1 })
      ПриНажатииКнопки("КнопкаПанельА", Функция() {      ПоказатьСообщение("Кнопка на основной панели нажата!") })
    ДобавитьОбъектНаСтранице(0, "ПолеВвода", "ПолеПанель1", { "Лево": 10, "Верх": 100, "Ширина": 200, "Высота": 30, "Подсказка": "Поле в основной панели", "Родитель": "Панели1", "Панель": 1 })
    
    // Добавляем виджеты на ВТОРУЮ панель (индекс 2)
    ДобавитьОбъектНаСтранице(0, "Надпись", "НадписьПанель2", { "Лево": 10, "Верх": 10, "Ширина": 350, "Высота": 25, "Заголовок": "=== ДОПОЛНИТЕЛЬНАЯ ПАНЕЛЬ ===", "Жирный": ИСТИНА, "Родитель": "Панели1", "Панель": 2 })
    ДобавитьОбъектНаСтранице(0, "Список", "СписокПанельB", { "Лево": 10, "Верх": 50, "Ширина": 200, "Высота": 30, "Элементы": "Опция 1,Опция 2,Опция 3", "Родитель": "Панели1", "Панель": 2 })
    ДобавитьОбъектНаСтранице(0, "Флажок", "ЧекПанель2", { "Лево": 10, "Верх": 100, "Ширина": 150, "Высота": 25, "Заголовок": "Включить доп. опцию", "Родитель": "Панели1", "Панель": 2 })
    
    // Добавляем виджеты на ТРЕТЬЮ панель (индекс 3)
    ДобавитьОбъектНаСтранице(0, "Надпись", "НадписьПанель3", { "Лево": 10, "Верх": 10, "Ширина": 350, "Высота": 25, "Заголовок": "=== РАСШИРЕННАЯ ПАНЕЛЬ ===", "Жирный": ИСТИНА, "Родитель": "Панели1", "Панель": 3  })
    ДобавитьОбъектНаСтранице(0, "Счетчик", "СчетчикПанельC", { "Лево": 10, "Верх": 50, "Ширина": 120, "Высота": 30, "Значение": 50, "Родитель": "Панели1", "Панель": 3 })
    ДобавитьОбъектНаСтранице(0, "Прогресс", "ПрогрессПанель3", { "Лево": 10, "Верх": 100, "Ширина": 300, "Высота": 25, "Минимум": 0, "Максимум": 100, "Значение": 75, "Родитель": "Панели1", "Панель": 3 })
    
    // ==================== РАЗДЕЛИТЕЛЬ (SPLITTER) ====================
    // Группа для разделителя
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Группа", "ГруппаРазделитель", {  "Лево": 10, "Верх": 420, "Ширина": 850, "Высота": 100, "Заголовок": "Разделитель (Splitter)" })
    
    // Создаём Splitter внутри группы
    ДобавитьОбъектНаСтранице(0, "Разделитель", "Сплиттер1", { "Лево": 20, "Верх": 40, "Ширина": 820, "Высота": 70, "Ориентация": "горизонтальная" }, "ГруппаРазделитель")
    
    // Создаём ПЕРВУЮ секцию
    ДобавитьОбъектНаСтранице(0, "Группа", "Секция1", { "Заголовок": "Панель 1" }, "Сплиттер1")
    ДобавитьОбъектНаСтранице(0, "Кнопка", "КнопкаСекция1", { "Лево": 10, "Верх": 10, "Ширина": 150, "Высота": 30, "Заголовок": "Кнопка в панели 1" }, "Секция1")
       ПриНажатииКнопки("КнопкаСекция1", Функция() {    ПоказатьСообщение("Кнопка в первой секции разделителя!")   })
    
    // Создаём ВТОРУЮ секцию
    ДобавитьОбъектНаСтранице(0, "Группа", "Секция2", { "Заголовок": "Панель 2" }, "Сплиттер1")
    ДобавитьОбъектНаСтранице(0, "ПолеВвода", "ПолеСекция2", { "Лево": 10, "Верх": 10, "Ширина": 180, "Высота": 30, "Подсказка": "Поле в панели 2" }, "Секция2")

    // Создаём ТРЕТЬЮ секцию
    ДобавитьОбъектНаСтранице(0, "Группа", "Секция3", { "Заголовок": "Панель 3" }, "Сплиттер1")
    ДобавитьОбъектНаСтранице(0, "Счетчик", "СчетчикСекция3", { "Лево": 10, "Верх": 10, "Ширина": 120, "Высота": 30, "Значение": 50 }, "Секция3")
    
    // ==================== КНОПКИ УПРАВЛЕНИЯ ====================
    // Кнопка для определения активной вкладки
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Кнопка", "КнопкаАктивнаяВкладка", {  "Лево": 20, "Верх": 540, "Ширина": 180, "Высота": 30, "Заголовок": "Показать активную вкладку" })
    ПриНажатииКнопки("КнопкаАктивнаяВкладка", Функция() {
        Пусть вкладки = ПолучитьВиджет("Вкладки1")
        Если вкладки Тогда
            ПоказатьСообщение("Активная вкладка: " + (вкладки.текущийИндекс() + 1))
        КонецЕсли;
    })
    
    // Кнопка для определения активной панели
    ДобавитьНаВкладку(ИмяВкладок, НомерВкладки, "Кнопка", "КнопкаАктивнаяПанель", { "Лево": 460, "Верх": 540, "Ширина": 180, "Высота": 30, "Заголовок": "Показать активную панель" })
    ПриНажатииКнопки("КнопкаАктивнаяПанель", Функция() {
        Пусть панели = ПолучитьВиджет("Панели1")
        Если панели Тогда
            ПоказатьСообщение("Активная панель: " + (панели.текущийИндекс() + 1))
        КонецЕсли;
    })
    
КонецФункции

//#КонецОбласти

Функция СоздатьОкноЖурналИзменений()
    Пусть ИмяОкна = "ОкноЖурналИзменений"
    СоздатьПодокноMDI(Глоб_mdi, ИмяОкна, 10, 10, 1020, 720)
    СоздатьВкладки("ВкладкиЖурналИзменений", {  "Лево": 10, "Верх": 10, "Ширина": 1010, "Высота": 710, "Вкладки": "ЖурналИзменений" }, ИмяОкна)

    ДобавитьОбъектНаСтранице(1, "ТекстоваяОбласть", "ТекстЖурналИзменений", { "Лево": 5, "Верх": 5, "Ширина": 1000, "Высота": 645, "Значение": "", "Родитель": "ВкладкиЖурналИзменений" })
    
    ЗначениеТекст = 
                    "31.05.2026  Добавлен класс QtФайлНаблюдатель (QtFileSystemWatcher). Сделано описание в руководстве. Не тестировал. \n"+
                    "Передалана руссификация и тест на 1С-Соответствие, 1С-СписокЗначений, 1С-ТаблицаЗначений, 1С-ДеревоЗначений. \n"+
                    "Доработана функция ВыгрузитьВТаблицу(). Создан класс QtВременныйФайл (QtTemporaryFile) (не тестировал). \n"+
                    "\n"+
                    "30.05.2026  Сделаны тесты для : QtList, QtVector, QtHash, QtSet, QtQueue, QtStack, QtVariant. \n"+
                    "\n"+
                    "29.05.2026  Руссифицированы объекты: QtList, QtVector, QtHash, QtSet, QtQueue, QtStack, QtVariant. \n"+
                    "\n"+
                    "28.05.2026  Реализованы руссифицированные объекты из Qt-библиотеки: {Файл, createFile}, {Каталог, createDir}, {ИнформацияОФайле, createFileInfo}, "+
                    "Созданы тесты для объектов Файл, Каталог, ИнформацияОФайле в сценарии ВсеТесты.RUS.   \n"+
                    "Создана руссификация через спец js-функцию из-за того, что MOC не работает с кириллицей и русские функции в С++ объектах передать не удалось.   \n"+
                    "Созданы тесты для объектов Таймер и Настройки в сценарии ВсеТесты.RUS. Таймер - SmartGridTimer, Настройки - SmartGridSettings \n"+
                    "\n"+
                    "25.05.2026   Создано тестовое окно LibraOffice в сценарии ВсеТесты.RUS. \n"+
                    "При запуске сценария теперь сценарий проверяется на наличие дублей имен функций. \n"+
                    "\n"+
                    "24.05.2026   Созданы 1С-подобные функции: {СтрЧислоСтрок, stringNumberOfLines}, {СтрПолучитьСтроку, stringGetLine}, {Дата, dateFromVariant}, "+
                    "{Год, year}, {Месяц, month}, {День, day}, {Час, hour}, {Минута, minute}, {Секунда, second}, {ДобавитьМесяц, addMonth}, {ДеньГода, dayOfYear}, "+
                    "{ДеньНедели, dayOfWeek}, {НеделяГода, weekOfYear}, {НачалоГода, startOfYear}, {КонецГода, endOfYear}, {НачалоКвартала, startOfQuarter}, "+
                    "{КонецКвартала, endOfQuarter}, {НачалоМесяца, startOfMonth}, {КонецМесяца, endOfMonth}, {НачалоНедели, startOfWeek}, {КонецНедели, endOfWeek}, "+
                    "{НачалоДня, startOfDay}, {КонецДня, endOfDay}, {НачалоЧаса, startOfHour}, {КонецЧаса, endOfHour}, {НачалоМинуты, startOfMinute}, "+
                    "{КонецМинуты, endOfMinute}, \n"+
                    "\n"+
                    "23.05.2026   Созданы 1С-подобные функции: {СтрДлина, stringLength}, {Лев, stringLeft}, {Прав, stringRight}, {Сред, stringMid}, "+
                    "{СтрНайти, stringFind}, {СтрЧислоВхождений, stringCountOccurrences}, {СтрЗаменить, stringReplace}, {ПустаяСтрока, stringIsEmpty}, "+
                    "{ВРег, stringToUpper}, {НРег, stringToLower}, {ТРег, stringToTitle}, {КодСимвола, charCode}, {Символ, charFromCode}, {СокрЛ, stringTrimLeft}, "+
                    "{СокрП, stringTrimRight}, {СокрЛП, stringTrim}, {Число, stringToNumber}, {СтрЗаменить, stringReplaceAll}, {ФорматЧисла, formatNumber}, "+
                    "{Строка, numberToString}, {ЗначениеВСтрокуВнутр, valueToInternalString}, {ЗначениеИзСтрокиВнутр, valueFromInternalString}, \n"+
                    "Создано окно тестирования Функций 1С. \n"+
                    "Созданы аналог 1С Символы: Символы.ПС, Символы.ВК, Символы.Таб, Символы.ВТаб, Символы.ПФ, Символы.НПП . \n"+
                    "\n"+
                    "22.05.2026   Сделаны окна для тестов: HTTP-запросов, базы SQLite, выполнение кода Python в сценарии ВсеТесты.RUS. Исправлена вставка групп в окна. \n"+
                    "Исправлена функция executeCommand - теперь правильно выполняет команды через cmd /c. \n "+
                    "Создана функция findPythonPath - ищет Python через where python и в стандартных каталогах \n "+
                    "Исправлена функция runPython - теперь: Добавляет UTF-8 кодировку для вывода Python.  \n "+
                    "Добавлены русские псевдонимы - ВыполнитьPython, ПроверитьPython, ВерсияPython, УстановитьПутьPython \n"+
                    "Добавлена новая функция {ПортСвободен, isPortAvailable},  \n"+
                    "Выяснил странность, что препроцессор ломается на сочетании рядом символов обратный слеш и двойная кавычка. Пока проблему не решил !!!  \n"+
                    "\n"+
                    "21.05.2026   К имени виджета автоматически добавляется префикс с именем текущего окна, чтоб избежать дублирования префиксов в многооконной среде. " +
                    "При удалении окна удаляются все виджеты с соответствующим префиксом. \n Добавлена функция {MdiОкноСуществует, mdiWindowExists}, которая проверяет "+
                    "существует ли окно с таким именем. \n В removeMdiSubWindow теперь полная очистка ВСЕХ реестров при закрытии окна.\n В createMdiSubWindow при повторном "+
                    "открытии окна оно активируется, а не создаётся заново.\n При закрытии окна вызывается removeMdiSubWindow для полной очистки.\n "+
                    "Каждый виджет имеет уникальное глобальное имя в формате: ИмяОкна_ИмяВиджета. Уникальность имён - благодаря префиксам имена всех "+
                    "виджетов в программе уникальны. \n Прямой доступ - можно обращаться к любому виджету из любого места, зная его полное имя."+
                    "Функции для работы:  ПолучитьВиджет(полное_имя) - получить виджет по полному имени, ПолучитьЗначениеВиджета(полное_имя) - получить значение, "+
                    "УстановитьЗначениеВиджета(полное_имя, значение), УстановитьВидимость(полное_имя, видимо), ВиджетСуществует(полное_имя) - проверить существование."
                    
                    

  
    УстановитьЗначениеВиджета("ТекстЖурналИзменений", ЗначениеТекст)
КонецФункции

//#Область Тест HTTP-ЗАПРОСОВ

Функция СоздатьОкноHTTP()
    Пусть имяОкна = "ОкноHTTP"
    СоздатьПодокноMDI(Глоб_mdi, имяОкна, 10, 10, 850, 720)
    
    // Создаём вкладки
    СоздатьВкладки("ВкладкиHTTP", { "Лево": 5, "Верх": 5, "Ширина": 830, "Высота": 560, "Вкладки": "HTTP-тест" }, имяОкна)
    
    // Создаём HTTP клиент (один на все запросы)
    Пусть http = Новый HTTPЗапрос()
    
    // 1. Кнопка для получения IP
    ДобавитьВMDI(имяОкна, "Кнопка", "КнопкаIP", { "Лево": 20, "Верх": 20, "Ширина": 250, "Высота": 40, "Заголовок": "1. Получить мой IP адрес" })
    
    ПриНажатииКнопки("КнопкаIP", Функция() {
        Сообщить("Запрос IP адреса...")
        http.Получить("http://ip-api.com/json/", Функция(успех, ответ) {
            Если успех Тогда
                Попытка
                    Пусть инфо = JSON_ИзСтроки(ответ)
                    Пусть текст = "=== IP ИНФОРМАЦИЯ ===\n"
                    текст = текст + "IP: " + инфо.query + "\n"
                    текст = текст + "Страна: " + инфо.country + "\n"
                    текст = текст + "Город: " + инфо.city + "\n"
                    текст = текст + "Провайдер: " + инфо.org
                    
                    УстановитьТекстВРезультат("Результат", текст)
                    ПоказатьСообщение("Ваш IP: " + инфо.query)
                Исключение
                    Сообщить("Ошибка парсинга: " + e)
                    УстановитьТекстВРезультат("Результат", "Ошибка парсинга: " + e)
                КонецПопытки;
            Иначе
                Сообщить("Ошибка: " + ответ)
                УстановитьТекстВРезультат("Результат", "Ошибка: " + ответ)
            КонецЕсли;
        })
    })
    
    // 2. Кнопка для тестового GET запроса
    ДобавитьВMDI(имяОкна, "Кнопка", "КнопкаGET", {
        "Лево": 20, "Верх": 70, "Ширина": 250, "Высота": 40,
        "Заголовок": "2. Тестовый GET запрос"
    })
    
    ПриНажатииКнопки("КнопкаGET", Функция() {
        Сообщить("Выполнение GET запроса...")
        
        http.Получить("http://httpbin.org/get", Функция(успех, ответ) {
            Если успех Тогда
                Попытка
                    Пусть результат = JSON_ИзСтроки(ответ)
                    Пусть текст = "=== GET РЕЗУЛЬТАТ ===\n"
                    текст = текст + "Ваш IP: " + результат.origin + "\n"
                    текст = текст + "User-Agent: " + результат.headers["User-Agent"]
                    
                    УстановитьТекстВРезультат("Результат", текст)
                    ПоказатьСообщение("GET запрос выполнен успешно!")
                Исключение
                    Сообщить("Ошибка парсинга")
                    УстановитьТекстВРезультат("Результат", "Ошибка парсинга ответа")
                КонецПопытки;
            Иначе
                Сообщить("Ошибка: " + ответ)
                УстановитьТекстВРезультат("Результат", "Ошибка: " + ответ)
            КонецЕсли;
        })
    })
    
    // 3. Кнопка для POST запроса
    ДобавитьВMDI(имяОкна, "Кнопка", "КнопкаPOST", {
        "Лево": 20, "Верх": 120, "Ширина": 250, "Высота": 40,
        "Заголовок": "3. Тестовый POST запрос"
    })
    
    ПриНажатииКнопки("КнопкаPOST", Функция() {
        Сообщить("Выполнение POST запроса...")
        
        Пусть данные = "name=SmartGrid&version=1.0&test=ok"
        http.Отправить("http://httpbin.org/post", данные, Функция(успех, ответ) {
            Если успех Тогда
                Попытка
                    Пусть результат = JSON_ИзСтроки(ответ)
                    Пусть текст = "=== POST РЕЗУЛЬТАТ ===\n"
                    текст = текст + "Отправлено: name=" + результат.form.name + "\n"
                    текст = текст + "version=" + результат.form.version
                    
                    УстановитьТекстВРезультат("РезультатPOST", текст)
                    ПоказатьСообщение("POST запрос выполнен успешно!")
                Исключение
                    Сообщить("Ошибка парсинга")
                    УстановитьТекстВРезультат("РезультатPOST", "Ошибка парсинга ответа")
                КонецПопытки;
            Иначе
                Сообщить("Ошибка: " + ответ)
                УстановитьТекстВРезультат("РезультатPOST", "Ошибка: " + ответ)
            КонецЕсли;
        })
    })
    
    // 4. Кнопка для погоды
    ДобавитьВMDI(имяОкна, "Кнопка", "КнопкаПогода", {
        "Лево": 20, "Верх": 170, "Ширина": 250, "Высота": 40,
        "Заголовок": "4. Погода в Москве"
    })
    
    ПриНажатииКнопки("КнопкаПогода", Функция() {
        Сообщить("Запрос погоды...")
        
        http.Получить("https://api.open-meteo.com/v1/forecast?latitude=55.75&longitude=37.62&current_weather=true", Функция(успех, ответ) {
            Если успех Тогда
                Попытка
                    Пусть погода = JSON_ИзСтроки(ответ)
                    Пусть текст = "=== ПОГОДА В МОСКВЕ ===\n"
                    текст = текст + "Температура: " + погода.current_weather.temperature + "°C\n"
                    текст = текст + "Ветер: " + погода.current_weather.windspeed + " км/ч"
                    
                    УстановитьТекстВРезультат("Результат", текст)
                    ПоказатьСообщение("Температура: " + погода.current_weather.temperature + "°C")
                Исключение
                    Сообщить("Ошибка парсинга")
                    УстановитьТекстВРезультат("Результат", "Ошибка парсинга ответа")
                КонецПопытки;
            Иначе
                Сообщить("Ошибка: " + ответ)
                УстановитьТекстВРезультат("Результат", "Ошибка: " + ответ)
            КонецЕсли;
        })
    })
    
    // 5. Кнопка для шутки Chuck Norris
    ДобавитьВMDI(имяОкна, "Кнопка", "КнопкаФакт", {
        "Лево": 20, "Верх": 220, "Ширина": 250, "Высота": 40,
        "Заголовок": "5. Шутка Chuck Norris"
    })
    ПриНажатииКнопки("КнопкаФакт", Функция() {
        Сообщить("Запрос шутки...")
        
        http.Получить("https://api.chucknorris.io/jokes/random", Функция(успех, ответ) {
            Если успех Тогда
                Попытка
                    Пусть шутка = JSON_ИзСтроки(ответ)
                    Пусть текст = "=== ШУТКА CHUCK NORRIS ===\n\n" + шутка.value
                    УстановитьТекстВРезультат("Результат", текст)
                    ПоказатьСообщение(шутка.value)
                Исключение
                    Сообщить("Ошибка парсинга: " + e)
                    УстановитьТекстВРезультат("Результат", "Ошибка парсинга: " + e)
                КонецПопытки;
            Иначе
                Сообщить("Ошибка: " + ответ)
                УстановитьТекстВРезультат("Результат", "Ошибка: " + ответ)
            КонецЕсли;
        })
    })
    
    // 6. Кнопка для HTTPS теста
    ДобавитьВMDI(имяОкна, "Кнопка", "КнопкаHTTPS", {
        "Лево": 20, "Верх": 270, "Ширина": 250, "Высота": 40,
        "Заголовок": "6. Тест HTTPS (GitHub)"
    })
    
    ПриНажатииКнопки("КнопкаHTTPS", Функция() {
        Сообщить("Запрос HTTPS...")
        
        http.Получить("https://api.github.com/zen", Функция(успех, ответ) {
            Если успех Тогда
                Пусть текст = "=== HTTPS РАБОТАЕТ! ===\n\n"
                текст = текст + "Ответ от GitHub API:\n" + ответ
                
                УстановитьТекстВРезультат("Результат", текст)
                ПоказатьСообщение("GitHub Zen: " + ответ)
                Сообщить("HTTPS успешно: " + ответ)
            Иначе
                Сообщить("HTTPS ошибка: " + ответ)
                УстановитьТекстВРезультат("Результат", "HTTPS ошибка:\n" + ответ)
            КонецЕсли;
        })
    })
    
    // 7. Кнопка для HTTPS POST запроса
    ДобавитьВMDI(имяОкна, "Кнопка", "КнопкаHTTPS_POST", {
        "Лево": 20, "Верх": 320, "Ширина": 250, "Высота": 40,
        "Заголовок": "7. HTTPS POST (JSONPlaceholder)"
    })
    
    ПриНажатииКнопки("КнопкаHTTPS_POST", Функция() {
        Сообщить("Выполнение HTTPS POST запроса...")
        
        Пусть данные = "title=Test Post&body=This is a test&userId=1"
        
        http.Отправить("https://jsonplaceholder.typicode.com/posts", данные, Функция(успех, ответ) {
            Если успех Тогда
                Попытка
                    Пусть результат = JSON_ИзСтроки(ответ)
                    Пусть текст = "=== HTTPS POST УСПЕШЕН! ===\n\n"
                    текст = текст + "ID созданной записи: " + результат.id + "\n"
                    текст = текст + "Заголовок: " + результат.title + "\n"
                    текст = текст + "User ID: " + результат.userId
                    
                    УстановитьТекстВРезультат("РезультатPOST", текст)
                    ПоказатьСообщение("HTTPS POST успешен! ID: " + результат.id)
                    Сообщить("HTTPS POST ответ: " + ответ)
                Исключение
                    Сообщить("Ошибка парсинга: " + e)
                    УстановитьТекстВРезультат("РезультатPOST", "Ошибка парсинга: " + e)
                КонецПопытки;
            Иначе
                Сообщить("HTTPS POST ошибка: " + ответ)
                УстановитьТекстВРезультат("РезультатPOST", "HTTPS POST ошибка:\n" + ответ)
            КонецЕсли;
        })
    })
    
    // Надпись для GET результатов
    ДобавитьВMDI(имяОкна, "Надпись", "МеткаGET", { "Лево": 300, "Верх": 20, "Ширина": 150, "Высота": 25, "Заголовок": "GET результаты:" })
    
    // Текстовая область для GET результатов
    ДобавитьВMDI(имяОкна, "ТекстоваяОбласть", "Результат", { "Лево": 300, "Верх": 50, "Ширина": 500, "Высота": 250, "Значение": "Нажмите любую кнопку для выполнения запроса" })
    
    // Надпись для POST результатов
    ДобавитьВMDI(имяОкна, "Надпись", "МеткаPOST", { "Лево": 300, "Верх": 320, "Ширина": 150, "Высота": 25, "Заголовок": "POST результаты:" })
    
    // Текстовая область для POST результатов
    ДобавитьВMDI(имяОкна, "ТекстоваяОбласть", "РезультатPOST", { "Лево": 300, "Верх": 350, "Ширина": 500, "Высота": 100, "Значение": "POST результаты появятся здесь" })
    
    // Информационная надпись
    ДобавитьВMDI(имяОкна, "Надпись", "Инфо", { "Лево": 300, "Верх": 470, "Ширина": 500, "Высота": 60, 
        "Заголовок": "Используемые API:\nhttpbin.org, ip-api.com, open-meteo.com, numbersapi.com, api.github.com" })
        
КонецФункции

// ВСПОМОГАТЕЛЬНАЯ ФУНКЦИЯ ДЛЯ УСТАНОВКИ ТЕКСТА В РЕЗУЛЬТАТ
Функция УстановитьТекстВРезультат(имяВиджета, текст)
    Пусть виджет = ПолучитьВиджет(имяВиджета)
    Если виджет Тогда
        виджет.установитьПростойТекст(текст)
    Иначе
        Сообщить("Виджет не найден: " + имяВиджета)
    КонецЕсли;
    Возврат ИСТИНА
КонецФункции


