Функция СоздатьОтчётМакрос()
    Если НЕ Глоб_СерверЗапущен Тогда
        ДобавитьВЛог("❌ Серверы не запущены!", "error")
        Возврат
    КонецЕсли;
    
    ДобавитьВЛог("📝 СОЗДАНИЕ ОТЧЁТА ЧЕРЕЗ МАКРОС", "progress")
    
    Пусть filePath = "C:/report_macro_" + СгенерироватьUUID() + ".ods"
    
    // Исправленный макрос - без использования chr()
    Пусть macroCode = `
try:
    doc = desktop.loadComponentFromURL("private:factory/scalc", "_blank", 0, ())
    sheet = doc.getSheets().getByIndex(0)
    
    headers = ["ID", "ФИО", "Должность", "Оклад", "Премия", "Итого"]
    for col, header in enumerate(headers):
        cell = sheet.getCellByPosition(col, 0)
        cell.setString(header)
        cell.CharWeight = 150
        cell.CellBackColor = 0x1b5e20
        cell.CharColor = 0xffffff
    
    data = [
        [1, "Иванов Иван", "Инженер", 50000, 10000, 0],
        [2, "Петров Пётр", "Программист", 65000, 13000, 0],
        [3, "Сидорова Мария", "Бухгалтер", 55000, 11000, 0],
        [4, "Кузнецов Алексей", "Менеджер", 60000, 12000, 0],
        [5, "Васильева Ольга", "Аналитик", 58000, 11600, 0]
    ]
    
    for row_idx, row in enumerate(data):
        for col_idx, value in enumerate(row):
            cell = sheet.getCellByPosition(col_idx, row_idx + 1)
            if col_idx >= 3 and isinstance(value, (int, float)):
                cell.setValue(value)
                cell.NumberFormat = 1
            elif isinstance(value, (int, float)):
                cell.setValue(value)
            else:
                cell.setString(str(value))
        cell = sheet.getCellByPosition(5, row_idx + 1)
        # Используем прямое вычисление вместо f-строки
        cell.setFormula("=D" + str(row_idx + 2) + "+E" + str(row_idx + 2))
        cell.NumberFormat = 1
    
    total_row = len(data) + 1
    # Используем прямое указание колонок без chr()
    for col, col_letter in [(3, "D"), (4, "E"), (5, "F")]:
        cell = sheet.getCellByPosition(col, total_row)
        cell.setFormula("=SUM(" + col_letter + "2:" + col_letter + str(len(data) + 1) + ")")
        cell.CellBackColor = 0xffd700
        cell.NumberFormat = 1
    
    label_cell = sheet.getCellByPosition(1, total_row)
    label_cell.setString("ИТОГО:")
    label_cell.CharWeight = 150
    label_cell.CellBackColor = 0xffd700
    
    for col in range(6):
        sheet.getColumns().getByIndex(col).OptimalWidth = True
    
    url = uno.systemPathToFileUrl("` + filePath + `")
    doc.storeToURL(url, ())
    print("SUCCESS")
except:
    import traceback
    print("ERROR: " + traceback.format_exc())
`
    
    Попытка
        Пусть результат = ВызватьФункциюСервера("ExecuteMacro", [macroCode])
        ДобавитьВЛог("Результат: " + результат, "macro")
        
        Если результат.indexOf("SUCCESS") >= 0 Тогда
            ДобавитьВЛог("✅ Отчёт через макрос сохранён: " + filePath, "success")
            ВыполнитьКоманду("start \"\" \"" + filePath + "\"", 1000)
            ПоказатьСообщение("Отчёт через макрос создан!\nФайл: " + filePath)
        Иначе
            ДобавитьВЛог("❌ Ошибка: " + результат, "error")
            ПоказатьСообщение("Ошибка: " + результат)
        КонецЕсли;
    Исключение
        ДобавитьВЛог("❌ Исключение: " + e, "error")
    КонецПопытки;
КонецФункции

