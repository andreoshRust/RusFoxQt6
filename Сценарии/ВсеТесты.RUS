        "• СписокЗначений\n" +
        "• Регулярные выражения\n" 
    })
    
    // ==================== ПРАВАЯ ПАНЕЛЬ  ====================
    ДобавитьНаВкладку("ГлавнаяВкладка", 0, "Группа", "logGroup", { "Лево": 290, "Верх": 5, "Ширина": 530, "Высота": 630, "Заголовок": "📜 ЖУРНАЛ ТЕСТИРОВАНИЯ" })
    ДобавитьНаВкладку("ГлавнаяВкладка", 0, "ТекстоваяОбласть", "txtLog", { "Лево": 300, "Верх": 35, "Ширина": 510, "Высота": 580, "Значение": "=== ЖУРНАЛ ТЕСТИРОВАНИЯ ===\n\n" })
    
    ДобавитьВЛог("✅ Тестовое окно 1С-подобных функций создано")
    ДобавитьВЛог("📌 Нажмите на любую кнопку для запуска тестов")
    
    Возврат имяОкна    

КонецФункции

// ============================================================================
// ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ
// ============================================================================
//Пусть Глоб_ЛогБуфер = ""

Функция ДобавитьВЛог(сообщение, тип)
    Пусть время = ТекущееВремя("HH:MM:SS")
    Пусть префикс = ""
    
    // Отладочный вывод (можно удалить потом)
     Сообщить("DEBUG: тип = '" + тип + "', длина = " + СтрДлина(тип))
    
    // Приводим тип к нижнему регистру для надёжности
    Пусть типНорм = НРег(тип)
    
    Если типНорм == "info" Тогда 
        префикс = "ℹ️"
    ИначеЕсли типНорм == "success" Тогда 
        префикс = "✅"
    ИначеЕсли типНорм == "error" Тогда 
        префикс = "❌"
    ИначеЕсли типНорм == "warning" Тогда 
        префикс = "⚠️"
    ИначеЕсли типНорм == "progress" Тогда 
        префикс = "🔄"
    ИначеЕсли типНорм == "command" Тогда 
        префикс = "💻"
    Иначе
        префикс = "📌"
        // Отладка: выводим непонятный тип
        Сообщить("Неизвестный тип: '" + тип + "'")
    КонецЕсли;
    
    Пусть строкаЛога = "[" + время + "] " + префикс + " " + сообщение
    
    // Добавляем в конец
    
    ЛогБуфер = ПолучитьЗначениеВиджета("txtLog")
    //Отладка(ЛогБуфер)
    ЛогБуфер = ЛогБуфер + строкаЛога + "\n"
    
    //// Ограничиваем размер
    //Если СтрДлина(Глоб_ЛогБуфер) > 50000 Тогда
    //    Глоб_ЛогБуфер = Прав(Глоб_ЛогБуфер, 50000)
    //КонецЕсли;
    
    //УстановитьТекст("txtLog", ЛогБуфер)
    УстановитьЗначениеВиджета("txtLog", ЛогБуфер)
    Сообщить(строкаЛога)
КонецФункции

Функция ОчиститьЛог()
    ЛогБуфер = "=== ЖУРНАЛ ТЕСТИРОВАНИЯ ===\n\n"
    УстановитьТекст("txtLog", ЛогБуфер)
    ДобавитьВЛог("Журнал очищен")
КонецФункции

Функция ТестСтроковыхФункций()
    ДобавитьВЛог("========== ТЕСТ СТРОКОВЫХ ФУНКЦИЙ ==========", "info")
    
    // 1. СтрДлина
    Пусть текст1 = "Привет, мир!"
    Пусть длина = СтрДлина(текст1)
    Пусть тип = "success"
    Если длина != 12 Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("1. СтрДлина('" + текст1 + "') = " + длина + " (ожидается: 12)", тип)
    
    // 2. Лев
    Пусть лево = Лев(текст1, 6)
    тип = "success"
    Если лево != "Привет" Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("2. Лев('" + текст1 + "', 6) = '" + лево + "' (ожидается: 'Привет')", тип)
    
    // 3. Прав
    Пусть право = Прав(текст1, 4)
    тип = "success"
    Если право != "мир!" Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("3. Прав('" + текст1 + "', 4) = '" + право + "' (ожидается: 'мир!')", тип)
    
    // 4. Сред
    Пусть середина = Сред(текст1, 9, 3)
    тип = "success"
    Если середина != "мир" Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("4. Сред('" + текст1 + "', 9, 3) = '" + середина + "' (ожидается: 'мир')", тип)
    
    // 5. СтрНайти
    Пусть позиция = СтрНайти(текст1, "мир")
    тип = "success"
    Если позиция != 9 Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("5. СтрНайти('" + текст1 + "', 'мир') = " + позиция + " (ожидается: 9)", тип)
    
    // 6. СтрЧислоВхождений
    Пусть текст2 = "я, я и ещё раз я."
    Пусть количество = СтрЧислоВхождений(текст2, "я")
    тип = "success"
    Если количество != 3 Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("6. СтрЧислоВхождений('" + текст2 + "', 'я') = " + количество + " (ожидается: 3)", тип)
    
    // 7. СтрЗаменить
    Пусть текст3 = "Идёт сильный дождь."
    Пусть новый = СтрЗаменить(текст3, "дождь", "снег")
    тип = "success"
    Если новый != "Идёт сильный снег." Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("7. СтрЗаменить('" + текст3 + "', 'дождь', 'снег') = '" + новый + "' (ожидается: 'Идёт сильный снег.')", тип)
    
    // 8. ПустаяСтрока
    Пусть пустая = ПустаяСтрока("     ")
    тип = "success"
    Если НЕ пустая Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("8. ПустаяСтрока('     ') = " + пустая + " (ожидается: true)", тип)
    
    // 9. СокрЛ, СокрП, СокрЛП
    Пусть текст4 = "   из лесу ёлочку    "
    Пусть сокрЛ = СокрЛ(текст4)
    тип = "success"
    Если сокрЛ != "из лесу ёлочку    " Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("9. СокрЛ('" + текст4 + "') = '" + сокрЛ + "'", тип)
    
    Пусть сокрП = СокрП(текст4)
    тип = "success"
    Если сокрП != "   из лесу ёлочку" Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("   СокрП('" + текст4 + "') = '" + сокрП + "'", тип)
    
    Пусть сокрЛП = СокрЛП(текст4)
    тип = "success"
    Если сокрЛП != "из лесу ёлочку" Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("   СокрЛП('" + текст4 + "') = '" + сокрЛП + "'", тип)
    
    // 10. ВРег, НРег, ТРег
    Пусть текст5 = "россия - родина моя!"
    Пусть верх = ВРег(текст5)
    тип = "success"
    Если верх != "РОССИЯ - РОДИНА МОЯ!" Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("10. ВРег('" + текст5 + "') = '" + верх + "'", тип)
    
    Пусть низ = НРег("МИР, ТРУД, МАЙ!")
    тип = "success"
    Если низ != "мир, труд, май!" Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("    НРег('МИР, ТРУД, МАЙ!') = '" + низ + "'", тип)
    
    Пусть титул = ТРег("мама мыла раму")
    тип = "success"
    Если титул != "Мама Мыла Раму" Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("    ТРег('мама мыла раму') = '" + титул + "'", тип)
    
    // 11. КодСимвола, Символ
    Пусть кодА = КодСимвола("A")
    тип = "success"
    Если кодА != 65 Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("11. КодСимвола('A') = " + кодА + " (ожидается: 65)", тип)
    
    Пусть символ65 = Символ(65)
    тип = "success"
    Если символ65 != "A" Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("    Символ(65) = '" + символ65 + "' (ожидается: 'A')", тип)
    
    Пусть кодЁ = КодСимвола("Ё")
    тип = "success"
    Если кодЁ != 1025 Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("    КодСимвола('Ё') = " + кодЁ + " (ожидается: 1025)", тип)
    
    ДобавитьВЛог("========== ТЕСТ СТРОКОВЫХ ФУНКЦИЙ ЗАВЕРШЁН ==========", "success")
КонецФункции

Функция ТестЧисловыхФункций()
    ДобавитьВЛог("========== ТЕСТ ЧИСЛОВЫХ ФУНКЦИЙ ==========", "info")
    
    // 1. Число (stringToNumber)
    Пусть число1 = Число("125.36")
    Пусть тип = "success"
    Если число1 != 125.36 Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("1. Число('125.36') = " + число1 + " (ожидается: 125.36)", тип)
    
    Пусть число2 = Число("125,36")
    тип = "success"
    Если число2 != 125.36 Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("   Число('125,36') = " + число2 + " (ожидается: 125.36)", тип)
    
    Пусть число3 = Число("  1 234.56  ")
    тип = "success"
    Если число3 != 1234.56 Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("   Число('  1 234.56  ') = " + число3 + " (ожидается: 1234.56)", тип)
    
    // 2. Формат (formatNumber)
    Пусть формат1 = ФорматЧисла(125.3678, 2)
    тип = "success"
    Если формат1 != "125.37" Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("2. ФорматЧисла(125.3678, 2) = '" + формат1 + "' (ожидается: '125.37')", тип)
    
    Пусть формат2 = ФорматЧисла(125.3678, 0)
    тип = "success"
    Если формат2 != "125" Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("   ФорматЧисла(125.3678, 0) = '" + формат2 + "' (ожидается: '125')", тип)
    
    // 3. Строка (numberToString)
    Пусть строка1 = Строка(125.36, 2)
    тип = "success"
    Если строка1 != "125.36" Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("3. Строка(125.36, 2) = '" + строка1 + "' (ожидается: '125.36')", тип)
    
    Пусть строка2 = Строка(125.99, 0)
    тип = "success"
    Если строка2 != "126" Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("   Строка(125.99, 0) = '" + строка2 + "' (ожидается: '126')", тип)
    
    // 4. Сумма
    Пусть сумма = 125.50 + 2300.75
    Пусть форматСуммы = ФорматЧисла(сумма, 2)
    тип = "success"
    Если Число(форматСуммы) != 2426.25 Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("4. Сумма: 125.50 + 2300.75 = " + форматСуммы + " (ожидается: 2426.25)", тип)
    
    ДобавитьВЛог("========== ТЕСТ ЧИСЛОВЫХ ФУНКЦИЙ ЗАВЕРШЁН ==========", "success")
КонецФункции

Функция ТестСтруктур()
    ДобавитьВЛог("========== ТЕСТ СТРУКТУР ==========", "info")
    
    // 1. Создание структуры
    Пусть сотрудник = Структура(["ФИО,Возраст,Город,Оклад", "Иванов Иван", 30, "Москва", 85000])
    Пусть тип = "success"
    Если сотрудник.ФИО != "Иванов Иван" Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("1. Структура создана: ФИО=" + сотрудник.ФИО + ", Возраст=" + сотрудник.Возраст, тип)
    
    // 2. Получение ключей и значений
    Пусть ключи = СтруктураКлючи(сотрудник)
    тип = "success"
    Если ключи.длина != 4 Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("2. Ключи: " + ключи.join(", "), тип)
    
    Пусть значения = СтруктураЗначения(сотрудник)
    тип = "success"
    Если значения.длина != 4 Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("   Значения: " + значения.join(", "), тип)
    
    // 3. Изменение полей
    сотрудник.Оклад = 90000
    тип = "success"
    Если сотрудник.Оклад != 90000 Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("3. Новый оклад: " + сотрудник.Оклад, тип)
    
    // 4. Вложенные структуры
    Пусть адрес = Структура(["Город,Улица,Дом", "Москва", "Тверская", 15])
    Пусть организация = Структура([])
    организация.Название = "ООО Ромашка"
    организация.Адрес = адрес
    тип = "success"
    Если организация.Адрес.Город != "Москва" Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("4. Вложенная структура: " + организация.Название + ", " + организация.Адрес.Город, тип)
    
    ДобавитьВЛог("========== ТЕСТ СТРУКТУР ЗАВЕРШЁН ==========", "success")
КонецФункции

Функция ТестСоответствия()
    ДобавитьВЛог("========== ТЕСТ СООТВЕТСТВИЯ 1 ==========", "info")
    
    // 1. Создание соответствия
    Пусть цвета = Новый Соответствие()
    цвета.ИзМассива(["Красный", "#FF0000", "Зеленый", "#00FF00", "Синий", "#0000FF"])
    Пусть тип = "success"
    Если цвета.Количество() != 3 Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("1. Соответствие создано, количество: " + цвета.Количество(), "success")
    
    // 2. Добавление элемента
    цвета.Вставить("Желтый", "#FFFF00")
    тип = "success"
    Если цвета.Количество() != 4 Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("2. Добавлен 'Желтый', теперь элементов: " + цвета.Количество(), тип)
    
    // 3. Получение значения
    Пусть код = цвета.Получить("Красный")
    тип = "success"
    Если код != "#FF0000" Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("3. Получить('Красный') = " + код, тип)
    
    // 4. Проверка наличия
    Если цвета.Есть("Синий") Тогда
        ДобавитьВЛог("4. 'Синий' есть в соответствии", "success")
    Иначе
        ДобавитьВЛог("4. 'Синий' есть в соответствии", "error")
    КонецЕсли;
    
    // 5. Получение всех ключей и значений
    Пусть всеКлючи = КлючиСоответствия(цвета)
    тип = "success"
    Если всеКлючи.длина != 4 Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("5. Ключи: " + всеКлючи.join(", "), тип)
    
    Пусть всеЗначения = ЗначенияСоответствия(цвета)
    тип = "success"
    Если всеЗначения.длина != 4 Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("   Значения: " + всеЗначения.join(", "), тип)
    
    // 6. Удаление элемента
    цвета.Удалить("Зеленый")
    тип = "success"
    Если цвета.Количество() != 3 Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("6. После удаления 'Зеленый', элементов: " + цвета.Количество(), тип)
    
    ДобавитьВЛог("========== ТЕСТ СООТВЕТСТВИЯ 1 ЗАВЕРШЁН ==========", "success")

    ДобавитьВЛог("========== ТЕСТ СООТВЕТСТВИЯ (Класс) ==========", "info")
    
    Попытка
        цвета = Новый Соответствие()
        ДобавитьВЛог("1. Соответствие создано", "success")
    Исключение
        ДобавитьВЛог("1. Ошибка: " + e, "error")
        Возврат
    КонецПопытки;
    
    Попытка
        цвета.Вставить("Красный", "#FF0000")
        цвета.Вставить("Зеленый", "#00FF00")
        цвета.Вставить("Синий", "#0000FF")
        
        Если цвета.Количество() == 3 Тогда
            ДобавитьВЛог("2. Добавлено 3 элемента, Количество() = " + цвета.Количество(), "success")
        Иначе
            ДобавитьВЛог("2. Ошибка: Количество() = " + цвета.Количество(), "error")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("2. Ошибка: " + e, "error")
    КонецПопытки;
    
    Попытка
        значение = цвета.Получить("Красный")
        ДобавитьВЛог("3. Получить('Красный') = " + значение, "success")
    Исключение
        ДобавитьВЛог("3. Ошибка: " + e, "error")
    КонецПопытки;
    
    Попытка
        Если цвета.Есть("Синий") Тогда
            ДобавитьВЛог("4. 'Синий' есть в соответствии", "success")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("4. Ошибка: " + e, "error")
    КонецПопытки;
    
    Попытка
        всеКлючи = цвета.Ключи()
        ДобавитьВЛог("5. Ключи: " + всеКлючи.join(", "), "success")
    Исключение
        ДобавитьВЛог("5. Ошибка: " + e, "error")
    КонецПопытки;
    
    Попытка
        цвета.Удалить("Зеленый")
        Если цвета.Количество() == 2 Тогда
            ДобавитьВЛог("6. После удаления, Количество() = " + цвета.Количество(), "success")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("6. Ошибка: " + e, "error")
    КонецПопытки;
    
    Попытка
        цвета.Очистить()
        Если цвета.Пустой() Тогда
            ДобавитьВЛог("7. Соответствие очищено, Пустой() = Истина", "success")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("7. Ошибка: " + e, "error")
    КонецПопытки;
    
    ДобавитьВЛог("========== ТЕСТ СООТВЕТСТВИЯ 2 ЗАВЕРШЁН ==========", "success")
КонецФункции

Функция ТестСпискаЗначений()
    ДобавитьВЛог("========== ТЕСТ СПИСКА ЗНАЧЕНИЙ ==========", "info")
    
    Пусть месяцы
    
    // 1. Создание
    Попытка
        месяцы = Новый СписокЗначений()
        ДобавитьВЛог("1. СписокЗначений создан", "success")
    Исключение
        ДобавитьВЛог("1. Ошибка создания: " + e, "error")
        Возврат
    КонецПопытки;
    
    // 2. Добавление элементов
    Попытка
        месяцы.Добавить(1, "Январь")
        месяцы.Добавить(2, "Февраль")
        месяцы.Добавить(3, "Март")
        ДобавитьВЛог("2. Добавлены элементы: Январь, Февраль, Март", "success")
    Исключение
        ДобавитьВЛог("2. Ошибка добавления: " + e, "error")
    КонецПопытки;
    
    // 3. Вставка в начало
    Попытка
        месяцы.Вставить(0, 0, "-- Выберите месяц --")
        ДобавитьВЛог("3. Вставлен элемент в начало", "success")
    Исключение
        ДобавитьВЛог("3. Ошибка вставки: " + e, "error")
    КонецПопытки;
    
    // 4. Проверка количества
    Попытка
        Если месяцы.Количество() == 4 Тогда
            ДобавитьВЛог("4. Количество() = " + месяцы.Количество(), "success")
        Иначе
            ДобавитьВЛог("4. Ошибка: Количество() = " + месяцы.Количество(), "error")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("4. Ошибка Количество(): " + e, "error")
    КонецПопытки;
    
    // 5. Получение значений
    Попытка
        Для i = 0 По месяцы.Количество() - 1 Цикл
            значение = месяцы.Значение(i)
            представление = месяцы.Представление(i)
            ДобавитьВЛог("   Элемент " + i + ": " + представление + " (" + значение + ")", "info")
        КонецЦикла;
        ДобавитьВЛог("5. Значения получены", "success")
    Исключение
        ДобавитьВЛог("5. Ошибка получения значений: " + e, "error")
    КонецПопытки;
    
    // 6. Поиск по значению
    Попытка
        индекс = месяцы.НайтиПоЗначению(3)
        Если индекс == 3 Тогда
            ДобавитьВЛог("6. Индекс значения 3: " + индекс, "success")
        Иначе
            ДобавитьВЛог("6. Индекс значения 3: " + индекс + " (ожидалось 3)", "warning")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("6. Ошибка поиска: " + e, "error")
    КонецПопытки;
    
    // 7. Поиск по представлению
    Попытка
        индекс = месяцы.НайтиПоПредставлению("Февраль")
        Если индекс == 2 Тогда
            ДобавитьВЛог("7. Индекс 'Февраль': " + индекс, "success")
        Иначе
            ДобавитьВЛог("7. Индекс 'Февраль': " + индекс + " (ожидалось 2)", "warning")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("7. Ошибка поиска: " + e, "error")
    КонецПопытки;
    
    // 8. Установка отметки
    Попытка
        месяцы.УстановитьОтметку(2, Истина)
        ДобавитьВЛог("8. Установлена отметка для элемента 2", "success")
    Исключение
        ДобавитьВЛог("8. Ошибка установки отметки: " + e, "error")
    КонецПопытки;
    
    // 9. Получение отмеченных значений
    Попытка
        отмеченные = месяцы.ОтмеченныеЗначения()
        Если отмеченные.длина == 1 Тогда
            ДобавитьВЛог("9. Отмеченные значения: " + отмеченные.join(", "), "success")
        Иначе
            ДобавитьВЛог("9. Отмеченные значения: " + отмеченные.join(", ") + " (ожидалось 1)", "warning")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("9. Ошибка получения отмеченных: " + e, "error")
    КонецПопытки;
    
    // 10. Получение отмеченных индексов
    Попытка
        отмеченныеИндексы = месяцы.ОтмеченныеИндексы()
        ДобавитьВЛог("10. Отмеченные индексы: " + отмеченныеИндексы.join(", "), "success")
    Исключение
        ДобавитьВЛог("10. Ошибка: " + e, "error")
    КонецПопытки;
    
    // 11. Установка пометки
    Попытка
        месяцы.УстановитьПометку(1, Истина)
        ДобавитьВЛог("11. Установлена пометка для элемента 1", "success")
    Исключение
        ДобавитьВЛог("11. Ошибка: " + e, "error")
    КонецПопытки;
    
    // 12. Получение помеченных значений
    Попытка
        помеченные = месяцы.ПомеченныеЗначения()
        ДобавитьВЛог("12. Помеченные значения: " + помеченные.join(", "), "success")
    Исключение
        ДобавитьВЛог("12. Ошибка: " + e, "error")
    КонецПопытки;
    
    // 13. Получение всех значений
    Попытка
        всеЗначения = месяцы.Значения()
        ДобавитьВЛог("13. Все значения: " + всеЗначения.join(", "), "success")
    Исключение
        ДобавитьВЛог("13. Ошибка: " + e, "error")
    КонецПопытки;
    
    // 14. Получение всех представлений
    Попытка
        всеПредставления = месяцы.Представления()
        ДобавитьВЛог("14. Все представления: " + всеПредставления.join(", "), "success")
    Исключение
        ДобавитьВЛог("14. Ошибка: " + e, "error")
    КонецПопытки;
    
    // 15. Удаление элемента
    Попытка
        месяцы.Удалить(0)
        ДобавитьВЛог("15. После удаления, Количество() = " + месяцы.Количество(), "success")
    Исключение
        ДобавитьВЛог("15. Ошибка удаления: " + e, "error")
    КонецПопытки;
    
    // 16. Очистка
    Попытка
        месяцы.Очистить()
        Если месяцы.Пустой() Тогда
            ДобавитьВЛог("16. Список очищен, Пустой() = Истина", "success")
        Иначе
            ДобавитьВЛог("16. Ошибка: список не пуст, Количество() = " + месяцы.Количество(), "error")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("16. Ошибка очистки: " + e, "error")
    КонецПопытки;
    
    ДобавитьВЛог("========== ТЕСТ СПИСКА ЗНАЧЕНИЙ ЗАВЕРШЁН ==========", "success")
КонецФункции

Функция ТестРегулярныхВыражений()
    ДобавитьВЛог("========== ТЕСТ РЕГУЛЯРНЫХ ВЫРАЖЕНИЙ ==========", "info")
    
    // 1. РегВырСовпадает
    Пусть совпадает1 = РегВырСовпадает("email@example.com", "\\w+@\\w+\\.\\w+")
    Пусть тип = "success"
    Если НЕ совпадает1 Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("1. РегВырСовпадает('email@example.com', '\\w+@\\w+\\.\\w+') = " + совпадает1, тип)
    
    // 2. РегВырНайти
    Пусть найден = РегВырНайти("Мой email: test@example.com", "\\w+@\\w+\\.\\w+")
    тип = "success"
    Если найден != "test@example.com" Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("2. РегВырНайти = '" + найден + "'", тип)
    
    // 3. РегВырНайтиВсе
    Пусть всеЦифры = РегВырНайтиВсе("a1b2c3d4", "\\d")
    тип = "success"
    Если всеЦифры.длина != 4 Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("3. РегВырНайтиВсе цифры: " + всеЦифры.join(", "), тип)
    
    // 4. РегВырЗаменить
    Пусть заменено = РегВырЗаменить("a1b2c3", "\\d", "X")
    тип = "success"
    Если заменено != "aXbXcX" Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("4. РегВырЗаменить('a1b2c3', '\\d', 'X') = '" + заменено + "'", тип)
    
    // 5. РегВырРазделить
    Пусть части = РегВырРазделить("раз,два,три", ",")
    тип = "success"
    Если части.длина != 3 Тогда тип = "error" КонецЕсли;
    ДобавитьВЛог("5. РегВырРазделить: " + части.join(", "), тип)
    
    ДобавитьВЛог("========== ТЕСТ РЕГУЛЯРНЫХ ВЫРАЖЕНИЙ ЗАВЕРШЁН ==========", "success")
КонецФункции

Функция ТестТаблицыЗначений()
    ДобавитьВЛог("========== ТЕСТ ТАБЛИЦЫ ЗНАЧЕНИЙ ==========", "info")
    
    Пусть таблица
    
    // ========== 1. СОЗДАНИЕ ТАБЛИЦЫ ==========
    Попытка
        таблица = Новый ТаблицаЗначений()
        ДобавитьВЛог("1. ТаблицаЗначений создана", "success")
    Исключение
        ДобавитьВЛог("1. Ошибка создания: " + e, "error")
        Возврат
    КонецПопытки;
    
    // ========== 2. ДОБАВЛЕНИЕ КОЛОНОК ==========
    Попытка
        таблица.ДобавитьКолонку("Фамилия", "string", 120)
        таблица.ДобавитьКолонку("Имя", "string", 100)
        таблица.ДобавитьКолонку("Возраст", "number", 60)
        таблица.ДобавитьКолонку("Работает", "boolean", 80)
        ДобавитьВЛог("2. Добавлено 4 колонки", "success")
    Исключение
        ДобавитьВЛог("2. Ошибка добавления колонок: " + e, "error")
    КонецПопытки;
    
    // ========== 3. ПРОВЕРКА КОЛОНОК ==========
    Попытка
        Если таблица.КоличествоКолонок() == 4 Тогда
            ДобавитьВЛог("3. КоличествоКолонок() = " + таблица.КоличествоКолонок(), "success")
        Иначе
            ДобавитьВЛог("3. Ошибка: КоличествоКолонок() = " + таблица.КоличествоКолонок(), "error")
        КонецЕсли;
        
        именаКолонок = таблица.ИменаКолонок()
        Если именаКолонок.длина == 4 Тогда
            ДобавитьВЛог("   Имена колонок: " + именаКолонок.join(", "), "info")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("3. Ошибка: " + e, "error")
    КонецПопытки;
    
    // ========== 4. ВСТАВКА КОЛОНКИ ==========
    Попытка
        таблица.ВставитьКолонку(2, "Отчество", "string", 120)
        Если таблица.КоличествоКолонок() == 5 Тогда
            ДобавитьВЛог("4. Вставлена колонка 'Отчество', теперь колонок: " + таблица.КоличествоКолонок(), "success")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("4. Ошибка вставки колонки: " + e, "error")
    КонецПопытки;
    
    // ========== 5. ДОБАВЛЕНИЕ СТРОК ==========
    Попытка
        строка1 = таблица.ДобавитьСтроку()
        строка2 = таблица.ДобавитьСтроку()
        строка3 = таблица.ДобавитьСтроку()
        
        Если таблица.КоличествоСтрок() == 3 Тогда
            ДобавитьВЛог("5. Добавлено 3 строки, КоличествоСтрок() = " + таблица.КоличествоСтрок(), "success")
        Иначе
            ДобавитьВЛог("5. Ошибка: КоличествоСтрок() = " + таблица.КоличествоСтрок(), "error")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("5. Ошибка добавления строк: " + e, "error")
    КонецПопытки;
    
    // ========== 6. ЗАПОЛНЕНИЕ ЗНАЧЕНИЙ ==========
    Попытка
        таблица.УстановитьЗначение(0, "Фамилия", "Иванов")
        таблица.УстановитьЗначение(0, "Имя", "Иван")
        таблица.УстановитьЗначение(0, "Отчество", "Иванович")
        таблица.УстановитьЗначение(0, "Возраст", 30)
        таблица.УстановитьЗначение(0, "Работает", Истина)
        
        таблица.УстановитьЗначение(1, "Фамилия", "Петров")
        таблица.УстановитьЗначение(1, "Имя", "Петр")
        таблица.УстановитьЗначение(1, "Отчество", "Петрович")
        таблица.УстановитьЗначение(1, "Возраст", 25)
        таблица.УстановитьЗначение(1, "Работает", Истина)
        
        таблица.УстановитьЗначение(2, "Фамилия", "Сидорова")
        таблица.УстановитьЗначение(2, "Имя", "Мария")
        таблица.УстановитьЗначение(2, "Отчество", "Алексеевна")
        таблица.УстановитьЗначение(2, "Возраст", 28)
        таблица.УстановитьЗначение(2, "Работает", Ложь)
        
        ДобавитьВЛог("6. Значения установлены", "success")
    Исключение
        ДобавитьВЛог("6. Ошибка установки значений: " + e, "error")
    КонецПопытки;
    
    // ========== 7. ПОЛУЧЕНИЕ ЗНАЧЕНИЙ ==========
    Попытка
        фамилия = таблица.ПолучитьЗначение(0, "Фамилия")
        имя = таблица.ПолучитьЗначение(0, "Имя")
        возраст = таблица.ПолучитьЗначение(0, "Возраст")
        работает = таблица.ПолучитьЗначение(0, "Работает")
        
        ДобавитьВЛог("7. Получение значений:", "info")
        ДобавитьВЛог("   Строка 0: " + фамилия + " " + имя + ", возраст=" + возраст + ", работает=" + (работает ? "Да" : "Нет"), "success")
    Исключение
        ДобавитьВЛог("7. Ошибка получения значений: " + e, "error")
    КонецПопытки;
    
    // ========== 8. ВЫВОД ВСЕХ ДАННЫХ ==========
    Попытка
        ДобавитьВЛог("8. Все данные таблицы:", "info")
        Для i = 0 По таблица.КоличествоСтрок() - 1 Цикл
            фамилия = таблица.ПолучитьЗначение(i, "Фамилия")
            имя = таблица.ПолучитьЗначение(i, "Имя")
            отчество = таблица.ПолучитьЗначение(i, "Отчество")
            возраст = таблица.ПолучитьЗначение(i, "Возраст")
            работает = таблица.ПолучитьЗначение(i, "Работает")
            ДобавитьВЛог("   [" + i + "] " + фамилия + " " + имя + " " + отчество + 
                         ", " + возраст + " лет, работает=" + (работает ? "Да" : "Нет"), "info")
        КонецЦикла;
    Исключение
        ДобавитьВЛог("8. Ошибка вывода: " + e, "error")
    КонецПопытки;
    
    // ========== 9. ПОИСК СТРОКИ ==========
    Попытка
        индекс = таблица.НайтиСтроку("Фамилия", "Петров")
        Если индекс == 1 Тогда
            ДобавитьВЛог("9. НайтиСтроку('Фамилия', 'Петров') = " + индекс, "success")
        Иначе
            ДобавитьВЛог("9. НайтиСтроку('Фамилия', 'Петров') = " + индекс + " (ожидалось 1)", "warning")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("9. Ошибка поиска: " + e, "error")
    КонецПопытки;
    
    // ========== 10. СОРТИРОВКА ==========
    Попытка
        таблица.СортироватьПоКолонке("Возраст", Истина)  // по возрастанию
        ДобавитьВЛог("10. Сортировка по возрасту (возрастание):", "success")
        
        // Вывод после сортировки
        Для i = 0 По таблица.КоличествоСтрок() - 1 Цикл
            фамилия = таблица.ПолучитьЗначение(i, "Фамилия")
            возраст = таблица.ПолучитьЗначение(i, "Возраст")
            ДобавитьВЛог("    " + фамилия + " - " + возраст + " лет", "info")
        КонецЦикла;
    Исключение
        ДобавитьВЛог("10. Ошибка сортировки: " + e, "error")
    КонецПопытки;
    
    // ========== 11. ВСТАВКА СТРОКИ ==========
    Попытка
        таблица.ВставитьСтроку(1)
        таблица.УстановитьЗначение(1, "Фамилия", "Новый")
        таблица.УстановитьЗначение(1, "Имя", "Сотрудник")
        таблица.УстановитьЗначение(1, "Возраст", 35)
        таблица.УстановитьЗначение(1, "Работает", Истина)
        
        Если таблица.КоличествоСтрок() == 4 Тогда
            ДобавитьВЛог("11. Вставлена строка, КоличествоСтрок() = " + таблица.КоличествоСтрок(), "success")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("11. Ошибка вставки строки: " + e, "error")
    КонецПопытки;
    
    // ========== 12. УДАЛЕНИЕ СТРОКИ ==========
    Попытка
        таблица.УдалитьСтроку(0)
        Если таблица.КоличествоСтрок() == 3 Тогда
            ДобавитьВЛог("12. Удалена строка 0, осталось строк: " + таблица.КоличествоСтрок(), "success")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("12. Ошибка удаления строки: " + e, "error")
    КонецПопытки;
    
    // ========== 13. УДАЛЕНИЕ КОЛОНКИ ==========
    Попытка
        таблица.УдалитьКолонкуПоИмени("Отчество")
        Если таблица.КоличествоКолонок() == 4 Тогда
            ДобавитьВЛог("13. Удалена колонка 'Отчество', осталось колонок: " + таблица.КоличествоКолонок(), "success")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("13. Ошибка удаления колонки: " + e, "error")
    КонецПопытки;
    
    // ========== 14. ПРОВЕРКА ПУСТОТЫ ==========
    Попытка
        Если НЕ таблица.Пустой() Тогда
            ДобавитьВЛог("14. Таблица не пуста (есть " + таблица.КоличествоСтрок() + " строк)", "success")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("14. Ошибка: " + e, "error")
    КонецПопытки;
    
    // ========== 15. ОЧИСТКА ТАБЛИЦЫ ==========
    Попытка
        таблица.Очистить()
        Если таблица.КоличествоСтрок() == 0 Тогда
            ДобавитьВЛог("15. Таблица очищена, КоличествоСтрок() = 0", "success")
        КонецЕсли;
        
        Если таблица.Пустой() Тогда
            ДобавитьВЛог("   Пустой() = Истина", "success")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("15. Ошибка очистки: " + e, "error")
    КонецПопытки;
    
    ДобавитьВЛог("========== ТЕСТ ТАБЛИЦЫ ЗНАЧЕНИЙ ЗАВЕРШЁН ==========", "success")
КонецФункции

Функция ТестДереваЗначений()
    ДобавитьВЛог("========== ТЕСТ ДЕРЕВА ЗНАЧЕНИЙ ==========", "info")
    
    Пусть дерево
    
    // ========== 1. СОЗДАНИЕ ДЕРЕВА ==========
    Попытка
        дерево = Новый ДеревоЗначений()
        ДобавитьВЛог("1. ДеревоЗначений создано", "success")
    Исключение
        ДобавитьВЛог("1. Ошибка создания: " + e, "error")
        Возврат
    КонецПопытки;
    
    // ========== 2. ДОБАВЛЕНИЕ КОЛОНОК ==========
    Попытка
        дерево.ДобавитьКолонку("Наименование", "string", 200)
        дерево.ДобавитьКолонку("Количество", "number", 80)
        дерево.ДобавитьКолонку("Цена", "number", 80)
        дерево.ДобавитьКолонку("Сумма", "number", 100)
        ДобавитьВЛог("2. Добавлено 4 колонки", "success")
    Исключение
        ДобавитьВЛог("2. Ошибка добавления колонок: " + e, "error")
    КонецПопытки;
    
    // ========== 3. ПРОВЕРКА КОЛОНОК ==========
    Попытка
        Если дерево.КоличествоКолонок() == 4 Тогда
            ДобавитьВЛог("3. КоличествоКолонок() = " + дерево.КоличествоКолонок(), "success")
        Иначе
            ДобавитьВЛог("3. Ошибка: КоличествоКолонок() = " + дерево.КоличествоКолонок(), "error")
        КонецЕсли;
        
        имена = дерево.ИменаКолонок()
        ДобавитьВЛог("   Имена колонок: " + имена.join(", "), "info")
    Исключение
        ДобавитьВЛог("3. Ошибка: " + e, "error")
    КонецПопытки;
    
    // ========== 4. ДОБАВЛЕНИЕ КОРНЕВЫХ СТРОК ==========
    Попытка
        // Добавляем корневые строки
        дерево.ДобавитьКорень()
        дерево.УстановитьЗначение(0, "Наименование", "Товары")
        
        дерево.ДобавитьКорень()
        дерево.УстановитьЗначение(1, "Наименование", "Услуги")
        
        дерево.ДобавитьКорень()
        дерево.УстановитьЗначение(2, "Наименование", "Работы")
        
        Если дерево.КоличествоСтрок() == 3 Тогда
            ДобавитьВЛог("4. Добавлено 3 корневых строки, КоличествоСтрок() = " + дерево.КоличествоСтрок(), "success")
        Иначе
            ДобавитьВЛог("4. Ошибка: КоличествоСтрок() = " + дерево.КоличествоСтрок(), "error")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("4. Ошибка добавления корневых строк: " + e, "error")
    КонецПопытки;
    
    // ========== 5. ДОБАВЛЕНИЕ ДОЧЕРНИХ СТРОК ==========
    Попытка
        // Для товаров (индекс 0) добавляем дочерние строки
        // Примечание: если метод ДобавитьДочернюю не существует, используем альтернативный подход
        // Сначала проверяем наличие метода
        Если typeof дерево.ДобавитьДочернюю !== "undefined" Тогда
            дерево.ДобавитьДочернюю(0)
            дерево.УстановитьДочернееЗначение(0, 0, "Наименование", "Телефон")
            дерево.УстановитьДочернееЗначение(0, 0, "Количество", 10)
            дерево.УстановитьДочернееЗначение(0, 0, "Цена", 15000)
            дерево.УстановитьДочернееЗначение(0, 0, "Сумма", 150000)
            
            дерево.ДобавитьДочернюю(0)
            дерево.УстановитьДочернееЗначение(0, 1, "Наименование", "Ноутбук")
            дерево.УстановитьДочернееЗначение(0, 1, "Количество", 5)
            дерево.УстановитьДочернееЗначение(0, 1, "Цена", 50000)
            дерево.УстановитьДочернееЗначение(0, 1, "Сумма", 250000)
            
            ДобавитьВЛог("5. Добавлены дочерние строки через ДобавитьДочернюю()", "success")
        Иначе
            ДобавитьВЛог("5. Метод ДобавитьДочернюю() не найден - пропускаем", "warning")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("5. Ошибка добавления дочерних строк: " + e, "error")
    КонецПопытки;
    
    // ========== 6. ВЫВОД ВСЕХ ДАННЫХ ==========
    Попытка
        ДобавитьВЛог("6. Содержимое дерева:", "info")
        
        Для i = 0 По дерево.КоличествоСтрок() - 1 Цикл
            наим = дерево.ПолучитьЗначение(i, "Наименование")
            кол = дерево.ПолучитьЗначение(i, "Количество")
            цена = дерево.ПолучитьЗначение(i, "Цена")
            сумма = дерево.ПолучитьЗначение(i, "Сумма")
            ДобавитьВЛог("   [" + i + "] " + наим + 
                         (кол !== undefined ? " кол=" + кол : "") +
                         (цена !== undefined ? " цена=" + цена : "") +
                         (сумма !== undefined ? " сумма=" + сумма : ""), "info")
        КонецЦикла;
    Исключение
        ДобавитьВЛог("6. Ошибка вывода: " + e, "error")
    КонецПопытки;
    
    // ========== 7. ПОИСК СТРОКИ (если есть метод findRow) ==========
    Попытка
        Если typeof дерево.НайтиСтроку !== "undefined" Тогда
            индекс = дерево.НайтиСтроку("Наименование", "Товары")
            Если индекс >= 0 Тогда
                ДобавитьВЛог("7. НайтиСтроку('Наименование', 'Товары') = " + индекс, "success")
            Иначе
                ДобавитьВЛог("7. Элемент 'Товары' найден, индекс = " + индекс, "info")
            КонецЕсли;
        Иначе
            ДобавитьВЛог("7. Метод НайтиСтроку() не найден", "warning")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("7. Ошибка поиска: " + e, "error")
    КонецПопытки;
    
    // ========== 8. ПРОВЕРКА ПУСТОТЫ ==========
    Попытка
        Если НЕ дерево.Пустой() Тогда
            ДобавитьВЛог("8. Дерево не пусто (есть " + дерево.КоличествоСтрок() + " корневых строк)", "success")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("8. Ошибка: " + e, "error")
    КонецПопытки;
    
    // ========== 9. ОЧИСТКА ДЕРЕВА ==========
    Попытка
        дерево.Очистить()
        Если дерево.КоличествоСтрок() == 0 Тогда
            ДобавитьВЛог("9. Дерево очищено, КоличествоСтрок() = 0", "success")
        КонецЕсли;
        
        Если дерево.Пустой() Тогда
            ДобавитьВЛог("   Пустой() = Истина", "success")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("9. Ошибка очистки: " + e, "error")
    КонецПопытки;
    
    ДобавитьВЛог("========== ТЕСТ ДЕРЕВА ЗНАЧЕНИЙ ЗАВЕРШЁН ==========", "success")
КонецФункции

Функция ЗапуститьВсеТесты()
    ДобавитьВЛог("================ НАЧАЛО ВСЕХ ТЕСТОВ ================", "info")
    ТестСтроковыхФункций()
    ТестЧисловыхФункций()
    ТестСтруктур()
    ТестСоответствия()
    ТестСпискаЗначений()
    ТестРегулярныхВыражений()
    ТестТаблицыЗначений()
    ТестДереваЗначений()
    ДобавитьВЛог("================ ВСЕ ТЕСТЫ ЗАВЕРШЕНЫ ================", "success")
    ПоказатьСообщение("Все тесты успешно завершены!\nРезультаты в журнале.")
КонецФункции

