Функция ПроверитьСтатус()
    ДобавитьВЛог("🔍 ПРОВЕРКА СТАТУСА СЕРВЕРОВ", "progress")
    
    Попытка
        Пусть ping = ВызватьФункциюСервера("Ping", [])
        Если ping == "OK" Тогда
            ДобавитьВЛог("✅ Веб-сервер доступен", "success")
            Глоб_СерверЗапущен = ИСТИНА
            
            // Получаем активные задания
            Попытка
                Пусть response = ВызватьФункциюСервера("GetActiveJobs", [])
                Пусть jobs = JSON_ИзСтроки(response)
                Пусть колВоЗаданий = jobs.jobs ? jobs.jobs.длина : 0
                ДобавитьВЛог("📋 Активных заданий: " + колВоЗаданий, "info")
            Исключение
                // Игнорируем
            КонецПопытки;
            
            УстановитьТекст("lblStatusResult", "✅ СТАТУС: СЕРВЕРЫ РАБОТАЮТ НОРМАЛЬНО")
            УстановитьСтиль("lblStatusResult", "color: #2ecc71; font-weight: bold;")
            
            // Обновляем доступность кнопок отчётов
            УстановитьДоступность("btnReport1", ИСТИНА)
            УстановитьДоступность("btnReport2", ИСТИНА)
            УстановитьДоступность("btnReport3", ИСТИНА)
            УстановитьДоступность("btnMacroReport", ИСТИНА)
        Иначе
            ДобавитьВЛог("❌ Веб-сервер не отвечает", "error")
            Глоб_СерверЗапущен = ЛОЖЬ
            УстановитьТекст("lblStatusResult", "❌ СТАТУС: СЕРВЕРЫ НЕ ДОСТУПНЫ")
            УстановитьСтиль("lblStatusResult", "color: #ff6b6b; font-weight: bold;")
            
            УстановитьДоступность("btnReport1", ЛОЖЬ)
            УстановитьДоступность("btnReport2", ЛОЖЬ)
            УстановитьДоступность("btnReport3", ЛОЖЬ)
            УстановитьДоступность("btnMacroReport", ЛОЖЬ)
        КонецЕсли;
    Исключение
        ДобавитьВЛог("❌ Ошибка подключения: " + e, "error")
        Глоб_СерверЗапущен = ЛОЖЬ
        УстановитьТекст("lblStatusResult", "❌ СТАТУС: ОШИБКА ПОДКЛЮЧЕНИЯ")
        УстановитьСтиль("lblStatusResult", "color: #ff6b6b; font-weight: bold;")
    КонецПопытки;
КонецФункции

