        ПриНажатииКнопки("btnRegexTests", Функция() {      ОчиститьЛог();    ТестРегулярныхВыражений();  })    
    ДобавитьНаВкладку("ГлавнаяВкладка", 0, "Кнопка", "btnValueTableTests", { "Лево": 10, "Верх": 250, "Ширина": 260, "Высота": 30, "Заголовок": "📋 ТЕСТ ТАБЛИЦЫ ЗНАЧЕНИЙ" })
        ПриНажатииКнопки("btnValueTableTests", Функция() {  ОчиститьЛог();    ТестТаблицыЗначений() })    
