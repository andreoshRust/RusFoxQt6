Функция СоздатьОкноLibraOffice()
    Пусть имяОкна = "ОкноLibraOffice"

    СоздатьПодокноMDI(Глоб_mdi, имяОкна, 10, 10, 1100, 750)
    
    // Создаём вкладки с тремя страницами
    СоздатьВкладки("ВкладкиУправление", { "Лево": 10, "Верх": 10, "Ширина": 1080, "Высота": 690, "Вкладки": "Статус подключения,Отчёты,Тестирование WebSocket" }, имяОкна)
    
    // ==================== СТРАНИЦА 0: СТАТУС ПОДКЛЮЧЕНИЯ ====================
    ДобавитьНаВкладку("ВкладкиУправление", 0, "Группа", "statusGroup", { "Лево": 20, "Верх": 20, "Ширина": 600, "Высота": 200, "Заголовок": "СТАТУС ПОДКЛЮЧЕНИЯ" })
    
    ДобавитьОбъектНаСтранице(0, "Надпись", "lblServerStatus", { "Лево": 20, "Верх": 35, "Ширина": 300, "Высота": 30, "Заголовок": "СЕРВЕРЫ НЕ ПРОВЕРЕНЫ",
        "Стиль": "color: #ffaa00; font-weight: bold; font-size: 14px;", "Родитель": "statusGroup" }) 
    ДобавитьОбъектНаСтранице(0, "Прогресс", "progressInit", { "Лево": 20, "Верх": 80, "Ширина": 560, "Высота": 25, "Минимум": 0, "Максимум": 100, "Значение": 0 }, 
                                                                          "statusGroup")
    ДобавитьОбъектНаСтранице(0, "Надпись", "lblInitStatus", { "Лево": 20, "Верх": 115, "Ширина": 560, "Высота": 30, "Заголовок": "Нажмите 'ПРОВЕРИТЬ СТАТУС'" }, 
                                                                          "statusGroup")
    ДобавитьОбъектНаСтранице(0, "Кнопка", "btnCheckStatus", { "Лево": 20, "Верх": 155, "Ширина": 560, "Высота": 35, "Заголовок": "ПРОВЕРИТЬ СТАТУС СЕРВЕРОВ" }, 
                                                                          "statusGroup")
        ПриНажатииКнопки("btnCheckStatus", Функция() { ОчиститьЛог();   ПроверитьСтатус();  })
    
    ДобавитьНаВкладку("ВкладкиУправление", 0, "Группа", "infoGroup", { "Лево": 640, "Верх": 20, "Ширина": 420, "Высота": 200, "Заголовок": "ИНФОРМАЦИЯ" })
    
    ДобавитьОбъектНаСтранице(0, "Надпись", "lblInfo", { "Лево": 20, "Верх": 35, "Ширина": 380, "Высота": 150,
        "Заголовок": "Серверы запускаются отдельно (через bat-файл)\n\n" +
        "Для создания отчётов необходимо:\n" +
        "1. Запустить веб-сервер Python\n" +
        "2. Запустить LO сервер\n" +
        "3. Нажать 'ПРОВЕРИТЬ СТАТУС'\n\n" +
        "После подтверждения статуса перейдите\n" +
        "на вкладку 'Отчёты'"
    }, "infoGroup")
    
    ДобавитьНаВкладку("ВкладкиУправление", 0, "Группа", "resultGroup", { "Лево": 20, "Верх": 235, "Ширина": 1040, "Высота": 80, "Заголовок": "РЕЗУЛЬТАТ ПРОВЕРКИ" })
    
    ДобавитьОбъектНаСтранице(0, "Надпись", "lblStatusResult", { "Лево": 20, "Верх": 30, "Ширина": 1000, "Высота": 35, "Заголовок": "Нажмите 'ПРОВЕРИТЬ СТАТУС' для проверки",
        "Стиль": "font-size: 14px;" }, "resultGroup")
    
    ДобавитьНаВкладку("ВкладкиУправление", 0, "Группа", "logGroup", { "Лево": 20, "Верх": 330, "Ширина": 1040, "Высота": 300, "Заголовок": "ЖУРНАЛ СОБЫТИЙ" })
    
    ДобавитьОбъектНаСтранице(0, "ТекстоваяОбласть", "txtLog", { "Лево": 10, "Верх": 25, "Ширина": 1020, "Высота": 270, "Значение": "=== ЖУРНАЛ СОБЫТИЙ ===\n\n" }, "logGroup", 0)
    ДобавитьОбъектНаСтранице(0, "Кнопка", "btnClearLog", { "Лево": 900, "Верх": 300, "Ширина": 120, "Высота": 25, "Заголовок": "ОЧИСТИТЬ ЖУРНАЛ" }, "logGroup", 0)
        ПриНажатииКнопки("btnClearLog", Функция() { ОчиститьЛог()  })
    
    // ==================== СТРАНИЦА 1: ОТЧЁТЫ ====================
    
    ДобавитьНаВкладку("ВкладкиУправление", 1, "Группа", "reportGroup", { "Лево": 20, "Верх": 20, "Ширина": 1040, "Высота": 260, "Заголовок": "ДОСТУПНЫЕ ОТЧЁТЫ" })
    
    ДобавитьОбъектНаСтранице(1, "Надпись", "lblReportInfo", { "Лево": 20, "Верх": 35, "Ширина": 1000, "Высота": 35,
        "Заголовок": "Для создания отчётов серверы должны быть запущены (проверьте статус на вкладке 'Статус подключения')", "Стиль": "color: #ffaa00;"  }, "reportGroup", 0)
    ДобавитьОбъектНаСтранице(1, "Кнопка", "btnReport1", { "Лево": 30, "Верх": 90, "Ширина": 310, "Высота": 45, "Заголовок": "ОТЧЁТ ПО СОТРУДНИКАМ" }, "reportGroup", 0)
        ПриНажатииКнопки("btnReport1", Функция() {    СоздатьОтчётПоСотрудникам()   })
    ДобавитьОбъектНаСтранице(1, "Кнопка", "btnReport2", { "Лево": 360, "Верх": 90, "Ширина": 310, "Высота": 45, "Заголовок": "ФИНАНСОВЫЙ ОТЧЁТ" }, "reportGroup", 0)
        ПриНажатииКнопки("btnReport2", Функция() {   СоздатьФинансовыйОтчёт()   })
    ДобавитьОбъектНаСтранице(1, "Кнопка", "btnReport3", { "Лево": 690, "Верх": 90, "Ширина": 310, "Высота": 45, "Заголовок": "ОТЧЁТ ПО ПРОДАЖАМ" }, "reportGroup", 0)
        ПриНажатииКнопки("btnReport3", Функция() {     СоздатьОтчётПоПродажам()   })    
    ДобавитьОбъектНаСтранице(1, "Кнопка", "btnMacroReport", { "Лево": 30, "Верх": 155, "Ширина": 970, "Высота": 45,
          "Заголовок": "СЛОЖНЫЙ ОТЧЁТ (макрос с формулами и форматированием)" }, "reportGroup", 0)
        ПриНажатииКнопки("btnMacroReport", Функция() {   СоздатьОтчётМакрос()    })          
    
    // Группа результатов отчётов
    ДобавитьНаВкладку("ВкладкиУправление", 1, "Группа", "reportResultGroup", { "Лево": 20, "Верх": 295, "Ширина": 1040, "Высота": 370, "Заголовок": "РЕЗУЛЬТАТЫ ОТЧЁТОВ" })
    
    ДобавитьОбъектНаСтранице(1, "ТекстоваяОбласть", "txtLogReports", { "Лево": 10, "Верх": 25, "Ширина": 1020, "Высота": 305, "Значение": "=== РЕЗУЛЬТАТЫ ОТЧЁТОВ ===\n\n"
                        }, "reportResultGroup", 0)
    
    // ==================== СТРАНИЦА 2: ТЕСТИРОВАНИЕ ====================
    
    ДобавитьНаВкладку("ВкладкиУправление", 2, "Группа", "testGroup", { "Лево": 20, "Верх": 20, "Ширина": 500, "Высота": 200, "Заголовок": "ТЕСТИРОВАНИЕ ВЕБ-СЕРВЕРА" })
    
    ДобавитьОбъектНаСтранице(2, "Кнопка", "btnTestFunctions", { "Лево": 20, "Верх": 40, "Ширина": 460, "Высота": 40, "Заголовок": "ТЕСТИРОВАТЬ ВСЕ ФУНКЦИИ" }, "testGroup", 0)
        ПриНажатииКнопки("btnTestFunctions", Функция() {     ТестироватьВебСервер()     })
    ДобавитьОбъектНаСтранице(2, "Кнопка", "btnTestGet", { "Лево": 20, "Верх": 95, "Ширина": 460, "Высота": 40, "Заголовок": "ПРОВЕРИТЬ GET ЗАПРОСЫ (/ping, /status)" }, "testGroup", 0)
        ПриНажатииКнопки("btnTestGet", Функция() {        ПроверитьПрямыеGET()     })
    ДобавитьОбъектНаСтранице(2, "Кнопка", "btnTestJob", { "Лево": 20, "Верх": 150, "Ширина": 460, "Высота": 40, "Заголовок": "ТЕСТ СОЗДАНИЯ ЗАДАНИЯ (CreateJob)" }, "testGroup", 0)
        ПриНажатииКнопки("btnTestJob", Функция() {     ТестСозданияЗадания()     })
    
    ДобавитьНаВкладку("ВкладкиУправление", 2, "Группа", "testResultGroup", { "Лево": 540, "Верх": 20, "Ширина": 520, "Высота": 200, "Заголовок": "РЕЗУЛЬТАТ ТЕСТИРОВАНИЯ" })
    
    ДобавитьОбъектНаСтранице(2, "Надпись", "lblTestResult", { "Лево": 20, "Верх": 35, "Ширина": 480, "Высота": 150, "Заголовок": "Нажмите кнопку для выполнения тестов",
        "Стиль": "font-size: 12px;" }, "testResultGroup", 0)
    
    ДобавитьНаВкладку("ВкладкиУправление", 2, "Группа", "testLogGroup", { "Лево": 20, "Верх": 235, "Ширина": 1040, "Высота": 430, "Заголовок": "ЖУРНАЛ ТЕСТИРОВАНИЯ" })
    
    ДобавитьОбъектНаСтранице(2, "ТекстоваяОбласть", "txtTestLog", { "Лево": 10, "Верх": 25, "Ширина": 1020, "Высота": 360, "Значение": "=== ТЕСТИРОВАНИЕ ВЕБ-СЕРВЕРА ===\n\n"
            }, "testLogGroup", 0)
    ДобавитьОбъектНаСтранице(2, "Кнопка", "btnClearTestLog", { "Лево": 900, "Верх": 395, "Ширина": 120, "Высота": 25, "Заголовок": "ОЧИСТИТЬ ЖУРНАЛ" }, "testLogGroup", 0)
        ПриНажатииКнопки("btnClearTestLog", Функция() {  ОчиститьТестЛог()     })
    
    ДобавитьВЛог("Окно управления серверами и отчётами создано", "success")
    ДобавитьВЛог("Для работы отчётов необходимо запустить серверы через bat-файл", "info")
    ДобавитьВЛог("Нажмите 'ПРОВЕРИТЬ СТАТУС' для проверки доступности серверов", "info")
    
    Возврат имяОкна
КонецФункции

//#КонецОбласти

//#Область Тест ОкноТестQtФайл

Функция ТестФайлы() 
    ДобавитьВЛог("📄 ТЕСТ 1: РАБОТА С ФАЙЛАМИ (КЛАСС ФАЙЛ)", "progress")
    
    // ========== ОБЪЯВЛЯЕМ ВСЕ ПЕРЕМЕННЫЕ В НАЧАЛЕ ==========
    Пусть ТестФайл = ""
    Пусть файл1 = null
    Пусть файл2 = null
    Пусть файл3 = null
    Пусть файл4 = null
    Пусть файл5 = null
    Пусть содержимое = ""
    Пусть номерСтроки = 0
    Пусть строка = ""
    Пусть КопияФайла = ""
    Пусть ПереименованныйФайл = ""
    
    // ========== 1. ПОДГОТОВКА ТЕСТОВОГО ФАЙЛА ==========
    Попытка
        ТестФайл = ТекущийПуть() + "/test_smartgrid_" + СгенерироватьUUID() + ".txt"
        ДобавитьВЛог("Файл для теста: " + ТестФайл, "info")
    Исключение
        ДобавитьВЛог("❌ Ошибка подготовки тестового файла: " + e, "error")
        Возврат 
    КонецПопытки;
    
    // ========== 2. СОЗДАНИЕ ФАЙЛА ==========
    Попытка 
        файл1 = Новый Файл(ТестФайл)
        ДобавитьВЛог("  Объект Файл создан", "info")
    Исключение
        ДобавитьВЛог("❌ Ошибка создания объекта Файл: " + e, "error")
        Возврат 
    КонецПопытки;
    
    // 2.1 Открытие файла
    Попытка 
        файл1.Открыть(2 | 16)  // 2 = WriteOnly, 16 = Text
        ДобавитьВЛог("  Файл открыт для записи", "info")
    Исключение
        ДобавитьВЛог("❌ Ошибка открытия файла для записи: " + e, "error")
        Возврат 
    КонецПопытки;
    
    // 2.2 Запись строки 1
    Попытка 
        файл1.ЗаписатьСтроку("Строка 1 - тест записи")
        ДобавитьВЛог("  Записана строка 1", "info")
    Исключение
        ДобавитьВЛог("❌ Ошибка записи строки 1: " + e, "error")
    КонецПопытки;
    
    // 2.3 Запись строки 2
    Попытка 
        файл1.ЗаписатьСтроку("Строка 2 - тест записи")
        ДобавитьВЛог("  Записана строка 2", "info")
    Исключение
        ДобавитьВЛог("❌ Ошибка записи строки 2: " + e, "error")
    КонецПопытки;
    
    // 2.4 Запись строки 3 (без перевода строки)
    Попытка 
        файл1.Записать("Строка 3 - без перевода строки")
        ДобавитьВЛог("  Записана строка 3 (без перевода)", "info")
    Исключение
        ДобавитьВЛог("❌ Ошибка записи строки 3: " + e, "error")
    КонецПопытки;
    
    // 2.5 Запись пустой строки
    Попытка 
        файл1.ЗаписатьСтроку("")
        ДобавитьВЛог("  Записана пустая строка", "info")
    Исключение
        ДобавитьВЛог("❌ Ошибка записи пустой строки: " + e, "error")
    КонецПопытки;
    
    // 2.6 Запись последней строки
    Попытка 
        файл1.ЗаписатьСтроку("Строка 4 - последняя")
        ДобавитьВЛог("  Записана строка 4", "info")
    Исключение
        ДобавитьВЛог("❌ Ошибка записи строки 4: " + e, "error")
    КонецПопытки;
    
    // 2.7 Закрытие файла
    Попытка 
        файл1.Закрыть()
        ДобавитьВЛог("✅ Файл закрыт", "success")
    Исключение
        ДобавитьВЛог("❌ Ошибка закрытия файла: " + e, "error")
    КонецПопытки;
    
    // ========== 3. ПРОВЕРКА СУЩЕСТВОВАНИЯ ==========
    Попытка
        Если ФайлСуществует(ТестФайл) Тогда 
            ДобавитьВЛог("✅ Файл существует", "success")
        Иначе
            ДобавитьВЛог("❌ Файл не найден", "error")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("❌ Ошибка проверки существования файла: " + e, "error")
    КонецПопытки;
    
    // ========== 4. ЧТЕНИЕ ФАЙЛА ==========
    Попытка
        файл2 = Новый Файл(ТестФайл)
    Исключение
        ДобавитьВЛог("❌ Ошибка создания объекта для чтения: " + e, "error")
        Возврат 
    КонецПопытки;
    
    Попытка
        файл2.Открыть(1 | 16)  // 1 = ReadOnly, 16 = Text
        ДобавитьВЛог("  Файл открыт для чтения", "info")
    Исключение
        ДобавитьВЛог("❌ Ошибка открытия файла для чтения: " + e, "error")
    КонецПопытки;
    
    Попытка
        содержимое = файл2.ПрочитатьВсе()
        ДобавитьВЛог("✅ Содержимое файла прочитано", "info")
        ДобавитьВЛог("---\n" + содержимое + "\n---", "info")
    Исключение
        ДобавитьВЛог("❌ Ошибка чтения файла: " + e, "error")
    КонецПопытки;
    
    Попытка
        ДобавитьВЛог("Размер файла: " + файл2.Размер() + " байт", "info")
    Исключение
        ДобавитьВЛог("❌ Ошибка получения размера файла: " + e, "error")
    КонецПопытки;
    
    Попытка
        файл2.Закрыть()
        ДобавитьВЛог("  Файл закрыт", "info")
    Исключение
        ДобавитьВЛог("❌ Ошибка закрытия файла после чтения: " + e, "error")
    КонецПопытки;
    
    // ========== 5. ПОСТРОЧНОЕ ЧТЕНИЕ ==========
    Попытка
        файл3 = Новый Файл(ТестФайл)
        файл3.Открыть(1 | 16)  // 1 = ReadOnly, 16 = Text
        ДобавитьВЛог("📖 Чтение файла построчно:", "info")
        
        номерСтроки = 1
        Пока НЕ файл3.КонецФайла() Цикл
            Попытка
                строка = файл3.ПрочитатьСтроку()
                Если НЕ ПустаяСтрока(строка) Тогда
                    ДобавитьВЛог("  Строка " + номерСтроки + ": " + строка, "info")
                КонецЕсли;
            Исключение
                ДобавитьВЛог("  Ошибка чтения строки " + номерСтроки + ": " + e, "error")
            КонецПопытки;
            номерСтроки = номерСтроки + 1
        КонецЦикла;
        
        файл3.Закрыть()
    Исключение
        ДобавитьВЛог("❌ Ошибка построчного чтения: " + e, "error")
    КонецПопытки;
    
    // ========== 6. КОПИРОВАНИЕ ФАЙЛА ==========
    Попытка
        КопияФайла = ТестФайл + ".copy"
        файл4 = Новый Файл(ТестФайл)
        файл4.Копировать(КопияФайла)
        ДобавитьВЛог("✅ Файл скопирован в: " + КопияФайла, "success")
    Исключение
        ДобавитьВЛог("❌ Ошибка копирования файла: " + e, "error")
    КонецПопытки;
    
    Попытка
        Если ФайлСуществует(КопияФайла) Тогда
            ДобавитьВЛог("✅ Копия существует", "success")
        Иначе
            ДобавитьВЛог("❌ Копия не найдена", "error")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("❌ Ошибка проверки копии: " + e, "error")
    КонецПопытки;
    
    // ========== 7. ПЕРЕИМЕНОВАНИЕ ФАЙЛА ==========
    Попытка
        ПереименованныйФайл = КопияФайла + ".renamed"
        файл5 = Новый Файл(КопияФайла)
        файл5.Переименовать(ПереименованныйФайл)
        ДобавитьВЛог("✅ Файл переименован в: " + ПереименованныйФайл, "success")
    Исключение
        ДобавитьВЛог("❌ Ошибка переименования: " + e, "error")
    КонецПопытки;
    
    // ========== 8. УДАЛЕНИЕ ФАЙЛОВ ==========
    Попытка
        УдалитьФайл(ТестФайл)
        ДобавитьВЛог("  Оригинальный файл удалён", "info")
    Исключение
        ДобавитьВЛог("❌ Ошибка удаления оригинального файла: " + e, "error")
    КонецПопытки;
    
    Попытка
        УдалитьФайл(ПереименованныйФайл)
        ДобавитьВЛог("  Переименованный файл удалён", "info")
    Исключение
        ДобавитьВЛог("❌ Ошибка удаления переименованного файла: " + e, "error")
    КонецПопытки;
    
    ДобавитьВЛог("========== ТЕСТ ФАЙЛОВ ЗАВЕРШЁН ==========", "success")
КонецФункции

Функция ТестКаталоги() 
    ДобавитьВЛог("📁 ТЕСТ 2: РАБОТА С КАТАЛОГАМИ (КЛАСС КАТАЛОГ)", "progress")
    
    // ========== ОБЪЯВЛЯЕМ ВСЕ ПЕРЕМЕННЫЕ ==========
    Пусть ТестКаталога = ""
    Пусть каталог1 = null
    Пусть каталог2 = null
    Пусть каталог3 = null
    Пусть каталог4 = null
    Пусть файл1 = null
    Пусть файл2 = null
    Пусть файл3 = null
    Пусть всеЭлементы = []
    Пусть i = 0
    Пусть подкаталог = null
    Пусть элементыПодкаталога = []
    
    // ========== 1. ПОДГОТОВКА ==========
    Попытка
        ТестКаталога = ТекущийПуть() + "/SmartGridTest_" + СгенерироватьUUID()
        ДобавитьВЛог("Каталог для теста: " + ТестКаталога, "info")
    Исключение
        ДобавитьВЛог("❌ Ошибка подготовки каталога: " + e, "error")
        Возврат 
    КонецПопытки;
    
    // ========== 2. СОЗДАНИЕ СТРУКТУРЫ КАТАЛОГОВ ==========
    Попытка 
        каталог1 = Новый Каталог(ТестКаталога)
        каталог1.СоздатьПуть(ТестКаталога + "/subfolder1/subfolder2")
        ДобавитьВЛог("✅ Создана структура каталогов", "success")
        
        ДобавитьВЛог("  Абсолютный путь: " + каталог1.АбсолютныйПуть(), "info")
        ДобавитьВЛог("  Имя каталога: " + каталог1.ИмяКаталога(), "info")
    Исключение 
        ДобавитьВЛог("❌ Ошибка создания каталогов: " + e, "error")
        Возврат 
    КонецПопытки;
    
    // ========== 3. СОЗДАНИЕ ФАЙЛОВ В КАТАЛОГЕ ==========
    // 3.1 Файл 1
    Попытка
        файл1 = Новый Файл(ТестКаталога + "/file1.txt")
        файл1.Открыть(2 | 16)  // 2 = WriteOnly, 16 = Text
        файл1.ЗаписатьСтроку("Тестовый файл 1 в каталоге")
        файл1.Закрыть()
        ДобавитьВЛог("  Создан файл: file1.txt", "info")
    Исключение
        ДобавитьВЛог("❌ Ошибка создания file1.txt: " + e, "error")
    КонецПопытки;
    
    // 3.2 Файл 2
    Попытка
        файл2 = Новый Файл(ТестКаталога + "/file2.log")
        файл2.Открыть(2 | 16)
        файл2.ЗаписатьСтроку("Лог-файл: тестовая запись")
        файл2.Закрыть()
        ДобавитьВЛог("  Создан файл: file2.log", "info")
    Исключение
        ДобавитьВЛог("❌ Ошибка создания file2.log: " + e, "error")
    КонецПопытки;
    
    // 3.3 Файл 3 (во вложенном каталоге)
    Попытка
        файл3 = Новый Файл(ТестКаталога + "/subfolder1/config.ini")
        файл3.Открыть(2 | 16)
        файл3.ЗаписатьСтроку("parameter=value")
        файл3.Закрыть()
        ДобавитьВЛог("  Создан файл: subfolder1/config.ini", "info")
    Исключение
        ДобавитьВЛог("❌ Ошибка создания config.ini: " + e, "error")
    КонецПопытки;
    
    ДобавитьВЛог("✅ Созданы тестовые файлы", "success")
    
    // ========== 4. ПОЛУЧЕНИЕ СПИСКА ФАЙЛОВ ==========
    Попытка
        каталог2 = Новый Каталог(ТестКаталога)
        
        // Все элементы
        всеЭлементы = каталог2.СписокФайлов()
        ДобавитьВЛог("📋 Содержимое каталога (" + всеЭлементы.length + " элементов):", "info")
        Для i = 0 По всеЭлементы.length - 1 Цикл
            Если всеЭлементы[i] != "." И всеЭлементы[i] != ".." Тогда
                ДобавитьВЛог("  " + всеЭлементы[i], "info")
            КонецЕсли;
        КонецЦикла;
    Исключение
        ДобавитьВЛог("❌ Ошибка получения списка: " + e, "error")
    КонецПопытки;
    
    // ========== 5. НАВИГАЦИЯ ПО КАТАЛОГАМ ==========
    Попытка
        каталог3 = Новый Каталог(ТестКаталога)
        ДобавитьВЛог("🧭 Навигация по каталогам:", "info")
        ДобавитьВЛог("  Текущий путь: " + каталог3.Путь(), "info")
        
        каталог3.ПерейтиВКаталог("subfolder1")
        ДобавитьВЛог("  После cd subfolder1: " + каталог3.Путь(), "info")
        
        каталог3.ПерейтиВверх()
        ДобавитьВЛог("  После cd Up: " + каталог3.Путь(), "info")
        
        ДобавитьВЛог("✅ Навигация успешна", "success")
    Исключение
        ДобавитьВЛог("❌ Ошибка навигации: " + e, "error")
    КонецПопытки;
    
    // ========== 6. ПРОСМОТР ПОДКАТАЛОГА ==========
    Попытка
        подкаталог = Новый Каталог(ТестКаталога + "/subfolder1")
        элементыПодкаталога = подкаталог.СписокФайлов()
        ДобавитьВЛог("📂 Содержимое подкаталога subfolder1:", "info")
        
        Для i = 0 По элементыПодкаталога.length - 1 Цикл
            Если элементыПодкаталога[i] != "." И элементыПодкаталога[i] != ".." Тогда
                ДобавитьВЛог("  " + элементыПодкаталога[i], "info")
            КонецЕсли;
        КонецЦикла;
    Исключение
        ДобавитьВЛог("❌ Ошибка просмотра подкаталога: " + e, "error")
    КонецПопытки;
    
    // ========== 7. УДАЛЕНИЕ ТЕСТОВОЙ СТРУКТУРЫ ==========
    Попытка
        каталог4 = Новый Каталог(ТестКаталога)
        каталог4.УдалитьРекурсивно()
        ДобавитьВЛог("✅ Тестовая структура удалена", "success")
    Исключение
        ДобавитьВЛог("❌ Ошибка удаления: " + e, "error")
    КонецПопытки;
    
    ДобавитьВЛог("========== ТЕСТ КАТАЛОГОВ ЗАВЕРШЁН ==========", "success")
КонецФункции

// ============================================================================
// ТЕСТ 3: ИНФОРМАЦИЯ О ФАЙЛАХ (КЛАСС ИНФОРМАЦИЯОФАЙЛЕ)
// ============================================================================
Функция ТестИнформацияОФайле() 
    ДобавитьВЛог("ℹ️ ТЕСТ 3: ИНФОРМАЦИЯ О ФАЙЛАХ (КЛАСС ИНФОРМАЦИЯОФАЙЛЕ)", "progress")
    
    // ========== ОБЪЯВЛЯЕМ ПЕРЕМЕННЫЕ ==========
    Пусть ТестФайл = ""
    Пусть файл = null
    Пусть инфо = null
    
    // ========== 1. СОЗДАНИЕ ТЕСТОВОГО ФАЙЛА ==========
    Попытка
        ТестФайл = ТекущийПуть() + "/test_info_" + СгенерироватьUUID() + ".txt"
        файл = Новый Файл(ТестФайл)
        файл.Открыть(2 | 16)  // 2 = WriteOnly, 16 = Text
        файл.ЗаписатьСтроку("Тестовый файл для получения информации")
        файл.Закрыть()
        ДобавитьВЛог("✅ Создан тестовый файл: " + ТестФайл, "success")
    Исключение
        ДобавитьВЛог("❌ Ошибка создания тестового файла: " + e, "error")
        Возврат 
    КонецПопытки;
    
    // ========== 2. ПОЛУЧЕНИЕ ИНФОРМАЦИИ О ФАЙЛЕ ==========
    Попытка
        инфо = Новый ИнформацияОФайле(ТестФайл)
        
        ДобавитьВЛог("📊 БАЗОВАЯ ИНФОРМАЦИЯ:", "info")
        ДобавитьВЛог("  Имя файла: " + инфо.ИмяФайла(), "info")
        ДобавитьВЛог("  Базовое имя: " + инфо.БазовоеИмя(), "info")
        ДобавитьВЛог("  Расширение: " + инфо.Расширение(), "info")
        ДобавитьВЛог("  Полный путь: " + инфо.ПолныйПуть(), "info")
        ДобавитьВЛог("  Абсолютный путь: " + инфо.АбсолютныйПуть(), "info")
        ДобавитьВЛог("  Родительский каталог: " + инфо.РодительскийКаталог(), "info")
        
        ДобавитьВЛог("📊 АТРИБУТЫ:", "info")
        ДобавитьВЛог("  Размер: " + инфо.Размер() + " байт", "info")
        ДобавитьВЛог("  Существует: " + (инфо.Существует() ? "Да" : "Нет"), "info")
        ДобавитьВЛог("  Является файлом: " + (инфо.ЯвляетсяФайлом() ? "Да" : "Нет"), "info")
        ДобавитьВЛог("  Является каталогом: " + (инфо.ЯвляетсяКаталогом() ? "Да" : "Нет"), "info")
        ДобавитьВЛог("  Скрытый: " + (инфо.Скрытый() ? "Да" : "Нет"), "info")
        ДобавитьВЛог("  Доступен для чтения: " + (инфо.ДоступенДляЧтения() ? "Да" : "Нет"), "info")
        ДобавитьВЛог("  Доступен для записи: " + (инфо.ДоступенДляЗаписи() ? "Да" : "Нет"), "info")
        
        ДобавитьВЛог("📊 ДАТЫ:", "info")
        ДобавитьВЛог("  Дата создания: " + инфо.ДатаСоздания().toString("dd.MM.yyyy HH:mm:ss"), "info")
        ДобавитьВЛог("  Дата изменения: " + инфо.ДатаПоследнегоИзменения().toString("dd.MM.yyyy HH:mm:ss"), "info")
        ДобавитьВЛог("  Дата последнего чтения: " + инфо.ДатаПоследнегоЧтения().toString("dd.MM.yyyy HH:mm:ss"), "info")
        
        ДобавитьВЛог("✅ Информация о файле получена", "success")
    Исключение
        ДобавитьВЛог("❌ Ошибка получения информации: " + e, "error")
    КонецПопытки;
    
    // ========== 3. УДАЛЕНИЕ ТЕСТОВОГО ФАЙЛА ==========
    Попытка
        УдалитьФайл(ТестФайл)
        ДобавитьВЛог("✅ Тестовый файл удалён", "success")
    Исключение
        ДобавитьВЛог("❌ Ошибка удаления файла: " + e, "error")
    КонецПопытки;
    
    ДобавитьВЛог("========== ТЕСТ ИНФОРМАЦИИ О ФАЙЛЕ ЗАВЕРШЁН ==========", "success")
КонецФункции

// ============================================================================
// ЗАПУСК ВСЕХ ТЕСТОВ
// ============================================================================
Функция ЗапуститьВсеТестыQtФайл() 
    ДобавитьВЛог("🚀 ЗАПУСК ВСЕХ ТЕСТОВ РУССКИХ КЛАССОВ", "progress")
    ДобавитьВЛог("=========================================", "info")
    
    ТестФайлы()
    Пауза(500)
    ТестКаталоги()
    Пауза(500)
    ТестИнформацияОФайле()
    Пауза(500)
    
    ДобавитьВЛог("=========================================", "info")
    ДобавитьВЛог("✅ ВСЕ ТЕСТЫ УСПЕШНО ЗАВЕРШЕНЫ!", "success")
    ПоказатьСообщение("✅ Все тесты русских классов успешно завершены!\n\n" +
        "Протестированы:\n" +
        "• Файл - работа с файлами\n" +
        "• Каталог - работа с каталогами\n" +
        "• ИнформацияОФайле - информация о файлах\n" +
        "• Статические методы SmartGridAPI\n\n" +
        "Результаты в журнале.")
КонецФункции

// ============================================================================
// ОТЛАДОЧНАЯ ФУНКЦИЯ ДЛЯ ПРОВЕРКИ МЕТОДОВ
// ============================================================================
Функция ПроверитьМетодыОбъекта(объект, имяОбъекта)
    ДобавитьВЛог("🔍 Проверка объекта: " + имяОбъекта, "info")
    
    Попытка
        // Проверяем, что объект существует
        Если объект == undefined Тогда
            ДобавитьВЛог("  ❌ Объект не определен", "error")
            Возврат 
        Иначе
            ДобавитьВЛог("  ✅ Объект существует", "success")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("  ❌ Ошибка проверки объекта: " + e, "error")
        Возврат 
    КонецПопытки;
    
    // Пробуем вызвать английские методы
    Попытка
        Пусть англМетод = объект.fileName
        Если англМетод == undefined Тогда
            ДобавитьВЛог("  ❌ Метод fileName не найден", "error")
        Иначе
            ДобавитьВЛог("  ✅ Метод fileName найден", "success")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("  ❌ Ошибка проверки fileName: " + e, "error")
    КонецПопытки;
    
    Попытка
        Пусть русМетод = объект.ИмяФайла
        Если русМетод == undefined Тогда
            ДобавитьВЛог("  ❌ Метод ИмяФайла не найден", "error")
        Иначе
            ДобавитьВЛог("  ✅ Метод ИмяФайла найден", "success")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("  ❌ Ошибка проверки ИмяФайла: " + e, "error")
    КонецПопытки;
    
    // Пробуем выполнить простой английский метод
    Попытка
        объект.setFileName("test.txt")
        ДобавитьВЛог("  ✅ Метод setFileName выполнен", "success")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка setFileName: " + e, "error")
    КонецПопытки;
    
    // Пробуем выполнить простой русский метод
    Попытка
        объект.УстановитьИмяФайла("test2.txt")
        ДобавитьВЛог("  ✅ Метод УстановитьИмяФайла выполнен", "success")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка УстановитьИмяФайла: " + e, "error")
    КонецПопытки;
    
    // Пробуем получить значение
    Попытка
        Пусть имя = объект.fileName()
        ДобавитьВЛог("  fileName() вернул: " + имя, "info")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка fileName(): " + e, "error")
    КонецПопытки;
    
    Попытка
        Пусть имяРус = объект.ИмяФайла()
        ДобавитьВЛог("  ИмяФайла() вернул: " + имяРус, "info")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка ИмяФайла(): " + e, "error")
    КонецПопытки;
КонецФункции

// ============================================================================
// ПРОВЕРКА ОБЪЕКТА ФАЙЛ (через Новый Файл)
// ============================================================================
Функция ПроверкаОбъектаФайл() 
    ДобавитьВЛог("🔧 ПРОВЕРКА ОБЪЕКТА ФАЙЛ (через Новый Файл)", "progress")
    ДобавитьВЛог("=========================================", "info")
    
    ДобавитьВЛог("1. СОЗДАНИЕ ОБЪЕКТА:", "info")
    
    Попытка
        файл = Новый Файл()
        ДобавитьВЛог("  ✅ Новый Файл() - объект создан", "success")
    Исключение
        ДобавитьВЛог("  ❌ Новый Файл() не работает: " + e, "error")
        Возврат 
    КонецПопытки; 
    
    // ========== 2. ПРОВЕРКА РУССКИХ МЕТОДОВ ==========
    ДобавитьВЛог("2. ПРОВЕРКА РУССКИХ МЕТОДОВ:", "info")
    
    // 2.1 УстановитьИмяФайла
    Попытка
        файл.УстановитьИмяФайла("test_rus.txt")
        ДобавитьВЛог("  ✅ УстановитьИмяФайла() - работает", "success")
    Исключение
        ДобавитьВЛог("  ❌ УстановитьИмяФайла(): " + e, "error")
    КонецПопытки;
    
    // 2.2 ИмяФайла
    Попытка
        имя = файл.ИмяФайла()
        ДобавитьВЛог("  ✅ ИмяФайла() = " + имя, "success")
    Исключение
        ДобавитьВЛог("  ❌ ИмяФайла(): " + e, "error")
    КонецПопытки;
    
    // 2.3 Открыть (используем константы из объекта)
    Попытка
        файл.Открыть(файл.ТолькоЗапись | файл.Текст)
        ДобавитьВЛог("  ✅ Открыть() - работает", "success")
    Исключение
        ДобавитьВЛог("  ❌ Открыть(): " + e, "error")
    КонецПопытки;
    
    // 2.4 ЗаписатьСтроку
    Попытка
        файл.ЗаписатьСтроку("Строка 1 - тест записи")
        файл.ЗаписатьСтроку("Строка 2 - тест записи")
        ДобавитьВЛог("  ✅ ЗаписатьСтроку() - работает", "success")
    Исключение
        ДобавитьВЛог("  ❌ ЗаписатьСтроку(): " + e, "error")
    КонецПопытки;
    
    // 2.5 Записать
    Попытка
        файл.Записать("Строка 3 - без перевода строки")
        ДобавитьВЛог("  ✅ Записать() - работает", "success")
    Исключение
        ДобавитьВЛог("  ❌ Записать(): " + e, "error")
    КонецПопытки;
    
    // 2.6 Закрыть
    Попытка
        файл.Закрыть()
        ДобавитьВЛог("  ✅ Закрыть() - работает", "success")
    Исключение
        ДобавитьВЛог("  ❌ Закрыть(): " + e, "error")
    КонецПопытки;
    
    // ========== 3. ЧТЕНИЕ ФАЙЛА ==========
    ДобавитьВЛог("3. ЧТЕНИЕ ФАЙЛА:", "info")
    
    Попытка
        файлДляЧтения = Новый Файл("test_rus.txt")
        файлДляЧтения.Открыть(файлДляЧтения.ТолькоЧтение | файлДляЧтения.Текст)
        содержимое = файлДляЧтения.ПрочитатьВсе()
        файлДляЧтения.Закрыть()
        ДобавитьВЛог("  ✅ ПрочитатьВсе() = " + Лев(содержимое, 50), "success")
    Исключение
        ДобавитьВЛог("  ❌ ПрочитатьВсе(): " + e, "error")
    КонецПопытки;
    
    // ========== 4. ПРОВЕРКА ДРУГИХ МЕТОДОВ ==========
    ДобавитьВЛог("4. ПРОВЕРКА ДРУГИХ МЕТОДОВ:", "info")
    
    // 4.1 Размер
    Попытка
        размер = файл.Размер()
        ДобавитьВЛог("  ✅ Размер() = " + размер + " байт", "success")
    Исключение
        ДобавитьВЛог("  ❌ Размер(): " + e, "error")
    КонецПопытки;
    
    // 4.2 Позиция
    Попытка
        позиция = файл.Позиция()
        ДобавитьВЛог("  ✅ Позиция() = " + позиция, "success")
    Исключение
        ДобавитьВЛог("  ❌ Позиция(): " + e, "error")
    КонецПопытки;
    
    // 4.3 КонецФайла
    Попытка
        конец = файл.КонецФайла()
        ДобавитьВЛог("  ✅ КонецФайла() = " + (конец ? "Да" : "Нет"), "success")
    Исключение
        ДобавитьВЛог("  ❌ КонецФайла(): " + e, "error")
    КонецПопытки;
    
    // 4.4 Перейти
    Попытка
        файл.Перейти(0)
        ДобавитьВЛог("  ✅ Перейти(0) - работает", "success")
    Исключение
        ДобавитьВЛог("  ❌ Перейти(): " + e, "error")
    КонецПопытки;
    
    // ========== 5. УДАЛЕНИЕ ФАЙЛА ==========
    ДобавитьВЛог("5. УДАЛЕНИЕ ФАЙЛА:", "info")
    
    Попытка
        файл.Удалить()
        ДобавитьВЛог("  ✅ Удалить() - файл удалён", "success")
    Исключение
        ДобавитьВЛог("  ❌ Удалить(): " + e, "error")
    КонецПопытки;
    
     
    ДобавитьВЛог("=========================================", "info")
    ДобавитьВЛог("========== ПРОВЕРКА ЗАВЕРШЕНА ==========", "success")
КонецФункции

// ============================================================================
// ПРОВЕРКА ОБЪЕКТА КАТАЛОГ (через Новый Каталог)
// ============================================================================
Функция ПроверкаОбъектаКаталог()
    ДобавитьВЛог("📁 ПРОВЕРКА ОБЪЕКТА КАТАЛОГ (через Новый Каталог)", "progress")
    ДобавитьВЛог("=========================================", "info")
    
    // ========== 1. СОЗДАНИЕ ОБЪЕКТА ==========
    ДобавитьВЛог("1. СОЗДАНИЕ ОБЪЕКТА:", "info")
    
    Попытка
        каталог = Новый Каталог()
        ДобавитьВЛог("  ✅ Новый Каталог() - объект создан", "success")
    Исключение
        ДобавитьВЛог("  ❌ Новый Каталог() не работает: " + e, "error")
        Возврат 
    КонецПопытки;
    
    // ========== 2. ПРОВЕРКА РУССКИХ МЕТОДОВ ==========
    ДобавитьВЛог("2. ПРОВЕРКА РУССКИХ МЕТОДОВ:", "info")
    
    // 2.1 УстановитьПуть и Путь
    Попытка
        каталог.УстановитьПуть(ТекущийПуть())
        путь = каталог.Путь()
        ДобавитьВЛог("  ✅ УстановитьПуть() / Путь() = " + путь, "success")
    Исключение
        ДобавитьВЛог("  ❌ УстановитьПуть() / Путь(): " + e, "error")
    КонецПопытки;
    
    // 2.2 АбсолютныйПуть
    Попытка
        абсПуть = каталог.АбсолютныйПуть()
        ДобавитьВЛог("  ✅ АбсолютныйПуть() = " + абсПуть, "success")
    Исключение
        ДобавитьВЛог("  ❌ АбсолютныйПуть(): " + e, "error")
    КонецПопытки;
    
    // 2.3 ИмяКаталога
    Попытка
        имя = каталог.ИмяКаталога()
        ДобавитьВЛог("  ✅ ИмяКаталога() = " + имя, "success")
    Исключение
        ДобавитьВЛог("  ❌ ИмяКаталога(): " + e, "error")
    КонецПопытки;
    
    // 2.4 Существует
    Попытка
        существует = каталог.Существует()
        ДобавитьВЛог("  ✅ Существует() = " + (существует ? "Да" : "Нет"), "success")
    Исключение
        ДобавитьВЛог("  ❌ Существует(): " + e, "error")
    КонецПопытки;
    
    // 2.5 ДоступенДляЧтения
    Попытка
        доступен = каталог.ДоступенДляЧтения()
        ДобавитьВЛог("  ✅ ДоступенДляЧтения() = " + (доступен ? "Да" : "Нет"), "success")
    Исключение
        ДобавитьВЛог("  ❌ ДоступенДляЧтения(): " + e, "error")
    КонецПопытки;
    
    // ========== 3. СОЗДАНИЕ КАТАЛОГОВ ==========
    ДобавитьВЛог("3. СОЗДАНИЕ КАТАЛОГОВ:", "info")
    
    тестовыйКаталог = ТекущийПуть() + "/TestDir_" + СгенерироватьUUID()
    
    // 3.1 СоздатьКаталог
    Попытка
        каталог.СоздатьКаталог(тестовыйКаталог)
        ДобавитьВЛог("  ✅ СоздатьКаталог(" + тестовыйКаталог + ") - работает", "success")
    Исключение
        ДобавитьВЛог("  ❌ СоздатьКаталог(): " + e, "error")
    КонецПопытки;
    
    // 3.2 СоздатьПуть (с вложенными каталогами)
    Попытка
        вложенныйПуть = тестовыйКаталог + "/subfolder1/subfolder2"
        каталог.СоздатьПуть(вложенныйПуть)
        ДобавитьВЛог("  ✅ СоздатьПуть(" + вложенныйПуть + ") - работает", "success")
    Исключение
        ДобавитьВЛог("  ❌ СоздатьПуть(): " + e, "error")
    КонецПопытки;
    
    // 3.3 Проверка существования
    Попытка
        каталог.УстановитьПуть(тестовыйКаталог)
        Если каталог.Существует() Тогда
            ДобавитьВЛог("  ✅ Каталог существует", "success")
        Иначе
            ДобавитьВЛог("  ⚠️ Каталог не найден", "warning")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("  ❌ Ошибка проверки существования: " + e, "error")
    КонецПопытки;
    
    // ========== 4. ПОЛУЧЕНИЕ СПИСКА ФАЙЛОВ ==========
    ДобавитьВЛог("4. ПОЛУЧЕНИЕ СПИСКА ФАЙЛОВ:", "info")
    
    // 4.1 Создаём тестовые файлы в каталоге
    Попытка
        файл1 = Новый Файл(тестовыйКаталог + "/file1.txt")
        файл1.Открыть(файл1.ТолькоЗапись | файл1.Текст)
        файл1.ЗаписатьСтроку("Тестовый файл 1")
        файл1.Закрыть()
        
        файл2 = Новый Файл(тестовыйКаталог + "/file2.txt")
        файл2.Открыть(файл2.ТолькоЗапись | файл2.Текст)
        файл2.ЗаписатьСтроку("Тестовый файл 2")
        файл2.Закрыть()
        
        ДобавитьВЛог("  ✅ Созданы тестовые файлы", "success")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка создания файлов: " + e, "error")
    КонецПопытки;
    
    // 4.2 СписокФайлов (все элементы)
    Попытка
        каталог.УстановитьПуть(тестовыйКаталог)
        всеЭлементы = каталог.СписокФайлов()
        ДобавитьВЛог("  ✅ СписокФайлов() = " + всеЭлементы.join(", "), "info")
    Исключение
        ДобавитьВЛог("  ❌ СписокФайлов(): " + e, "error")
    КонецПопытки;
    
    // 4.3 ТолькоФайлы
    Попытка
        толькофайлы = каталог.ТолькоФайлы()
        ДобавитьВЛог("  ✅ ТолькоФайлы() = " + толькофайлы.join(", "), "info")
    Исключение
        ДобавитьВЛог("  ❌ ТолькоФайлы(): " + e, "error")
    КонецПопытки;
    
    // 4.4 ТолькоКаталоги
    Попытка
        толькокаталоги = каталог.ТолькоКаталоги()
        ДобавитьВЛог("  ✅ ТолькоКаталоги() = " + толькокаталоги.join(", "), "info")
    Исключение
        ДобавитьВЛог("  ❌ ТолькоКаталоги(): " + e, "error")
    КонецПопытки;
    
    // ========== 5. НАВИГАЦИЯ ПО КАТАЛОГАМ ==========
    ДобавитьВЛог("5. НАВИГАЦИЯ ПО КАТАЛОГАМ:", "info")
    
    // 5.1 ПерейтиВКаталог
    Попытка
        каталог.ПерейтиВКаталог("subfolder1")
        новыйПуть = каталог.Путь()
        ДобавитьВЛог("  ✅ ПерейтиВКаталог('subfolder1') -> " + новыйПуть, "success")
    Исключение
        ДобавитьВЛог("  ❌ ПерейтиВКаталог(): " + e, "error")
    КонецПопытки;
    
    // 5.2 ПерейтиВверх
    Попытка
        каталог.ПерейтиВверх()
        верхнийПуть = каталог.Путь()
        ДобавитьВЛог("  ✅ ПерейтиВверх() -> " + верхнийПуть, "success")
    Исключение
        ДобавитьВЛог("  ❌ ПерейтиВверх(): " + e, "error")
    КонецПопытки;
    
    // ========== 6. УДАЛЕНИЕ КАТАЛОГА ==========
    ДобавитьВЛог("6. УДАЛЕНИЕ КАТАЛОГА:", "info")
    
    // 6.1 УдалитьКаталог (пустой каталог)
    Попытка
        пустойКаталог = ТекущийПуть() + "/EmptyDir_" + СгенерироватьUUID()
        каталог.СоздатьКаталог(пустойКаталог)
        каталог.УдалитьКаталог(пустойКаталог)
        ДобавитьВЛог("  ✅ УдалитьКаталог() - пустой каталог удалён", "success")
    Исключение
        ДобавитьВЛог("  ❌ УдалитьКаталог(): " + e, "error")
    КонецПопытки;
    
    // 6.2 УдалитьРекурсивно (каталог с файлами)
    Попытка
        каталог.УстановитьПуть(тестовыйКаталог)
        каталог.УдалитьРекурсивно()
        ДобавитьВЛог("  ✅ УдалитьРекурсивно() - каталог с файлами удалён", "success")
    Исключение
        ДобавитьВЛог("  ❌ УдалитьРекурсивно(): " + e, "error")
    КонецПопытки;
    
    // 6.3 Проверка, что каталог удалён
    Попытка
        каталог.УстановитьПуть(тестовыйКаталог)
        Если НЕ каталог.Существует() Тогда
            ДобавитьВЛог("  ✅ Каталог действительно удалён", "success")
        Иначе
            ДобавитьВЛог("  ⚠️ Каталог всё ещё существует", "warning")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("  ❌ Ошибка проверки удаления: " + e, "error")
    КонецПопытки;
    
    ДобавитьВЛог("=========================================", "info")
    ДобавитьВЛог("========== ПРОВЕРКА КАТАЛОГА ЗАВЕРШЕНА ==========", "success")
КонецФункции

// ============================================================================
// ПРОВЕРКА ОБЪЕКТА ИНФОРМАЦИЯОФАЙЛЕ (через Новый ИнформацияОФайле)
// ============================================================================
Функция ПроверкаОбъектаИнформацияОФайле()
    ДобавитьВЛог("ℹ️ ПРОВЕРКА ОБЪЕКТА ИНФОРМАЦИЯОФАЙЛЕ (через Новый ИнформацияОФайле)", "progress")
    ДобавитьВЛог("=========================================", "info")
    
    // ========== 1. СОЗДАНИЕ ОБЪЕКТА ==========
    ДобавитьВЛог("1. СОЗДАНИЕ ОБЪЕКТА:", "info")
    
    // 1.1 Создаём тестовый файл
    Попытка
        тестовыйФайл = ТекущийПуть() + "/test_info_" + СгенерироватьUUID() + ".txt"
        файлДляТеста = Новый Файл(тестовыйФайл)
        файлДляТеста.Открыть(2 | 16)  // 2 = WriteOnly, 16 = Text
        файлДляТеста.ЗаписатьСтроку("Тестовый файл для получения информации")
        файлДляТеста.ЗаписатьСтроку("Вторая строка для теста")
        файлДляТеста.Закрыть()
        ДобавитьВЛог("  ✅ Создан тестовый файл: " + тестовыйФайл, "success")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка создания тестового файла: " + e, "error")
        Возврат 
    КонецПопытки;
    
    // 1.2 Создание объекта ИнформацияОФайле
    Попытка
        инфо = Новый ИнформацияОФайле(тестовыйФайл)
        ДобавитьВЛог("  ✅ Новый ИнформацияОФайле() - объект создан", "success")
    Исключение
        ДобавитьВЛог("  ❌ Новый ИнформацияОФайле() не работает: " + e, "error")
        Возврат 
    КонецПопытки;
    
    // ========== 2. ПРОВЕРКА ОСНОВНЫХ МЕТОДОВ ==========
    ДобавитьВЛог("2. ПРОВЕРКА ОСНОВНЫХ МЕТОДОВ:", "info")
    
    // 2.1 ПолныйПуть
    Попытка
        полныйПуть = инфо.ПолныйПуть()
        ДобавитьВЛог("  ✅ ПолныйПуть() = " + полныйПуть, "success")
    Исключение
        ДобавитьВЛог("  ❌ ПолныйПуть(): " + e, "error")
    КонецПопытки;
    
    // 2.2 АбсолютныйПуть
    Попытка
        абсолютныйПуть = инфо.АбсолютныйПуть()
        ДобавитьВЛог("  ✅ АбсолютныйПуть() = " + абсолютныйПуть, "success")
    Исключение
        ДобавитьВЛог("  ❌ АбсолютныйПуть(): " + e, "error")
    КонецПопытки;
    
    // 2.3 ИмяФайла
    Попытка
        имяФайла = инфо.ИмяФайла()
        ДобавитьВЛог("  ✅ ИмяФайла() = " + имяФайла, "success")
    Исключение
        ДобавитьВЛог("  ❌ ИмяФайла(): " + e, "error")
    КонецПопытки;
    
    // 2.4 БазовоеИмя
    Попытка
        базовоеИмя = инфо.БазовоеИмя()
        ДобавитьВЛог("  ✅ БазовоеИмя() = " + базовоеИмя, "success")
    Исключение
        ДобавитьВЛог("  ❌ БазовоеИмя(): " + e, "error")
    КонецПопытки;
    
    // 2.5 Расширение
    Попытка
        расширение = инфо.Расширение()
        ДобавитьВЛог("  ✅ Расширение() = " + расширение, "success")
    Исключение
        ДобавитьВЛог("  ❌ Расширение(): " + e, "error")
    КонецПопытки;
    
    // 2.6 Путь
    Попытка
        путь = инфо.Путь()
        ДобавитьВЛог("  ✅ Путь() = " + путь, "success")
    Исключение
        ДобавитьВЛог("  ❌ Путь(): " + e, "error")
    КонецПопытки;
    
    // 2.7 РодительскийКаталог
    Попытка
        родительскийКаталог = инфо.РодительскийКаталог()
        ДобавитьВЛог("  ✅ РодительскийКаталог() = " + родительскийКаталог, "success")
    Исключение
        ДобавитьВЛог("  ❌ РодительскийКаталог(): " + e, "error")
    КонецПопытки;
    
    // ========== 3. ПРОВЕРКА АТРИБУТОВ ==========
    ДобавитьВЛог("3. ПРОВЕРКА АТРИБУТОВ:", "info")
    
    // 3.1 Размер
    Попытка
        размер = инфо.Размер()
        ДобавитьВЛог("  ✅ Размер() = " + размер + " байт", "success")
    Исключение
        ДобавитьВЛог("  ❌ Размер(): " + e, "error")
    КонецПопытки;
    
    // 3.2 Существует
    Попытка
        существует = инфо.Существует()
        ДобавитьВЛог("  ✅ Существует() = " + (существует ? "Да" : "Нет"), "success")
    Исключение
        ДобавитьВЛог("  ❌ Существует(): " + e, "error")
    КонецПопытки;
    
    // 3.3 ЯвляетсяФайлом
    Попытка
        являетсяФайлом = инфо.ЯвляетсяФайлом()
        ДобавитьВЛог("  ✅ ЯвляетсяФайлом() = " + (являетсяФайлом ? "Да" : "Нет"), "success")
    Исключение
        ДобавитьВЛог("  ❌ ЯвляетсяФайлом(): " + e, "error")
    КонецПопытки;
    
    // 3.4 ЯвляетсяКаталогом
    Попытка
        являетсяКаталогом = инфо.ЯвляетсяКаталогом()
        ДобавитьВЛог("  ✅ ЯвляетсяКаталогом() = " + (являетсяКаталогом ? "Да" : "Нет"), "success")
    Исключение
        ДобавитьВЛог("  ❌ ЯвляетсяКаталогом(): " + e, "error")
    КонецПопытки;
    
    // 3.5 Скрытый
    Попытка
        скрытый = инфо.Скрытый()
        ДобавитьВЛог("  ✅ Скрытый() = " + (скрытый ? "Да" : "Нет"), "success")
    Исключение
        ДобавитьВЛог("  ❌ Скрытый(): " + e, "error")
    КонецПопытки;
    
    // 3.6 ДоступенДляЧтения
    Попытка
        доступенЧтение = инфо.ДоступенДляЧтения()
        ДобавитьВЛог("  ✅ ДоступенДляЧтения() = " + (доступенЧтение ? "Да" : "Нет"), "success")
    Исключение
        ДобавитьВЛог("  ❌ ДоступенДляЧтения(): " + e, "error")
    КонецПопытки;
    
    // 3.7 ДоступенДляЗаписи
    Попытка
        доступенЗапись = инфо.ДоступенДляЗаписи()
        ДобавитьВЛог("  ✅ ДоступенДляЗаписи() = " + (доступенЗапись ? "Да" : "Нет"), "success")
    Исключение
        ДобавитьВЛог("  ❌ ДоступенДляЗаписи(): " + e, "error")
    КонецПопытки;
    
    // ========== 4. ПРОВЕРКА ДАТ ==========
    ДобавитьВЛог("4. ПРОВЕРКА ДАТ:", "info")
    
    // 4.1 ДатаСоздания
    Попытка
        датаСоздания = инфо.ДатаСоздания()
        ДобавитьВЛог("  ✅ ДатаСоздания() = " + датаСоздания.toString("dd.MM.yyyy HH:mm:ss"), "success")
    Исключение
        ДобавитьВЛог("  ❌ ДатаСоздания(): " + e, "error")
    КонецПопытки;
    
    // 4.2 ДатаПоследнегоИзменения
    Попытка
        датаИзменения = инфо.ДатаПоследнегоИзменения()
        ДобавитьВЛог("  ✅ ДатаПоследнегоИзменения() = " + датаИзменения.toString("dd.MM.yyyy HH:mm:ss"), "success")
    Исключение
        ДобавитьВЛог("  ❌ ДатаПоследнегоИзменения(): " + e, "error")
    КонецПопытки;
    
    // 4.3 ДатаПоследнегоЧтения
    Попытка
        датаЧтения = инфо.ДатаПоследнегоЧтения()
        ДобавитьВЛог("  ✅ ДатаПоследнегоЧтения() = " + датаЧтения.toString("dd.MM.yyyy HH:mm:ss"), "success")
    Исключение
        ДобавитьВЛог("  ❌ ДатаПоследнегоЧтения(): " + e, "error")
    КонецПопытки;
    
    // ========== 5. ПРОВЕРКА СВОЙСТВ СИМВОЛИЧЕСКИХ ССЫЛОК ==========
    ДобавитьВЛог("5. ПРОВЕРКА СВОЙСТВ СИМВОЛИЧЕСКИХ ССЫЛОК:", "info")
    
    Попытка
        являетсяСсылкой = инфо.ЯвляетсяСимволическойСсылкой()
        ДобавитьВЛог("  ✅ ЯвляетсяСимволическойСсылкой() = " + (являетсяСсылкой ? "Да" : "Нет"), "success")
    Исключение
        ДобавитьВЛог("  ❌ ЯвляетсяСимволическойСсылкой(): " + e, "error")
    КонецПопытки;
    
    // ========== 6. УДАЛЕНИЕ ТЕСТОВОГО ФАЙЛА ==========
    ДобавитьВЛог("6. УДАЛЕНИЕ ТЕСТОВОГО ФАЙЛА:", "info")
    
    Попытка
        файлДляТеста.Удалить()
        ДобавитьВЛог("  ✅ Тестовый файл удалён", "success")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка удаления файла: " + e, "error")
    КонецПопытки;
    
    ДобавитьВЛог("=========================================", "info")
    ДобавитьВЛог("========== ПРОВЕРКА ИНФОРМАЦИЯОФАЙЛЕ ЗАВЕРШЕНА ==========", "success")
КонецФункции

Функция СоздатьОкноТестQtФайл() 
    Пусть имяОкна = "ОкноТестQtФайл"
    
    СоздатьПодокноMDI(Глоб_mdi, имяОкна, 10, 10, 950, 750)
    
    // Создаём вкладки
    СоздатьВкладки("ВкладкиТестыРус", { 
        "Лево": 10, "Верх": 10, "Ширина": 920, "Высота": 680, 
        "Вкладки": "ТестыРусскихКлассов" 
    }, имяОкна)
    
    // ==================== СТРАНИЦА 0: ТЕСТЫ ====================
    
    ДобавитьНаВкладку("ВкладкиТестыРус", 0, "Группа", "testButtonsGroupRus", { "Лево": 20, "Верх": 20, "Ширина": 880, "Высота": 200, "Заголовок": "ТЕСТЫ РУССКИХ КЛАССОВ" })
    
    ДобавитьОбъектНаСтранице(0, "Кнопка", "btnTestFilesRus", { "Лево": 30, "Верх": 30, "Ширина": 260, "Высота": 40, "Заголовок": "📄 ТЕСТ ФАЙЛ (Файл)" }, "testButtonsGroupRus")
        ПриНажатииКнопки("btnTestFilesRus", Функция() { ОчиститьЛог(); ТестФайлы() })
    ДобавитьОбъектНаСтранице(0, "Кнопка", "btnTestDirsRus", { "Лево": 310, "Верх": 30, "Ширина": 260, "Высота": 40, "Заголовок": "📁 ТЕСТ КАТАЛОГ (Каталог)" }, "testButtonsGroupRus")
        ПриНажатииКнопки("btnTestDirsRus", Функция() { ОчиститьЛог(); ТестКаталоги() })
    ДобавитьОбъектНаСтранице(0, "Кнопка", "btnTestFileInfoRus", { "Лево": 590, "Верх": 30, "Ширина": 260, "Высота": 40, "Заголовок": "ℹ️ ТЕСТ ИНФОРМАЦИИ (ИнформацияОФайле)" }, "testButtonsGroupRus")
        ПриНажатииКнопки("btnTestFileInfoRus", Функция() { ОчиститьЛог(); ТестИнформацияОФайле() })
    
    ДобавитьОбъектНаСтранице(0, "Кнопка", "btnRunAllTestsRus", { "Лево": 310, "Верх": 80, "Ширина": 260, "Высота": 40, "Заголовок": "🚀 ЗАПУСТИТЬ ВСЕ ТЕСТЫ" }, "testButtonsGroupRus")
        ПриНажатииКнопки("btnRunAllTestsRus", Функция() { ОчиститьЛог(); ЗапуститьВсеТестыQtФайл() })
    ДобавитьОбъектНаСтранице(0, "Кнопка", "btnClearLogRus", { "Лево": 590, "Верх": 80, "Ширина": 260, "Высота": 40, "Заголовок": "🗑️ ОЧИСТИТЬ ЖУРНАЛ" }, "testButtonsGroupRus")
        ПриНажатииКнопки("btnClearLogRus", Функция() { ОчиститьЛог() })
    
    ДобавитьОбъектНаСтранице(0, "Кнопка", "btnCheckMethods", { "Лево": 30, "Верх": 130, "Ширина": 200, "Высота": 40, "Заголовок": "🔧 ПРОВЕРИТЬ ОБЪЕКТ Файл" }, "testButtonsGroupRus")
        ПриНажатииКнопки("btnCheckMethods", Функция() { ОчиститьЛог(); ПроверкаОбъектаФайл() })
    ДобавитьОбъектНаСтранице(0, "Кнопка", "btnCheckDir", { "Лево": 250, "Верх": 130, "Ширина": 200, "Высота": 40, "Заголовок": "🔧 ПРОВЕРИТЬ ОБЪЕКТ Каталог" }, "testButtonsGroupRus")
        ПриНажатииКнопки("btnCheckDir", Функция() { ОчиститьЛог(); ПроверкаОбъектаКаталог() })
    ДобавитьОбъектНаСтранице(0, "Кнопка", "btnCheckFileInfo", { "Лево": 470, "Верх": 130, "Ширина": 200, "Высота": 40, "Заголовок": "🔧 ПРОВЕРИТЬ ОБЪЕКТ ИнфоФайл" }, "testButtonsGroupRus")
        ПриНажатииКнопки("btnCheckFileInfo", Функция() { ОчиститьЛог(); ПроверкаОбъектаИнформацияОФайле() }) 
  
    ДобавитьНаВкладку("ВкладкиТестыРус", 0, "Группа", "infoGroupRus", { "Лево": 20, "Верх": 220, "Ширина": 880, "Высота": 130, "Заголовок": "ИНФОРМАЦИЯ О ТЕСТАХ" })
    
    ДобавитьОбъектНаСтранице(0, "Надпись", "lblInfoRus", { "Лево": 30, "Верх": 30, "Ширина": 870, "Высота": 80, 
        "Заголовок": "Тестирование русских классов для работы с файловой системой:\n" +
        "• Файл - полный аналог QFile с русскими методами\n" +
        "• Каталог - полный аналог QDir с русскими методами\n" +
        "• ИнформацияОФайле - полный аналог QFileInfo с русскими методами"
    }, "infoGroupRus")
    
    ДобавитьНаВкладку("ВкладкиТестыРус", 0, "Группа", "logGroupRus", { "Лево": 20, "Верх": 360, "Ширина": 880, "Высота": 300, "Заголовок": "ЖУРНАЛ ТЕСТИРОВАНИЯ" })
    
    ДобавитьОбъектНаСтранице(0, "ТекстоваяОбласть", "txtLog", { "Лево": 10, "Верх": 25, "Ширина": 860, "Высота": 260, 
                "Значение": "=== ЖУРНАЛ ТЕСТИРОВАНИЯ РУССКИХ КЛАССОВ ===\n\nНажмите на кнопку для запуска тестов..." }, "logGroupRus")
    
    ДобавитьВЛог("✅ Окно тестирования русских классов создано", "success")
    ДобавитьВЛог("📌 Доступные тесты: Файл, Каталог, ИнформацияОФайле, Статические методы", "info")
    
        ПоказатьСообщение("🧪 ТЕСТИРОВАНИЕ РУССКИХ КЛАССОВ\n\n" +
        "Протестированные классы:\n" +
        "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n" +
        "📄 Файл - работа с файлами\n" +
        "   • Создание, чтение, запись\n" +
        "   • Копирование, переименование, удаление\n" +
        "   • Построчное чтение\n" +
        "\n" +
        "📁 Каталог - работа с каталогами\n" +
        "   • Создание структуры\n" +
        "   • Навигация (cd, cdUp)\n" +
        "   • Список файлов с фильтрацией\n" +
        "   • Рекурсивный обход\n" +
        "\n" +
        "ℹ️ ИнформацияОФайле - информация о файлах\n" +
        "   • Базовые атрибуты (имя, размер, путь)\n" +
        "   • Даты создания/изменения\n" +
        "   • Тип файла, читаемый размер\n" +
        "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n" +
        "Нажмите на кнопки для запуска тестов.\n" +
        "Результаты отображаются в журнале.")
    
    Сообщить("=== ТЕСТИРОВАНИЕ РУССКИХ КЛАССОВ ГОТОВО ===")
    Возврат имяОкна
КонецФункции

//#КонецОбласти

//#Область Тест ОкноТестQtТаймер

// ============================================================================
// ТЕСТ ТАЙМЕРА
// ============================================================================
Функция ТестТаймер() 
    ДобавитьВЛог("⏱️ ТЕСТ ТАЙМЕРА (SmartGridTimer)", "progress")
    
    // ========== 1. СОЗДАНИЕ ТАЙМЕРА ==========
    Попытка
        таймер = Новый Таймер()
        ДобавитьВЛог("  ✅ Таймер создан", "success")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка создания таймера: " + e, "error")
        Возврат 
    КонецПопытки;
    
    // ========== 2. НАСТРОЙКА ТАЙМЕРА ==========
    Попытка
        таймер.УстановитьИнтервал(1000)      // 1 секунда
        ДобавитьВЛог("  ✅ Интервал установлен: " + таймер.Интервал() + " мс", "success")
    Исключение
        ДобавитьВЛог("  ❌ Интервал не установлен: " + e, "error")
        Возврат 
    КонецПопытки;
    Попытка
        таймер.УстановитьОднократный(ЛОЖЬ)   // Периодический
        ДобавитьВЛог("  ✅ Однократный режим: " + (таймер.Однократный() ? "Да" : "Нет"), "info")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка настройки таймера: " + e, "error")
        Возврат 
    КонецПопытки;
    
    // ========== 3. УСТАНОВКА ОБРАБОТЧИКА ==========
    Пусть счетчик = 0
    
    Попытка
        таймер.УстановитьТаймаут( Функция() {
            счетчик = счетчик + 1
            ДобавитьВЛог("  🔔 Тик #" + счетчик, "info")
            
            if (счетчик >= 3) {
                таймер.Остановить()
                ДобавитьВЛог("  ✅ Таймер остановлен после 3 тиков", "success")
            }
        })
        ДобавитьВЛог("  ✅ Обработчик установлен", "success")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка установки обработчика: " + e, "error")
        Возврат 
    КонецПопытки;
    
    // ========== 4. ЗАПУСК ТАЙМЕРА ==========
    Попытка
        таймер.Запустить()
        ДобавитьВЛог("  ✅ Таймер запущен", "success")
        ДобавитьВЛог("  Активен: " + (таймер.isActive() ? "Да" : "Нет"), "info")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка запуска таймера: " + e, "error")
        Возврат 
    КонецПопытки;
    
    // ========== 5. ОЖИДАНИЕ ==========
    Пауза(4000)
    
    // ========== 6. ПРОВЕРКА ==========
    Попытка
        Если НЕ таймер.Активен()) {
            ДобавитьВЛог("  ✅ Таймер остановлен корректно", "success")
        }
    Исключение
        ДобавитьВЛог("  ❌ Ошибка проверки: " + e, "error")
    КонецПопытки;
    
    ДобавитьВЛог("========== ТЕСТ ТАЙМЕРА ЗАВЕРШЁН ==========", "success")
КонецФункции


// ============================================================================
// ТЕСТ ОДНОКРАТНОГО ТАЙМЕРА
// ============================================================================
Функция ТестОднократныйТаймер() 
    ДобавитьВЛог("⏱️ ТЕСТ ОДНОКРАТНОГО ТАЙМЕРА", "progress")
    
    Пусть таймер = null
    Пусть сработал = false
    
    // 1. СОЗДАНИЕ
    Попытка
        таймер = Новый Таймер()
        ДобавитьВЛог("  ✅ Таймер создан", "success")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка создания: " + e, "error")
        Возврат 
    КонецПопытки;
    
    // 2. НАСТРОЙКА
    Попытка
        таймер.УстановитьОднократный(ИСТИНА)   // Однократный
        таймер.УстановитьИнтервал(2000)     // 2 секунды
        ДобавитьВЛог("  ✅ Настроен как однократный", "success")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка настройки: " + e, "error")
        Возврат 
    КонецПопытки;
    
    // 3. ОБРАБОТЧИК
    Попытка
        таймер.УстановитьТаймаут( Функция() {
            ДобавитьВЛог("  🔔 Однократный таймер сработал!", "success")
            сработал = ИСТИНА
        })
        ДобавитьВЛог("  ✅ Обработчик установлен", "success")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка установки обработчика: " + e, "error")
        Возврат 
    КонецПопытки;
    
    // 4. ЗАПУСК
    Попытка
        таймер.Запустить()
        ДобавитьВЛог("  ✅ Таймер запущен", "success")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка запуска: " + e, "error")
        Возврат 
    КонецПопытки;
    
    // 5. ОЖИДАНИЕ
    Пауза(2500)
    
    // 6. ПРОВЕРКА
    Если сработал Тогда
        ДобавитьВЛог("  ✅ Однократный таймер отработал корректно", "success")
    Иначе
        ДобавитьВЛог("  ❌ Однократный таймер не сработал", "error")
    КонецЕсли;
    
    ДобавитьВЛог("========== ТЕСТ ОДНОКРАТНОГО ТАЙМЕРА ЗАВЕРШЁН ==========", "success")
КонецФункции


// ============================================================================
// ЗАПУСК ВСЕХ ТЕСТОВ
// ============================================================================
Функция ЗапуститьВсеТестыТаймера() 
    ДобавитьВЛог("🚀 ЗАПУСК ВСЕХ ТЕСТОВ ТАЙМЕРА", "progress")
    ДобавитьВЛог("=========================================", "info")
    
    ТестТаймер()
    sleep(500)
    ТестОднократныйТаймер()
    sleep(500)
    
    ДобавитьВЛог("=========================================", "info")
    ДобавитьВЛог("✅ ВСЕ ТЕСТЫ ТАЙМЕРА ЗАВЕРШЕНЫ", "success")
    ПоказатьСообщение("✅ Все тесты таймера успешно завершены!\n\n" +
        "Протестированы:\n" +
        "• Периодический таймер (3 тика)\n" +
        "• Однократный таймер (2 секунды)\n\n" +
        "Результаты в журнале.")
КонецФункции


// ============================================================================
// ТЕСТ НАСТРОЕК (SmartGridSettings)
// ============================================================================
Функция ТестНастройки() 
    ДобавитьВЛог("⚙️ ТЕСТ НАСТРОЕК (SmartGridSettings)", "progress")
    
    // ========== 1. СОЗДАНИЕ НАСТРОЕК ==========
    Попытка
        настройки = Новый Настройки("test_config.ini", 1)  // SmartGridSettings.IniFormat = 1
        ДобавитьВЛог("  ✅ Настройки созданы", "success")
        ДобавитьВЛог("  Имя файла: " + настройки.ИмяФайла(), "info")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка создания: " + e, "error")
        Возврат 
    КонецПопытки;
    
    // ========== 2. ЗАПИСЬ ЗНАЧЕНИЙ ==========
    Попытка
        настройки.УстановитьЗначение("app/name", "SmartGrid")
        настройки.УстановитьЗначение("app/version", 10)
        настройки.УстановитьЗначение("app/debug", true)
        настройки.Сохранить()
        ДобавитьВЛог("  ✅ Значения сохранены", "success")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка сохранения: " + e, "error")
    КонецПопытки;
    
    // ========== 3. ЧТЕНИЕ ЗНАЧЕНИЙ ==========
    Попытка
        имя = настройки.Значение("app/name")    //.toString()
        версия = настройки.Значение("app/version")
        отладка = настройки.Значение("app/debug")
        
        ДобавитьВЛог("  Значения прочитаны:", "info")
        ДобавитьВЛог("    Имя: " + имя, "info")
        ДобавитьВЛог("    Версия: " + версия, "info")
        ДобавитьВЛог("    Отладка: " + (отладка ? "Да" : "Нет"), "info")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка чтения: " + e, "error")
    КонецПопытки;
    
    // ========== 4. РАБОТА С ГРУППАМИ ==========
    Попытка
        настройки.НачатьГруппу("database")
        настройки.УстановитьЗначение("host", "localhost")
        настройки.УстановитьЗначение("port", 3306)
        настройки.ЗакончитьГруппу()
        настройки.Сохранить()
        ДобавитьВЛог("  ✅ Группа database сохранена", "success")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка: " + e, "error")
    КонецПопытки;
    
    // ========== 5. ВСЕ КЛЮЧИ ==========
    Попытка
        всеКлючи = настройки.ВсеКлючи()
        ДобавитьВЛог("  Все ключи (" + всеКлючи.длина + " шт.):", "info")
        Для i = 0 По всеКлючи.длина - 1 Цикл
            ДобавитьВЛог("    " + всеКлючи[i], "info")
        КонецЦикла;
    Исключение
        ДобавитьВЛог("  ❌ Ошибка: " + e, "error")
    КонецПопытки;
    
    // ========== 6. УДАЛЕНИЕ ==========
    Попытка
        Если настройки.Содержит("app/version") Тогда
            настройки.Удалить("app/version")
            настройки.Сохранить()
            ДобавитьВЛог("  ✅ Ключ 'app/version' удалён", "success")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("  ❌ Ошибка удаления: " + e, "error")
    КонецПопытки;
    
    // ========== 7. ОЧИСТКА ==========
    Попытка
        настройки.Очистить()
        настройки.Сохранить()
        ДобавитьВЛог("  ✅ Настройки очищены", "success")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка очистки: " + e, "error")
    КонецПопытки;
    
    ДобавитьВЛог("========== ТЕСТ НАСТРОЕК ЗАВЕРШЁН ==========", "success")
КонецФункции


// ============================================================================
// СОЗДАНИЕ ОКНА С ТЕСТАМИ
// ============================================================================
Функция СоздатьОкноТестQtТаймер() 
    Пусть имяОкна = "ОкноТестQtТаймер"
    
    СоздатьПодокноMDI(Глоб_mdi, имяОкна, 10, 10, 950, 750)
    СоздатьВкладки("ВкладкиТестыТаймер", { "Лево": 10, "Верх": 10, "Ширина": 920, "Высота": 680, "Вкладки": "ТестыТаймера" }, имяОкна)
    
    // Группа для кнопок
    ДобавитьНаВкладку("ВкладкиТестыТаймер", 0, "Группа", "testButtonsGroup", { "Лево": 20, "Верх": 20, "Ширина": 880, "Высота": 200, 
                                "Заголовок": "ТЕСТЫ КЛАССА ТАЙМЕР (SmartGridTimer)" })
    
    ДобавитьОбъектНаСтранице(0, "Кнопка", "btnRunAllTests", { "Лево": 30, "Верх": 50, "Ширина": 300, "Высота": 50, "Заголовок": "⏱️ ТЕСТЫ ТАЙМЕРА" }, "testButtonsGroup")
        ПриНажатииКнопки("btnRunAllTests", function() { ОчиститьЛог(); ЗапуститьВсеТестыТаймера() })
    ДобавитьОбъектНаСтранице(0, "Кнопка", "btnRunNastr", { "Лево": 360, "Верх": 50, "Ширина": 300, "Высота": 50, "Заголовок": "⏱️ ТЕСТЫ INI-файла" }, "testButtonsGroup")
        ПриНажатииКнопки("btnRunNastr", function() { ОчиститьЛог(); ТестНастройки() })
    
    ДобавитьОбъектНаСтранице(0, "Кнопка", "btnClearLog", { "Лево": 30, "Верх": 130, "Ширина": 150, "Высота": 50, "Заголовок": "🗑️ ОЧИСТИТЬ ЛОГ" }, "testButtonsGroup")
        ПриНажатииКнопки("btnClearLog", function() { ОчиститьЛог() })
    
    ДобавитьНаВкладку("ВкладкиТестыТаймер", 0, "Группа", "infoGroup", { "Лево": 20, "Верх": 240, "Ширина": 880, "Высота": 100, "Заголовок": "ИНФОРМАЦИЯ" })
    
    ДобавитьОбъектНаСтранице(0, "Надпись", "lblInfo", { "Лево": 30, "Верх": 30, "Ширина": 840, "Высота": 60, 
        "Заголовок": "Тестирование класса Таймер (SmartGridTimer):\n" +
        "• Периодический таймер - 3 тика с интервалом 1 секунда\n" +
        "• Однократный таймер - срабатывание через 2 секунды" 
    }, "infoGroup")
    
    // Группа результатов (лог)
    ДобавитьНаВкладку("ВкладкиТестыТаймер", 0, "Группа", "logGroup", { "Лево": 20, "Верх": 360, "Ширина": 880, "Высота": 300, "Заголовок": "ЖУРНАЛ" })
    
    ДобавитьОбъектНаСтранице(0, "ТекстоваяОбласть", "txtLog", { "Лево": 10, "Верх": 25, "Ширина": 860, "Высота": 260, 
        "Значение": "=== ЖУРНАЛ ТЕСТИРОВАНИЯ ТАЙМЕРА ===\n\nНажмите на кнопку для запуска тестов..." }, "logGroup")
    
    ДобавитьВЛог("✅ Окно тестирования таймера создано", "success")
        ПоказатьСообщение("⏱️ ТЕСТИРОВАНИЕ КЛАССА ТАЙМЕР\n\n" +
        "Протестированные функции:\n" +
        "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n" +
        "⏱️ Периодический таймер\n" +
        "   • Создание и настройка\n" +
        "   • Запуск и остановка\n" +
        "   • 3 тика с интервалом 1 секунда\n" +
        "\n" +
        "⏱️ Однократный таймер\n" +
        "   • Срабатывание через 2 секунды\n" +
        "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n" +
        "Нажмите на кнопку для запуска тестов.\n" +
        "Результаты отображаются в журнале.")
    
    Возврат имяОкна
КонецФункции


//#КонецОбласти

//#Область Тест ОкноТестQtКонтейнеры
// ============================================================================
// ТЕСТ QtList (Список)
// ============================================================================
Функция ТестСписок() 
    ДобавитьВЛог("📋 ТЕСТ СПИСОК (QtList)", "progress")
    
    // ========== 1. СОЗДАНИЕ ==========
    Попытка
        список = Новый QtСписок()
        ДобавитьВЛог("  ✅ Список создан", "success")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка создания: " + e, "error")
        Возврат 
    КонецПопытки;
    
    // ========== 2. ДОБАВЛЕНИЕ ЭЛЕМЕНТОВ ==========
    Попытка
        список.append("Первый")
        ДобавитьВЛог("  ✅ Добавлено 1 элемент (append)", "success")
    Исключение    
        ДобавитьВЛог("  ❌ Ошибка добавления (append): " + e, "error")
    КонецПопытки;
    
    Попытка
        список.Добавить("Второй")
        список.Добавить("Третий")
        список.ДобавитьВНачало("Нулевой")
        ДобавитьВЛог("  ✅ Добавлено ещё 3 элемента (Добавить)", "success")
        ДобавитьВЛог("    Размер: " + список.Длина, "info")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка добавления (Добавить): " + e, "error")
        Возврат 
    КонецПопытки;
    
    // ========== 3. ЧТЕНИЕ ЭЛЕМЕНТОВ ==========
    Попытка
        первый = список.Первый()     //.toString()
        последний = список.Последний()   //.toString()
        второй = список.Получить(1)   //.toString()
        
        ДобавитьВЛог("  ✅ Чтение элементов:", "info")
        ДобавитьВЛог("    Первый: " + первый, "info")
        ДобавитьВЛог("    Второй: " + второй, "info")
        ДобавитьВЛог("    Последний: " + последний, "info")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка чтения: " + e, "error")
    КонецПопытки;
    
    // ========== 4. ВСТАВКА И УДАЛЕНИЕ ==========
    Попытка
        список.Вставить(2, "Вставленный")
        ДобавитьВЛог("  ✅ Вставлен элемент на позицию 2", "success")
        
        удаленный = список.ИзвлечьПервый().toString()
        ДобавитьВЛог("  ✅ Извлечен первый элемент: " + удаленный, "success")
        
        список.УдалитьПоИндексу(1)
        ДобавитьВЛог("  ✅ Удален элемент по индексу 1", "success")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка вставки/удаления: " + e, "error")
    КонецПопытки;
    
    // ========== 5. ПРЕОБРАЗОВАНИЕ ==========
    Попытка
        массив = список.ВМассив()
        строка = список.Соединить(", ")
        ДобавитьВЛог("  ✅ Преобразование:", "info")
        ДобавитьВЛог("    В строку: " + строка, "info")
        ДобавитьВЛог("    В массив: " + массив.длина + " элементов", "info")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка преобразования: " + e, "error")
    КонецПопытки;
    
    // ========== 6. ОЧИСТКА ==========
    Попытка
        список.Очистить()
    Исключение
        ДобавитьВЛог("  ❌ Ошибка очистки: " + e, "error")
    КонецПопытки;
    Попытка
        Если список.Пустой() Тогда
            ДобавитьВЛог("  ✅ Список очищен", "success")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("  ❌ Список не очищен: " + e, "error")
    КонецПопытки;
    ДобавитьВЛог("========== ТЕСТ СПИСОК ЗАВЕРШЁН ==========", "success")
КонецФункции


// ============================================================================
// ТЕСТ QtVector (Вектор)
// ============================================================================
Функция ТестВектор() 
    ДобавитьВЛог("📊 ТЕСТ ВЕКТОР (QtVector)", "progress")
    
    // ========== 1. СОЗДАНИЕ ==========
    Попытка
        вектор = Новый QtВектор()
        ДобавитьВЛог("  ✅ Вектор создан", "success")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка создания: " + e, "error")
        Возврат 
    КонецПопытки;
    
    // ========== 2. ДОБАВЛЕНИЕ ЭЛЕМЕНТОВ ==========
    Попытка
        вектор.Добавить(10)
        вектор.Добавить(20)
        вектор.Добавить(30)
        ДобавитьВЛог("  ✅ Добавлены числа (Добавить): 10, 20, 30", "success")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка добавления (Добавить): " + e, "error")
        Возврат 
    КонецПопытки;
    
    Попытка
        вектор.ДобавитьВНачало(5)
        ДобавитьВЛог("  ✅ Добавлены числа (ДобавитьВНачало): 5, 10, 20, 30", "success")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка добавления (ДобавитьВНачало): " + e, "error")
        Возврат 
    КонецПопытки;    

    Попытка
        ДобавитьВЛог("    Размер: " + вектор.Размер(), "info")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка чтения размера " + e, "error")
        Возврат 
    КонецПопытки;    

    Попытка
        ДобавитьВЛог("    Ёмкость: " + вектор.Ёмкость(), "info")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка чтения Ёмкость " + e, "error")
        Возврат 
    КонецПопытки;    


    // ========== 3. ИЗМЕНЕНИЕ РАЗМЕРА ==========
    Попытка
        вектор.ИзменитьРазмер(6)
    Исключение
        ДобавитьВЛог("  ❌ Ошибка изменения размера: " + e, "error")
    КонецПопытки;

    Попытка
        вектор.Заполнить(0, 2)  // заполнить последние 2 элемента нулями
        ДобавитьВЛог("  ✅ Размер изменён на 6", "success")
        ДобавитьВЛог("    Новый размер: " + вектор.Размер(), "info")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка (Заполнить): " + e, "error")
    КонецПопытки;

    // ========== 4. ЧТЕНИЕ И УДАЛЕНИЕ ==========
    Попытка
        первый = вектор.Первый()  
        последний = вектор.Последний() 
        третий = вектор.Получить(2)  
        
        ДобавитьВЛог("  ✅ Чтение:", "info")
        ДобавитьВЛог("    Первый: " + первый, "info")
        ДобавитьВЛог("    Третий: " + третий, "info")
        ДобавитьВЛог("    Последний: " + последний, "info")
        
        извлеченный = вектор.ИзвлечьПервый()  
        ДобавитьВЛог("  ✅ Извлечен первый элемент: " + извлеченный, "success")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка (Первый): " + e, "error")
    КонецПопытки;
    
    // ========== 5. ОЧИСТКА ==========
    Попытка
        вектор.Очистить()
        Если вектор.Пустой() Тогда
            ДобавитьВЛог("  ✅ Вектор очищен", "success")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("  ❌ Ошибка очистки: " + e, "error")
    КонецПопытки;
    
    ДобавитьВЛог("========== ТЕСТ ВЕКТОР ЗАВЕРШЁН ==========", "success")
КонецФункции


// ============================================================================
// ТЕСТ QtHash (ХешТаблица)
// ============================================================================
Функция ТестХешТаблица() 
    ДобавитьВЛог("🗂️ ТЕСТ ХЕШ-ТАБЛИЦА (QtHash)", "progress")
    
    // ========== 1. СОЗДАНИЕ ==========
    Попытка
        хеш = Новый QtХешТаблица()
        ДобавитьВЛог("  ✅ Хеш-таблица создана", "success")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка создания: " + e, "error")
        Возврат 
    КонецПопытки;
    
    // ========== 2. ВСТАВКА ЗНАЧЕНИЙ ==========
    Попытка
        хеш.Вставить("имя", "Иван")
        хеш.Вставить("возраст", 25)
        хеш.Вставить("активен", true)
        хеш.Вставить("город", "Москва")
        ДобавитьВЛог("  ✅ Вставлено 4 пары ключ-значение", "success")
        ДобавитьВЛог("    Размер: " + хеш.Размер(), "info")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка вставки: " + e, "error")
        Возврат 
    КонецПопытки;
    
    // ========== 3. ПОЛУЧЕНИЕ ЗНАЧЕНИЙ ==========
    Попытка
        имя = хеш.Получить("имя")  
        возраст = хеш.Получить("возраст")  
        активен = хеш.Получить("активен")  
        
        ДобавитьВЛог("  ✅ Получены значения:", "info")
        ДобавитьВЛог("    имя: " + имя, "info")
        ДобавитьВЛог("    возраст: " + возраст, "info")
        ДобавитьВЛог("    активен: " + (активен ? "Да" : "Нет"), "info")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка получения: " + e, "error")
    КонецПопытки;
    
    // ========== 4. ПРОВЕРКА СУЩЕСТВОВАНИЯ ==========
    Попытка
        Если хеш.Содержит("имя") Тогда
            ДобавитьВЛог("  ✅ Ключ 'имя' существует", "success")
        КонецЕсли;
        
        Если НЕ хеш.Содержит("email") Тогда
            ДобавитьВЛог("  ✅ Ключ 'email' не существует", "success")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("  ❌ Ошибка проверки: " + e, "error")
    КонецПопытки;
    
    // ========== 5. ПОЛУЧЕНИЕ КЛЮЧЕЙ И ЗНАЧЕНИЙ ==========
    Попытка
        ключи = хеш.Ключи()
        значения = хеш.Значения()
        
        ДобавитьВЛог("  ✅ Все ключи (" + ключи.длина + " шт.):", "info")
        Для i = 0 По ключи.длина - 1 Цикл
            ДобавитьВЛог("    " + ключи[i], "info")
        КонецЦикла;
    Исключение
        ДобавитьВЛог("  ❌ Ошибка: " + e, "error")
    КонецПопытки;
    
    // ========== 6. УДАЛЕНИЕ И ИЗВЛЕЧЕНИЕ ==========
    Попытка
        хеш.Удалить("город")
        ДобавитьВЛог("  ✅ Ключ 'город' удалён", "success")
        
        извлеченный = хеш.Извлечь("возраст")
        ДобавитьВЛог("  ✅ Извлечён возраст: " + извлеченный, "success")
        ДобавитьВЛог("    Новый размер: " + хеш.Размер(), "info")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка удаления: " + e, "error")
    КонецПопытки;
    
    // ========== 7. ОЧИСТКА ==========
    Попытка
        хеш.Очистить()
        Если хеш.Пустой() Тогда
            ДобавитьВЛог("  ✅ Хеш-таблица очищена", "success")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("  ❌ Ошибка очистки: " + e, "error")
    КонецПопытки;
    
    ДобавитьВЛог("========== ТЕСТ ХЕШ-ТАБЛИЦА ЗАВЕРШЁН ==========", "success")
КонецФункции


// ============================================================================
// ТЕСТ QtSet (Множество)
// ============================================================================
Функция ТестМножество() 
    ДобавитьВЛог("🔢 ТЕСТ МНОЖЕСТВО (QtSet)", "progress")
    
    // ========== 1. СОЗДАНИЕ ==========
    Попытка
        множество = Новый QtМножество()
        ДобавитьВЛог("  ✅ Множество создано", "success")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка создания: " + e, "error")
        Возврат 
    КонецПопытки;
    
    // ========== 2. ДОБАВЛЕНИЕ ЭЛЕМЕНТОВ (уникальность) ==========
    Попытка
        множество.Добавить("яблоко")
        множество.Добавить("банан")
        множество.Добавить("яблоко")  // дубликат не добавится
        множество.Добавить("апельсин")
        множество.Добавить("банан")   // дубликат не добавится
        
        ДобавитьВЛог("  ✅ Добавлены элементы: яблоко, банан, апельсин", "success")
        ДобавитьВЛог("    Размер (дубликаты проигнорированы): " + множество.Размер(), "info")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка добавления: " + e, "error")
        Возврат 
    КонецПопытки;
    
    // ========== 3. ПРОВЕРКА НАЛИЧИЯ ==========
    Попытка
        Если множество.Содержит("банан") Тогда
            ДобавитьВЛог("  ✅ Элемент 'банан' присутствует", "success")
        КонецЕсли;
        
        Если НЕ множество.Содержит("вишня") Тогда
            ДобавитьВЛог("  ✅ Элемент 'вишня' отсутствует", "success")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("  ❌ Ошибка проверки: " + e, "error")
    КонецПопытки;
    
    // ========== 4. ПОЛУЧЕНИЕ ЗНАЧЕНИЙ ==========
    Попытка
        значения = множество.Значения()
        ДобавитьВЛог("  ✅ Все элементы множества:", "info")
        Для i = 0 По значения.длина - 1 Цикл
            ДобавитьВЛог("    " + значения[i], "info")
        КонецЦикла;
    Исключение
        ДобавитьВЛог("  ❌ Ошибка: " + e, "error")
    КонецПопытки;
    
    // ========== 5. ОБЪЕДИНЕНИЕ МНОЖЕСТВ ==========
    Попытка
        множество2 = Новый QtМножество()
        множество2.Добавить("груша")
        множество2.Добавить("банан")  // уже есть
        множество2.Добавить("киви")
        
        множество.Объединить(множество2)
        ДобавитьВЛог("  ✅ Объединение с {груша, банан, киви}", "success")
        ДобавитьВЛог("    Новый размер: " + множество.Размер(), "info")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка объединения: " + e, "error")
    КонецПопытки;
    
    // ========== 6. УДАЛЕНИЕ ==========
    Попытка
        множество.Удалить("банан")
        ДобавитьВЛог("  ✅ Элемент 'банан' удалён", "success")
        ДобавитьВЛог("    Размер после удаления: " + множество.Размер(), "info")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка удаления: " + e, "error")
    КонецПопытки;
    
    // ========== 7. ОЧИСТКА ==========
    Попытка
        множество.Очистить()
        Если множество.Пустой() Тогда
            ДобавитьВЛог("  ✅ Множество очищено", "success")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("  ❌ Ошибка очистки: " + e, "error")
    КонецПопытки;
    
    ДобавитьВЛог("========== ТЕСТ МНОЖЕСТВО ЗАВЕРШЁН ==========", "success")
КонецФункции


// ============================================================================
// ТЕСТ QtQueue (Очередь)
// ============================================================================
Функция ТестОчередь() 
    ДобавитьВЛог("⏳ ТЕСТ QtОчередь (QtQueue)", "progress")
    
    // ========== 1. СОЗДАНИЕ ==========
    Попытка
        очередь = Новый QtОчередь()
        ДобавитьВЛог("  ✅ Очередь создана", "success")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка создания: " + e, "error")
        Возврат 
    КонецПопытки;
    
    // ========== 2. ДОБАВЛЕНИЕ В ОЧЕРЕДЬ (FIFO) ==========
    Попытка
        очередь.ВОчередь("Задача 1")
        очередь.ВОчередь("Задача 2")
        очередь.ВОчередь("Задача 3")
        ДобавитьВЛог("  ✅ Добавлены задачи: 1, 2, 3", "success")
        ДобавитьВЛог("    Размер очереди: " + очередь.Размер(), "info")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка добавления: " + e, "error")
        Возврат 
    КонецПопытки;
    
    // ========== 3. ПРОСМОТР ГОЛОВЫ ==========
    Попытка
        голова = очередь.Голова()
        ДобавитьВЛог("  ✅ Голова очереди (без извлечения): " + голова, "success")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка (Голова): " + e, "error")
    КонецПопытки;
    
    // ========== 4. ИЗВЛЕЧЕНИЕ ИЗ ОЧЕРЕДИ (FIFO) ==========
    Попытка
        задача1 = очередь.ИзОчереди()
        задача2 = очередь.ИзОчереди()
        
        ДобавитьВЛог("  ✅ Извлечены задачи:", "info")
        ДобавитьВЛог("    1-я: " + задача1, "info")
        ДобавитьВЛог("    2-я: " + задача2, "info")
        ДобавитьВЛог("    Осталось в очереди: " + очередь.Размер(), "info")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка извлечения: " + e, "error")
    КонецПопытки;
    
    // ========== 5. ДАЛЬНЕЙШЕЕ ИЗВЛЕЧЕНИЕ ==========
    Попытка
        задача3 = очередь.ИзОчереди()  //.toString()
        ДобавитьВЛог("  ✅ 3-я задача: " + задача3, "success")
        
        Если очередь.Пустой() Тогда
            ДобавитьВЛог("  ✅ Очередь пуста", "success")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("  ❌ Ошибка: " + e, "error")
    КонецПопытки;
    
    // ========== 6. ПРОВЕРКА НА ПУСТОТУ ==========
    Попытка
        пустое = очередь.ИзОчереди()  // Попытка извлечь из пустой очереди
        Если пустое == null Тогда
            ДобавитьВЛог("  ✅ Извлечение из пустой очереди возвращает null", "success")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("  ❌ Ошибка (Пустой): " + e, "error")
    КонецПопытки;
    
    ДобавитьВЛог("========== ТЕСТ ОЧЕРЕДЬ ЗАВЕРШЁН ==========", "success")
КонецФункции


// ============================================================================
// ТЕСТ QtStack (Стек)
// ============================================================================
Функция ТестСтек() 
    ДобавитьВЛог("📚 ТЕСТ QtСтек (QtStack)", "progress")
    
    // ========== 1. СОЗДАНИЕ ==========
    Попытка
        стек = Новый QtСтек()
        ДобавитьВЛог("  ✅ Стек создан", "success")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка создания: " + e, "error")
        Возврат 
    КонецПопытки;
    
    // ========== 2. ДОБАВЛЕНИЕ В СТЕК (LIFO) ==========
    Попытка
        стек.ВСтек("Книга 1")
        стек.ВСтек("Книга 2")
        стек.ВСтек("Книга 3")
        ДобавитьВЛог("  ✅ Добавлены книги: 1, 2, 3", "success")
        ДобавитьВЛог("    Размер стека: " + стек.Размер(), "info")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка добавления: " + e, "error")
        Возврат 
    КонецПопытки;
    
    // ========== 3. ПРОСМОТР ВЕРШИНЫ ==========
    Попытка
        вершина = стек.Вершина().toString()
        ДобавитьВЛог("  ✅ Вершина стека (без извлечения): " + вершина, "success")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка: " + e, "error")
    КонецПопытки;
    
    // ========== 4. ИЗВЛЕЧЕНИЕ ИЗ СТЕКА (LIFO) ==========
    Попытка
        книга3 = стек.ИзСтека().toString()
        книга2 = стек.ИзСтека().toString()
        
        ДобавитьВЛог("  ✅ Извлечены книги (LIFO):", "info")
        ДобавитьВЛог("    1-я: " + книга3, "info")
        ДобавитьВЛог("    2-я: " + книга2, "info")
        ДобавитьВЛог("    Осталось в стеке: " + стек.Размер(), "info")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка извлечения: " + e, "error")
    КонецПопытки;
    
    // ========== 5. ИЗВЛЕЧЕНИЕ ПОСЛЕДНЕГО ==========
    Попытка
        книга1 = стек.ИзСтека().toString()
        ДобавитьВЛог("  ✅ 3-я книга: " + книга1, "success")
        
        Если стек.Пустой() Тогда
            ДобавитьВЛог("  ✅ Стек пуст", "success")
        КонецЕсли;
    Исключение
        ДобавитьВЛог("  ❌ Ошибка: " + e, "error")
    КонецПопытки;
    
    ДобавитьВЛог("========== ТЕСТ СТЕК ЗАВЕРШЁН ==========", "success")
КонецФункции


// ============================================================================
// ТЕСТ QtVariant (Вариант)
// ============================================================================
Функция ТестВариант()
    ДобавитьВЛог("🎲 ТЕСТ QtВариант (полностью русифицированный)", "progress")
    
    // ========== 1. СОЗДАНИЕ ==========
    Попытка
        варСтрока = Новый QtВариант("Привет мир!")
        варЧисло = Новый QtВариант(42)
        варДробь = Новый QtВариант(3.14159)
        варЛогика = Новый QtВариант(Истина)
        варПустой = Новый QtВариант()
        ДобавитьВЛог("  ✅ Созданы варианты с разными типами", "success")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка создания: " + e, "error")
        Возврат
    КонецПопытки;
    
    // ========== 2. ПРОВЕРКА ПОЛУЧЕНИЯ ЗНАЧЕНИЙ ==========
    Попытка
        ДобавитьВЛог("  ✅ Проверка ПолучитьЗначение():", "info")
        ДобавитьВЛог("    варСтрока.ПолучитьЗначение(): " + варСтрока.ПолучитьЗначение(), "info")
        ДобавитьВЛог("    варЧисло.ПолучитьЗначение(): " + варЧисло.ПолучитьЗначение(), "info")
        ДобавитьВЛог("    варДробь.ПолучитьЗначение(): " + варДробь.ПолучитьЗначение(), "info")
        ДобавитьВЛог("    варЛогика.ПолучитьЗначение(): " + варЛогика.ПолучитьЗначение(), "info")
        ДобавитьВЛог("    варПустой.ПолучитьЗначение(): " + варПустой.ПолучитьЗначение(), "info")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка ПолучитьЗначение(): " + e, "error")
    КонецПопытки;
    
    // ========== 3. ПРОВЕРКА ТИПОВ ==========
    Попытка
        ДобавитьВЛог("  ✅ Типы вариантов:", "info")
        ДобавитьВЛог("    Строка: " + варСтрока.Тип(), "info")
        ДобавитьВЛог("    Число: " + варЧисло.Тип(), "info")
        ДобавитьВЛог("    Дробь: " + варДробь.Тип(), "info")
        ДобавитьВЛог("    Логика: " + варЛогика.Тип(), "info")
        ДобавитьВЛог("    Пустой: " + варПустой.Тип(), "info")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка определения типов: " + e, "error")
    КонецПопытки;
    
    // ========== 4. ПРОВЕРКА ТИПОВ МЕТОДАМИ ==========
    Попытка
        ДобавитьВЛог("  ✅ Проверка типа методами:", "info")
        ДобавитьВЛог("    варСтрока.ЭтоСтрока(): " + ВРед(варСтрока.ЭтоСтрока()), "info")
        ДобавитьВЛог("    варЧисло.ЭтоЧисло(): " + ВРед(варЧисло.ЭтоЧисло()), "info")
        ДобавитьВЛог("    варЛогика.ЭтоЛогика(): " + ВРед(варЛогика.ЭтоЛогика()), "info")
        ДобавитьВЛог("    варПустой.Пустой(): " + ВРед(варПустой.Пустой()), "info")
        ДобавитьВЛог("    варСтрока.Корректен(): " + ВРед(варСтрока.Корректен()), "info")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка проверки типов: " + e, "error")
    КонецПопытки;
    
    // ========== 5. ПРЕОБРАЗОВАНИЕ ТИПОВ (используем ПолучитьЗначение вместо ВСтроку) ==========
    Попытка
        ДобавитьВЛог("  ✅ Преобразование типов:", "info")
        // Временно используем ПолучитьЗначение() вместо ВСтроку(), так как ВСтроку возвращает строку объекта
        ДобавитьВЛог("    Число 42 -> строка: '" + варЧисло.ПолучитьЗначение() + "'", "info")
        ДобавитьВЛог("    Строка 'Привет мир!' -> число: " + варСтрока.ВЧисло(), "info")
        ДобавитьВЛог("    Число 42 -> логика: " + ВРед(варЧисло.ВЛогику()), "info")
        ДобавитьВЛог("    Дробь 3.14 -> строка: '" + варДробь.ПолучитьЗначение() + "'", "info")
        ДобавитьВЛог("    Логика Истина -> строка: '" + варЛогика.ПолучитьЗначение() + "'", "info")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка преобразования: " + e, "error")
    КонецПопытки;
    
    // ========== 6. ПРЕОБРАЗОВАНИЕ С УМОЛЧАНИЕМ (английские методы) ==========
    Попытка
        ДобавитьВЛог("  ✅ Преобразование с умолчанием (англ.):", "info")
        ДобавитьВЛог("    Пустой -> число по умолчанию: " + варПустой.toIntOrDefault(999), "info")
        ДобавитьВЛог("    Пустой -> строка по умолчанию: '" + варПустой.toStringOrDefault("значение по умолчанию") + "'", "info")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка: " + e, "error")
    КонецПопытки;
    
    // ========== 7. УСТАНОВКА НОВОГО ЗНАЧЕНИЯ ==========
    Попытка
        варПустой.УстановитьЗначение("Новое значение")
        ДобавитьВЛог("  ✅ Установлено новое значение: " + варПустой.ПолучитьЗначение(), "success")
    Исключение
        ДобавитьВЛог("  ❌ Ошибка установки значения: " + e, "error")
    КонецПопытки;
    
    // ========== 8. ДОПОЛНИТЕЛЬНЫЕ ПРОВЕРКИ ==========
    Попытка
        ДобавитьВЛог("  ✅ Дополнительные проверки:", "info")
        
        // Изменение значения
        варЧисло.УстановитьЗначение(100)
        ДобавитьВЛог("    varЧисло.УстановитьЗначение(100) -> значение: " + варЧисло.ПолучитьЗначение(), "info")
        
        // Проверка после изменения
        ДобавитьВЛог("    varЧисло.ЭтоЧисло(): " + ВРед(варЧисло.ЭтоЧисло()), "info")
        ДобавитьВЛог("    varЧисло.Тип(): " + варЧисло.Тип(), "info")
        
        // Работа с логикой
        варЛогика.УстановитьЗначение(Ложь)
        ДобавитьВЛог("    varЛогика.УстановитьЗначение(Ложь) -> ВЛогику(): " + ВРед(варЛогика.ВЛогику()), "info")
        ДобавитьВЛог("    varЛогика.ПолучитьЗначение(): " + варЛогика.ПолучитьЗначение(), "info")
        
    Исключение
        ДобавитьВЛог("  ❌ Ошибка: " + e, "error")
    КонецПопытки;
    
    ДобавитьВЛог("========== ТЕСТ QtВариант УСПЕШНО ЗАВЕРШЁН ==========", "success")
КонецФункции

// Вспомогательная функция для форматирования Да/Нет
Функция ВРед(значение)
    Если значение = Истина Тогда
        Возврат "Да"
    Иначе
        Возврат "Нет"
    КонецЕсли;
КонецФункции


// ============================================================================
// ЗАПУСК ВСЕХ ТЕСТОВ КОНТЕЙНЕРОВ
// ============================================================================
Функция ЗапуститьВсеТестыКонтейнеров() 
    ДобавитьВЛог("🚀 ЗАПУСК ВСЕХ ТЕСТОВ КОНТЕЙНЕРОВ", "progress")
    ДобавитьВЛог("=========================================", "info")
    
    ТестСписок()
    Пауза(500)
    ТестВектор()
    Пауза(500)
    ТестХешТаблица()
    Пауза(500)
    ТестМножество()
    Пауза(500)
    ТестОчередь()
    Пауза(500)
    ТестСтек()
    Пауза(500)
    ТестВариант()
    //Пауза(500)
    
    ДобавитьВЛог("=========================================", "info")
    ДобавитьВЛог("✅ ВСЕ ТЕСТЫ КОНТЕЙНЕРОВ ЗАВЕРШЕНЫ", "success")
    ПоказатьСообщение("✅ Все тесты контейнеров успешно завершены!\n\n" +
        "Протестированы:\n" +
        "• QtList (Список)\n" +
        "• QtVector (Вектор)\n" +
        "• QtHash (ХешТаблица)\n" +
        "• QtSet (Множество)\n" +
        "• QtQueue (Очередь)\n" +
        "• QtStack (Стек)\n" +
        "• QtVariant (Вариант)\n\n" +
        "Результаты в журнале.")
КонецФункции


// ============================================================================
// ОБНОВЛЁННОЕ СОЗДАНИЕ ОКНА С ТЕСТАМИ
// ============================================================================
Функция СоздатьОкноТестQtКонтейнеры() 
    Пусть имяОкна = "ОкноТестQtКонтейнеры"
    СоздатьПодокноMDI(Глоб_mdi, имяОкна, 10, 10, 1050, 725)
    СоздатьВкладки("ВкладкиТестыКонтейнеры", { "Лево": 10, "Верх": 5, "Ширина": 1020, "Высота": 680, "Вкладки": "Контейнеры" }, имяОкна)
    
    ДобавитьНаВкладку("ВкладкиТестыКонтейнеры", 0, "Группа", "testButtonsGroup", { "Лево": 20, "Верх": 10, "Ширина": 980, "Высота": 170, "Заголовок": "ТЕСТЫ КОНТЕЙНЕРНЫХ КЛАССОВ Qt" })
    
    ДобавитьОбъектНаСтранице(0, "Кнопка", "btnRunAllTests", { "Лево": 30, "Верх": 30, "Ширина": 220, "Высота": 45, "Заголовок": "📋 ТЕСТ СПИСОК" }, "testButtonsGroup")
        ПриНажатииКнопки("btnRunAllTests", function() { ОчиститьЛог();  ТестСписок() })
    ДобавитьОбъектНаСтранице(0, "Кнопка", "btnRunVector", { "Лево": 260, "Верх": 30, "Ширина": 220, "Высота": 45, "Заголовок": "📊 ТЕСТ ВЕКТОР" }, "testButtonsGroup")
        ПриНажатииКнопки("btnRunVector", function() { ОчиститьЛог(); ТестВектор() })
    ДобавитьОбъектНаСтранице(0, "Кнопка", "btnRunHash", { "Лево": 490, "Верх": 30, "Ширина": 220, "Высота": 45, "Заголовок": "🗂️ ТЕСТ ХЕШ-ТАБЛИЦА" }, "testButtonsGroup")
        ПриНажатииКнопки("btnRunHash", function() { ОчиститьЛог(); ТестХешТаблица() })
    ДобавитьОбъектНаСтранице(0, "Кнопка", "btnRunSet", { "Лево": 720, "Верх": 30, "Ширина": 220, "Высота": 45, "Заголовок": "🔢 ТЕСТ МНОЖЕСТВО" }, "testButtonsGroup")
        ПриНажатииКнопки("btnRunSet", function() { ОчиститьЛог(); ТестМножество() })
        
    ДобавитьОбъектНаСтранице(0, "Кнопка", "btnRunQueue", { "Лево": 30, "Верх": 100, "Ширина": 150, "Высота": 45, "Заголовок": "⏳ ТЕСТ ОЧЕРЕДЬ" }, "testButtonsGroup")
        ПриНажатииКнопки("btnRunQueue", function() { ОчиститьЛог(); ТестОчередь() })
    ДобавитьОбъектНаСтранице(0, "Кнопка", "btnRunStack", { "Лево": 190, "Верх": 100, "Ширина": 150, "Высота": 45, "Заголовок": "📚 ТЕСТ СТЕК" }, "testButtonsGroup")
        ПриНажатииКнопки("btnRunStack", function() { ОчиститьЛог(); ТестСтек() })
    ДобавитьОбъектНаСтранице(0, "Кнопка", "btnRunVariant", { "Лево": 360, "Верх": 100, "Ширина": 150, "Высота": 45, "Заголовок": "🎲 ТЕСТ ВАРИАНТ" }, "testButtonsGroup")
        ПриНажатииКнопки("btnRunVariant", function() { ОчиститьЛог(); ТестВариант() })
    ДобавитьОбъектНаСтранице(0, "Кнопка", "btnRunAll", { "Лево": 530, "Верх": 100, "Ширина": 200, "Высота": 50, "Заголовок": "🚀 ЗАПУСТИТЬ ВСЕ ТЕСТЫ" }, "testButtonsGroup")
        ПриНажатииКнопки("btnRunAll", function() { ОчиститьЛог(); ЗапуститьВсеТестыКонтейнеров() })
    ДобавитьОбъектНаСтранице(0, "Кнопка", "btnClearLog", { "Лево": 750, "Верх": 100, "Ширина": 150, "Высота": 50, "Заголовок": "🗑️ ОЧИСТИТЬ ЛОГ" }, "testButtonsGroup")
        ПриНажатииКнопки("btnClearLog", function() { ОчиститьЛог() })
        
    
    // Группа информации
    ДобавитьНаВкладку("ВкладкиТестыКонтейнеры", 0, "Группа", "infoGroup", { "Лево": 20, "Верх": 190, "Ширина": 980, "Высота": 130, "Заголовок": "ИНФОРМАЦИЯ" })
    ДобавитьОбъектНаСтранице(0, "Надпись", "lblInfo", { "Лево": 30, "Верх": 25, "Ширина": 950, "Высота": 100, 
        "Заголовок": "Тестирование контейнерных классов Qt:\n" +
        "• Список - динамический массив с добавлением/удалением\n" +
        "• Вектор - массив с изменяемым размером\n" +
        "• ХешТаблица - ассоциативный массив (ключ-значение)\n" +
        "• Множество - набор уникальных элементов\n" +
        "• Очередь - FIFO (первый вошёл - первый вышел)\n" +
        "• Стек - LIFO (последний вошёл - первый вышел)\n" +
        "• Вариант - универсальный тип для любых данных" 
    }, "infoGroup")
    
    // Группа результатов (лог)
    ДобавитьНаВкладку("ВкладкиТестыКонтейнеры", 0, "Группа", "logGroup", { "Лево": 20, "Верх": 330, "Ширина": 980, "Высота": 320, "Заголовок": "ЖУРНАЛ" })
    ДобавитьОбъектНаСтранице(0, "ТекстоваяОбласть", "txtLog", { "Лево": 10, "Верх": 25, "Ширина": 960, "Высота": 290, 
        "Значение": "=== ЖУРНАЛ ТЕСТИРОВАНИЯ КОНТЕЙНЕРОВ ===\n\nНажмите на кнопку для запуска тестов..." }, "logGroup")
    
    //ДобавитьВЛог("✅ Окно тестирования контейнеров создано", "success")
   ПоказатьСообщение("🎲 ТЕСТИРОВАНИЕ КОНТЕЙНЕРНЫХ КЛАССОВ Qt\n\n" +
        "Протестированные контейнеры:\n" +
        "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n" +
        "📋 Список (QtList)\n" +
        "   • Добавление, вставка, удаление элементов\n" +
        "   • Доступ по индексу, преобразование в массив/строку\n" +
        "\n" +
        "📊 Вектор (QtVector)\n" +
        "   • Динамический массив с изменяемым размером\n" +
        "   • Резервирование памяти, заполнение значениями\n" +
        "\n" +
        "🗂️ ХешТаблица (QtHash)\n" +
        "   • Ассоциативный массив (ключ-значение)\n" +
        "   • Получение ключей, значений, проверка существования\n" +
        "\n" +
        "🔢 Множество (QtSet)\n" +
        "   • Уникальные элементы, объединение множеств\n" +
        "\n" +
        "⏳ Очередь (QtQueue)\n" +
        "   • FIFO: первый вошёл - первый вышел\n" +
        "\n" +
        "📚 Стек (QtStack)\n" +
        "   • LIFO: последний вошёл - первый вышел\n" +
        "\n" +
        "🎲 Вариант (QtVariant)\n" +
        "   • Универсальный тип для любых данных\n" +
        "   • Преобразование типов, проверка корректности\n" +
        "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n" +
        "Нажмите на кнопку для запуска тестов.\n" +
        "Результаты отображаются в журнале.")    
    Возврат имяОкна
КонецФункции


//#КонецОбласти
