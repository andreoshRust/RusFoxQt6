Функция ДобавитьВТестЛог(сообщение, тип)
    Пусть время = ТекущееВремя("HH:MM:SS")
    Пусть префикс = ""
    
    Если тип == "info" Тогда префикс = "ℹ️"
    ИначеЕсли тип == "success" Тогда префикс = "✅"
    ИначеЕсли тип == "error" Тогда префикс = "❌"
    ИначеЕсли тип == "warning" Тогда префикс = "⚠️"
    Иначе префикс = "📌"
    КонецЕсли;
    
    Пусть строкаЛога = "[" + время + "] " + префикс + " " + сообщение
    
    Если ПустаяСтрока(Глоб_ТестБуфер) Тогда
        Глоб_ТестБуфер = строкаЛога
    Иначе
        Глоб_ТестБуфер = Глоб_ТестБуфер + "\n" + строкаЛога
    КонецЕсли;
    
    Если СтрДлина(Глоб_ТестБуфер) > 50000 Тогда
        Глоб_ТестБуфер = Прав(Глоб_ТестБуфер, 50000)
    КонецЕсли;
    
    УстановитьТекст("txtTestLog", Глоб_ТестБуфер)
    Сообщить(строкаЛога)
КонецФункции

