Функция ТестироватьВебСервер()
    ДобавитьВТестЛог("🧪 НАЧАЛО ТЕСТИРОВАНИЯ ВЕБ-СЕРВЕРА", "info")
    
    Пусть функцииДляПроверки = [
        "Ping",
        "CreateJob",
        "CreateReportFromData",
        "ExecuteMacro",
        "ExecuteMacroInJob",
        "SaveJob",
        "CloseJob",
        "GetActiveJobs",
        "GetJobInfo"
    ]
    
    Пусть работает = 0
    Пусть всего = функцииДляПроверки.длина
    
    Для i = 0 По всего - 1 Цикл
        Пусть имяФункции = функцииДляПроверки[i]
        Попытка
            Пусть результат = ВызватьФункциюСервера(имяФункции, [])
            
            Если результат.indexOf("SUCCESS") >= 0 ИЛИ результат.indexOf("OK") >= 0 Тогда
                ДобавитьВТестЛог("  ✅ " + имяФункции + " - ДОСТУПНА", "success")
                работает = работает + 1
            ИначеЕсли результат.indexOf("not found") >= 0 Тогда
                ДобавитьВТестЛог("  ❌ " + имяФункции + " - НЕ СУЩЕСТВУЕТ", "error")
            ИначеЕсли результат.indexOf("ERROR") >= 0 Тогда
                ДобавитьВТестЛог("  ⚠️ " + имяФункции + " - ОШИБКА (требует параметры)", "warning")
                работает = работает + 1
            Иначе
                ДобавитьВТестЛог("  ✅ " + имяФункции + " - ДОСТУПНА", "success")
                работает = работает + 1
            КонецЕсли;
        Исключение
            ДобавитьВТестЛог("  ❌ " + имяФункции + " - ОШИБКА: " + e, "error")
        КонецПопытки;
    КонецЦикла;
    
    ДобавитьВТестЛог("📊 ИТОГО: доступно " + работает + " из " + всего + " функций", "info")
    
    УстановитьТекст("lblTestResult", "Диагностика завершена. Доступно " + работает + " из " + всего + " функций")
    
    Если работает == всего Тогда
        УстановитьСтиль("lblTestResult", "color: #2ecc71; font-weight: bold;")
        ДобавитьВТестЛог("✅ ВСЕ ФУНКЦИИ ДОСТУПНЫ", "success")
    Иначе
        УстановитьСтиль("lblTestResult", "color: #ffaa00; font-weight: bold;")
        ДобавитьВТестЛог("⚠️ НЕКОТОРЫЕ ФУНКЦИИ НЕДОСТУПНЫ", "warning")
    КонецЕсли;
КонецФункции

Функция ПроверитьПрямыеGET()
    ДобавитьВТестЛог("🔍 ПРОВЕРКА ПРЯМЫХ GET ЗАПРОСОВ", "info")
    
    Попытка
        Пусть пингРезультат = СинхронныйGET("http://localhost:8080/ping")
        ДобавитьВТестЛог("GET /ping: '" + пингРезультат + "'", 
            пингРезультат == "OK" ? "success" : "warning")
    Исключение
        ДобавитьВТестЛог("GET /ping: ОШИБКА - " + e, "error")
    КонецПопытки
    
    Попытка
        Пусть статусРезультат = СинхронныйGET("http://localhost:8080/status")
        ДобавитьВТестЛог("GET /status: '" + статусРезультат + "'", "info")
    Исключение
        ДобавитьВТестЛог("GET /status: ОШИБКА - " + e, "error")
    КонецПопытки
КонецФункции

Функция ТестСозданияЗадания()
    ДобавитьВТестЛог("🔧 ТЕСТ СОЗДАНИЯ ЗАДАНИЯ", "info")
    
    Попытка
        Пусть jobResponse = ВызватьФункциюСервера("CreateJob", [])
        ДобавитьВТестЛог("CreateJob: " + jobResponse, "macro")
        
        Если jobResponse.длина > 0 Тогда
            Попытка
                Пусть jobInfo = JSON_ИзСтроки(jobResponse)
                Если jobInfo.status == "SUCCESS" Тогда
                    Пусть jobId = jobInfo.job_id
                    ДобавитьВТестЛог("✅ Задание создано: " + jobId, "success")
                КонецЕсли;
            Исключение
                ДобавитьВТестЛог("Ошибка парсинга JSON: " + e, "error")
            КонецПопытки
        КонецЕсли;
    Исключение
        ДобавитьВТестЛог("CreateJob ошибка: " + e, "error")
    КонецПопытки
КонецФункции

