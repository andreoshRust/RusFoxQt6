        ВывестиСтрокуВКонсоль("  ✓ Колбэк был вызван")
    Иначе
        ВывестиСтрокуВКонсоль("  ❌ Колбэк НЕ был вызван")
        тестПройден = ЛОЖЬ
    КонецЕсли;
    
