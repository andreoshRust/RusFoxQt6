        Иначе
            ВывестиСтрокуВКонсоль("  ❌ Колбэк получил некорректную ошибку: " + ошибка)
            тестПройден = ЛОЖЬ
        КонецЕсли;
    }
    
    Попытка
        тестЗапросы.ОтправитьКоманду("test-session", "/help", тестКолбэк3)
        ВывестиСтрокуВКонсоль("  ОтправитьКоманду('/help') вызван")
    Исключение
        ВывестиСтрокуВКонсоль("  ✗ ОШИБКА при ОтправитьКоманду(): " + e)
        тестПройден = ЛОЖЬ
    КонецПопытки;
    
    Пауза(100)
    
    Если колбэкВызван3 Тогда
        ВывестиСтрокуВКонсоль("  ✓ Колбэк был вызван")
    Иначе
        ВывестиСтрокуВКонсоль("  ❌ Колбэк НЕ был вызван")
        тестПройден = ЛОЖЬ
    КонецЕсли;
    
    Если тестПройден Тогда
        успешноТестов = успешноТестов + 1
    КонецЕсли;
    ВывестиСтрокуВКонсоль("")

    // ========== 7. ТЕСТ ПОЛУЧЕНИЯ СТАТУСА ==========
    УстановитьЦветКонсоли("yellow")
    ВывестиСтрокуВКонсоль("┌────────────────────────────────────────────────────────────────────────────────┐")
    ВывестиСтрокуВКонсоль("│ 7. ТЕСТ ПОЛУЧЕНИЯ СТАТУСА                                                   │")
    ВывестиСтрокуВКонсоль("└────────────────────────────────────────────────────────────────────────────────┘")
    СброситьЦветКонсоли()
    
    всегоТестов = всегоТестов + 1
    тестПройден = ИСТИНА
    колбэкВызван4 = ЛОЖЬ
    
    тестКолбэк4 = Функция(успешно, ошибка, результат) {
        колбэкВызван4 = ИСТИНА
        ВывестиСтрокуВКонсоль("  Колбэк вызван: успешно=" + успешно + ", ошибка=" + ошибка)
        Если успешно == false И ошибка == "Not connected to gateway" Тогда
            ВывестиСтрокуВКонсоль("  ✓ Колбэк получил корректную ошибку")
        Иначе
            ВывестиСтрокуВКонсоль("  ❌ Колбэк получил некорректную ошибку: " + ошибка)
            тестПройден = ЛОЖЬ
        КонецЕсли;
    }
    
    Попытка
        тестЗапросы.ПолучитьСтатус("test-session", тестКолбэк4)
        ВывестиСтрокуВКонсоль("  ПолучитьСтатус() вызван")
    Исключение
        ВывестиСтрокуВКонсоль("  ✗ ОШИБКА при ПолучитьСтатус(): " + e)
        тестПройден = ЛОЖЬ
    КонецПопытки;
    
    Пауза(100)
    
