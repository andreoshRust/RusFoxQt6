        Иначе
            ВывестиСтрокуВКонсоль("  ❌ Колбэк получил некорректную ошибку: " + ошибка)
            тестПройден = ЛОЖЬ
        КонецЕсли;
    }
    
    Попытка
        тестЗапросы.ОтправитьФоновыйЗапрос("test-session", "test message", тестКолбэк2)
        ВывестиСтрокуВКонсоль("  ОтправитьФоновыйЗапрос() вызван")
    Исключение
        ВывестиСтрокуВКонсоль("  ✗ ОШИБКА при ОтправитьФоновыйЗапрос(): " + e)
        тестПройден = ЛОЖЬ
    КонецПопытки;
    
    Пауза(100)
    
    Если колбэкВызван2 Тогда
        ВывестиСтрокуВКонсоль("  ✓ Колбэк был вызван")
    Иначе
        ВывестиСтрокуВКонсоль("  ❌ Колбэк НЕ был вызван")
        тестПройден = ЛОЖЬ
    КонецЕсли;
    
    Если тестПройден Тогда
        успешноТестов = успешноТестов + 1
    КонецЕсли;
    ВывестиСтрокуВКонсоль("")

    // ========== 5. ТЕСТ ПРЕРЫВАНИЯ ОТВЕТА ==========
    УстановитьЦветКонсоли("yellow")
    ВывестиСтрокуВКонсоль("┌────────────────────────────────────────────────────────────────────────────────┐")
    ВывестиСтрокуВКонсоль("│ 5. ТЕСТ ПРЕРЫВАНИЯ ОТВЕТА                                                   │")
    ВывестиСтрокуВКонсоль("└────────────────────────────────────────────────────────────────────────────────┘")
    СброситьЦветКонсоли()
    
    всегоТестов = всегоТестов + 1
    тестПройден = ИСТИНА
    
    Попытка
        тестЗапросы.ПрерватьОтвет("test-session")
        ВывестиСтрокуВКонсоль("  ✓ ПрерватьОтвет() выполнен без ошибок")
    Исключение
        ВывестиСтрокуВКонсоль("  ✗ ОШИБКА при ПрерватьОтвет(): " + e)
        тестПройден = ЛОЖЬ
    КонецПопытки;
    
    Если тестПройден Тогда
        успешноТестов = успешноТестов + 1
    КонецЕсли;
    ВывестиСтрокуВКонсоль("")

    // ========== 6. ТЕСТ ОТПРАВКИ КОМАНДЫ ==========
    УстановитьЦветКонсоли("yellow")
    ВывестиСтрокуВКонсоль("┌────────────────────────────────────────────────────────────────────────────────┐")
    ВывестиСтрокуВКонсоль("│ 6. ТЕСТ ОТПРАВКИ КОМАНДЫ                                                   │")
    ВывестиСтрокуВКонсоль("└────────────────────────────────────────────────────────────────────────────────┘")
    СброситьЦветКонсоли()
    
    всегоТестов = всегоТестов + 1
    тестПройден = ИСТИНА
    колбэкВызван3 = ЛОЖЬ
    
    тестКолбэк3 = Функция(успешно, ошибка, результат) {
        колбэкВызван3 = ИСТИНА
        ВывестиСтрокуВКонсоль("  Колбэк вызван: успешно=" + успешно + ", ошибка=" + ошибка)
