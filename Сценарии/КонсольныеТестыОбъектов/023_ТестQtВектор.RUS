    ВывестиСтрокуВКонсоль("┌────────────────────────────────────────────────────────────────────────────────┐")
    ВывестиСтрокуВКонсоль("│ 16. ТЕСТ reserve() / Зарезервировать() и capacity() / Ёмкость()                │")
    ВывестиСтрокуВКонсоль("└────────────────────────────────────────────────────────────────────────────────┘")
    СброситьЦветКонсоли()
    
    всегоТестов = всегоТестов + 1
    Попытка
        в14 = Новый QtВектор()
        ёмкость1 = в14.capacity()
        ВывестиСтрокуВКонсоль("  Исходная ёмкость = " + ёмкость1)
        
        в14.reserve(10)
        ёмкость2 = в14.capacity()
        ВывестиСтрокуВКонсоль("  reserve(10) -> capacity = " + ёмкость2 + " (ожидается >= 10)")
        
        в14.Зарезервировать(20)
        ёмкость3 = в14.capacity()
        ВывестиСтрокуВКонсоль("  Зарезервировать(20) -> capacity = " + ёмкость3 + " (ожидается >= 20)")
        
        Если ёмкость2 >= 10 И ёмкость3 >= 20 Тогда
            ВывестиСтрокуВКонсоль("  ✓ reserve() / Зарезервировать() и capacity() / Ёмкость() работают корректно")
            успешноТестов = успешноТестов + 1
        Иначе
            ВывестиСтрокуВКонсоль("  ❌ reserve() / Зарезервировать() и capacity() / Ёмкость() работают некорректно")
