        в9.append("Второй")
        в9.append("Третий")
        в9.append("Четвертый")
        
        извлечПервый = в9.takeFirst()
        извлечПоследний = в9.ИзвлечьПоследний()
        размер = в9.size
        первый = в9.first()
        последний = в9.last()
        
        ВывестиСтрокуВКонсоль("  takeFirst() = " + извлечПервый.toString() + " (ожидается Первый)")
        ВывестиСтрокуВКонсоль("  ИзвлечьПоследний() = " + извлечПоследний.toString() + " (ожидается Четвертый)")
        ВывестиСтрокуВКонсоль("  first() = " + первый.toString() + " (ожидается Второй)")
        ВывестиСтрокуВКонсоль("  last() = " + последний.toString() + " (ожидается Третий)")
        ВывестиСтрокуВКонсоль("  size = " + размер + " (ожидается 2)")
        
