    СброситьЦветКонсоли()
    
    всегоТестов = всегоТестов + 1
    Попытка
        в12 = Новый QtВектор()
        в12.append("A")
        в12.append("B")
        в12.append("C")
        
        в12.fill("X")
        эл0 = в12.at(0)
        эл1 = в12.at(1)
        эл2 = в12.at(2)
        размер = в12.size
        
        ВывестиСтрокуВКонсоль("  fill('X')")
        ВывестиСтрокуВКонсоль("  at(0) = " + эл0.toString() + " (ожидается X)")
        ВывестиСтрокуВКонсоль("  at(1) = " + эл1.toString() + " (ожидается X)")
        ВывестиСтрокуВКонсоль("  at(2) = " + эл2.toString() + " (ожидается X)")
        ВывестиСтрокуВКонсоль("  size = " + размер + " (ожидается 3)")
        
        в12.Заполнить("Z", 2)
        эл0_2 = в12.at(0)
        эл1_2 = в12.at(1)
        размер2 = в12.size
        ВывестиСтрокуВКонсоль("  Заполнить('Z', 2)")
        ВывестиСтрокуВКонсоль("  at(0) = " + эл0_2.toString() + " (ожидается Z)")
        ВывестиСтрокуВКонсоль("  at(1) = " + эл1_2.toString() + " (ожидается Z)")
        ВывестиСтрокуВКонсоль("  size = " + размер2 + " (ожидается 2)")
        
        Если эл0.toString() == "X" И эл1.toString() == "X" И эл2.toString() == "X" И размер == 3 И эл0_2.toString() == "Z" И эл1_2.toString() == "Z" И размер2 == 2 Тогда
            ВывестиСтрокуВКонсоль("  ✓ fill() / Заполнить() работают корректно")
            успешноТестов = успешноТестов + 1
        Иначе
            ВывестиСтрокуВКонсоль("  ❌ fill() / Заполнить() работают некорректно")
        КонецЕсли;
    Исключение
        ВывестиСтрокуВКонсоль("  ✗ ОШИБКА при заполнении вектора: " + e)
