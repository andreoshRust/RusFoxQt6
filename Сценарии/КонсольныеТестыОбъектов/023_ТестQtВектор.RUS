    ВывестиСтрокуВКонсоль("└────────────────────────────────────────────────────────────────────────────────┘")
    СброситьЦветКонсоли()
    
    всегоТестов = всегоТестов + 1
    Попытка
        в16 = Новый QtВектор()
        в16.append(42)
        в16.append("Строка")
        в16.append(true)
        в16.append(3.14)
        
        эл0 = в16.at(0)
        эл1 = в16.at(1)
        эл2 = в16.at(2)
        эл3 = в16.at(3)
        размер = в16.size
        
        ВывестиСтрокуВКонсоль("  at(0) = " + эл0.toString() + " (ожидается 42)")
