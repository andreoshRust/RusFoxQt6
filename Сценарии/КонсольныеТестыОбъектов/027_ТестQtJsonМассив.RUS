    тестПройден = ИСТИНА
    
    Попытка
        кол = а1.Размер()
        ВывестиСтрокуВКонсоль("  Размер() = " + кол + " (ожидается 0)")
        Если кол == 0 Тогда
            ВывестиСтрокуВКонсоль("  ✓ Массив пустой (Размер = 0)")
        Иначе
            ВывестиСтрокуВКонсоль("  ❌ Массив не пустой (Размер = " + кол + ")")
            тестПройден = ЛОЖЬ
        КонецЕсли;
    Исключение
        ВывестиСтрокуВКонсоль("  ✗ ОШИБКА при Размер(): " + e)
        тестПройден = ЛОЖЬ
    КонецПопытки;
    
    Если тестПройден И кол == 0 Тогда
        успешноТестов = успешноТестов + 1
