    ДиагностикаМетодов()
    
    // ========== ТЕСТ QtJsonArray ==========
    УстановитьЦветКонсоли("cyan")
    ВывестиСтрокуВКонсоль("╔════════════════════════════════════════════════════════════════════════════════╗")
    ВывестиСтрокуВКонсоль("║                     ТЕСТИРОВАНИЕ QtJsonМассив (QtJsonArray)                     ║")
