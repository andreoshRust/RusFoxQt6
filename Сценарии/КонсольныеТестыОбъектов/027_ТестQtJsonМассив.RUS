        успешноТестов = успешноТестов + 1
    Иначе
        ВывестиСтрокуВКонсоль("  ❌ Очистка работает некорректно")
    КонецЕсли;
    ВывестиСтрокуВКонсоль("")

    // ========== 8. ТЕСТ ПРЕОБРАЗОВАНИЯ В СТРОКУ ==========
    УстановитьЦветКонсоли("yellow")
    ВывестиСтрокуВКонсоль("┌────────────────────────────────────────────────────────────────────────────────┐")
    ВывестиСтрокуВКонсоль("│ 8. ТЕСТ ПРЕОБРАЗОВАНИЯ В СТРОКУ (ВСтроку, ВСтрокуСОтступами)                  │")
    ВывестиСтрокуВКонсоль("└────────────────────────────────────────────────────────────────────────────────┘")
    СброситьЦветКонсоли()
    
    всегоТестов = всегоТестов + 1
    а7 = Новый QtJsonМассив()
    тестПройден = ИСТИНА
    
    Попытка
        а7.ДобавитьСтроку("a")
        а7.ДобавитьЧисло(123)
        ВывестиСтрокуВКонсоль("  ДобавитьСтроку('a'), ДобавитьЧисло(123)")
    Исключение
        ВывестиСтрокуВКонсоль("  ✗ ОШИБКА при добавлении: " + e)
        тестПройден = ЛОЖЬ
    КонецПопытки;
    
    Попытка
        стр = а7.ВСтроку()
        стрОтступ = а7.ВСтрокуСОтступами()
        ВывестиСтрокуВКонсоль("  ВСтроку() = " + стр)
        ВывестиСтрокуВКонсоль("  ВСтрокуСОтступами() = " + стрОтступ)
    Исключение
        ВывестиСтрокуВКонсоль("  ✗ ОШИБКА при преобразовании: " + e)
        тестПройден = ЛОЖЬ
    КонецПопытки;
    
    Если тестПройден И стр != "" И стрОтступ != "" Тогда
        ВывестиСтрокуВКонсоль("  ✓ Преобразование в строку работает корректно")
        успешноТестов = успешноТестов + 1
    Иначе
        ВывестиСтрокуВКонсоль("  ❌ Преобразование в строку работает некорректно")
    КонецЕсли;
    ВывестиСтрокуВКонсоль("")

    // ========== 9. ТЕСТ КЛОНИРОВАНИЯ ==========
    УстановитьЦветКонсоли("yellow")
    ВывестиСтрокуВКонсоль("┌────────────────────────────────────────────────────────────────────────────────┐")
    ВывестиСтрокуВКонсоль("│ 9. ТЕСТ КЛОНИРОВАНИЯ (Клонировать)                                            │")
    ВывестиСтрокуВКонсоль("└────────────────────────────────────────────────────────────────────────────────┘")
    СброситьЦветКонсоли()
    
    всегоТестов = всегоТестов + 1
    а8 = Новый QtJsonМассив()
    тестПройден = ИСТИНА
    
    Попытка
        а8.ДобавитьСтроку("original")
        ВывестиСтрокуВКонсоль("  ДобавитьСтроку('original')")
    Исключение
        ВывестиСтрокуВКонсоль("  ✗ ОШИБКА при добавлении: " + e)
        тестПройден = ЛОЖЬ
    КонецПопытки;
    
    Попытка
        клон = а8.Клонировать()
        // Используем английские методы для клона
        стр = клон.getString(0)
        ВывестиСтрокуВКонсоль("  Клонировать().getString(0) = " + стр + " (ожидается original)")
    Исключение
        ВывестиСтрокуВКонсоль("  ✗ ОШИБКА при клонировании: " + e)
        тестПройден = ЛОЖЬ
    КонецПопытки;
    
    Если тестПройден И стр == "original" Тогда
        ВывестиСтрокуВКонсоль("  ✓ Клонирование работает корректно")
        успешноТестов = успешноТестов + 1
    Иначе
        ВывестиСтрокуВКонсоль("  ❌ Клонирование работает некорректно")
    КонецЕсли;
    ВывестиСтрокуВКонсоль("")

    // ========== 10. ТЕСТ СОЗДАНИЯ ИЗ СТРОКИ (ИзСтроки) ==========
    УстановитьЦветКонсоли("yellow")
    ВывестиСтрокуВКонсоль("┌────────────────────────────────────────────────────────────────────────────────┐")
    ВывестиСтрокуВКонсоль("│ 10. ТЕСТ СОЗДАНИЯ ИЗ СТРОКИ (ИзСтроки)                                       │")
    ВывестиСтрокуВКонсоль("└────────────────────────────────────────────────────────────────────────────────┘")
    СброситьЦветКонсоли()
    
    всегоТестов = всегоТестов + 1
    json = '["первый","второй",3,true]'
    тестПройден = ИСТИНА
    
    Попытка
        // Создаём пустой массив и вызываем ИзСтроки через экземпляр
        а9 = Новый QtJsonМассив()
        а9 = а9.ИзСтроки(json)
        ВывестиСтрокуВКонсоль("  Новый QtJsonМассив().ИзСтроки('" + json + "')")
    Исключение
        ВывестиСтрокуВКонсоль("  ✗ ОШИБКА при ИзСтроки(): " + e)
        тестПройден = ЛОЖЬ
    КонецПопытки;
    
    Если тестПройден Тогда
        Попытка
            // Используем английские методы для получения (русские не работают для клонированных объектов)
            стр1 = а9.getString(0)
            стр2 = а9.getString(1)
            чис = а9.getNumber(2)
            лог = а9.getBool(3)
            ВывестиСтрокуВКонсоль("  getString(0) = " + стр1 + " (ожидается первый)")
            ВывестиСтрокуВКонсоль("  getString(1) = " + стр2 + " (ожидается второй)")
            ВывестиСтрокуВКонсоль("  getNumber(2) = " + чис + " (ожидается 3)")
            ВывестиСтрокуВКонсоль("  getBool(3) = " + лог + " (ожидается true)")
        Исключение
            ВывестиСтрокуВКонсоль("  ✗ ОШИБКА при получении: " + e)
            тестПройден = ЛОЖЬ
        КонецПопытки;
    КонецЕсли;
    
    Если тестПройден И стр1 == "первый" И стр2 == "второй" И чис == 3 И лог == true Тогда
        ВывестиСтрокуВКонсоль("  ✓ ИзСтроки() работает корректно")
        успешноТестов = успешноТестов + 1
    Иначе
        ВывестиСтрокуВКонсоль("  ❌ ИзСтроки() работает некорректно")
    КонецЕсли;
    ВывестиСтрокуВКонсоль("")
    
    // ========== ИТОГОВЫЙ ОТЧЁТ ==========
    УстановитьЦветКонсоли("cyan")
    ВывестиСтрокуВКонсоль("╔════════════════════════════════════════════════════════════════════════════════╗")
    ВывестиСтрокуВКонсоль("║                         ТЕСТИРОВАНИЕ ЗАВЕРШЕНО                                 ║")
    ВывестиСтрокуВКонсоль("╠════════════════════════════════════════════════════════════════════════════════╣")
    ВывестиСтрокуВКонсоль("║  Всего тестов: " + всегоТестов + "                                                  ║")
    
    Если успешноТестов == всегоТестов Тогда
        УстановитьЦветКонсоли("green")
        ВывестиСтрокуВКонсоль("║  Успешно:       " + успешноТестов + "                                                  ║")
        ВывестиСтрокуВКонсоль("║  СТАТУС:        ВСЕ ТЕСТЫ ПРОЙДЕНЫ УСПЕШНО!                              ║")
    Иначе
        УстановитьЦветКонсоли("yellow")
        ВывестиСтрокуВКонсоль("║  Успешно:       " + успешноТестов + "                                                  ║")
        ВывестиСтрокуВКонсоль("║  Ошибок:        " + (всегоТестов - успешноТестов) + "                                                  ║")
        ВывестиСтрокуВКонсоль("║  СТАТУС:        ЕСТЬ ОШИБКИ (проверьте вывод выше)                        ║")
    КонецЕсли
    
    СброситьЦветКонсоли()
    ВывестиСтрокуВКонсоль("╚════════════════════════════════════════════════════════════════════════════════╝")
    ВывестиСтрокуВКонсоль("")
    
    ВывестиСтрокуВКонсоль("Тестирование завершено. Программа закроется через 10 секунд.")
    
    Пауза(10000)
    
    ЗавершитьПрограмму(0)

КОНЕЦПРОЦЕДУРЫ


