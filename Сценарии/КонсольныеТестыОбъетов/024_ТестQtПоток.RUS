        Функция ТестЗадержки()
            поток6.msleepThread(100)
            задержкаВыполнена = true
        КонецФункции;
        
        поток6 = Новый QtПоток()
        поток6.startWithFunction(ТестЗадержки)
        
        Пауза(50)
