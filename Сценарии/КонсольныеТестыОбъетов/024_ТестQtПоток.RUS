//Список тестов для QtПоток:   (Закомментарил то, что пока не работает !!!  )
//
//№    Тест    Проверяемые методы
//1    Создание объекта    Новый QtПоток()
//2    Состояние нового потока    isRunningThread(), isFinishedThread()
//3    Запуск и остановка    startThread(), quitThread(), waitThread()
//4    Запуск с колбэком    startWithCallback()
//5    Запуск с функцией    startWithFunction()
//6    Приоритеты    getPriority(), setPriority(), УстановитьПриоритет()
//7    Задержки    sleepThread(), msleepThread(), usleepThread()
//8    Прерывания    requestInterruption(), isInterruptionRequested(), ЗапроситьПрерывание()
//9    Размер стека    setStackSize(), getStackSize(), УстановитьРазмерСтека(), РазмерСтека()
