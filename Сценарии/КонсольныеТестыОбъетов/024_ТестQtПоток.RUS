        КонецФункции;
        
        поток3 = Новый QtПоток()
        поток3.startWithCallback(ТестовыйКолбэк)
        
        Пауза(200)
        
        запущен3 = поток3.isRunningThread()
        ВывестиСтрокуВКонсоль("  startWithCallback() -> isRunningThread() = " + запущен3 + " (ожидается true)")
        
        поток3.quitThread()
        поток3.waitThread()
        
        ВывестиСтрокуВКонсоль("  колбэкВызван = " + колбэкВызван + " (ожидается true)")
        
        Если колбэкВызван == true Тогда
            ВывестиСтрокуВКонсоль("  ✓ Запуск с колбэком работает корректно")
            успешноТестов = успешноТестов + 1
        Иначе
            ВывестиСтрокуВКонсоль("  ❌ Запуск с колбэком работает некорректно")
        КонецЕсли;
    Исключение
        ВывестиСтрокуВКонсоль("  ✗ ОШИБКА при запуске с колбэком: " + e)
    КонецПопытки;
    ВывестиСтрокуВКонсоль("")

    // ========== 5. ТЕСТ ЗАПУСКА С ФУНКЦИЕЙ ==========
    УстановитьЦветКонсоли("yellow")
    ВывестиСтрокуВКонсоль("┌────────────────────────────────────────────────────────────────────────────────┐")
    ВывестиСтрокуВКонсоль("│ 5. ТЕСТ ЗАПУСКА С ФУНКЦИЕЙ (startWithFunction)                                │")
    ВывестиСтрокуВКонсоль("└────────────────────────────────────────────────────────────────────────────────┘")
    СброситьЦветКонсоли()
    
    всегоТестов = всегоТестов + 1
    Попытка
        функцияВызвана = false
        
        Функция ФункцияТестовая()
            функцияВызвана = true
            ВывестиСтрокуВКонсоль("  >> Функция выполнена в потоке")
        КонецФункции;
        
        поток4 = Новый QtПоток()
        поток4.startWithFunction(ФункцияТестовая())
        
        Пауза(200)
        
        запущен4 = поток4.isRunningThread()
        ВывестиСтрокуВКонсоль("  startWithFunction() -> isRunningThread() = " + запущен4 + " (ожидается true)")
        
        поток4.quitThread()
        поток4.waitThread()
        
        ВывестиСтрокуВКонсоль("  функцияВызвана = " + функцияВызвана + " (ожидается true)")
        
        Если функцияВызвана == true Тогда
            ВывестиСтрокуВКонсоль("  ✓ Запуск с функцией работает корректно")
            успешноТестов = успешноТестов + 1
        Иначе
            ВывестиСтрокуВКонсоль("  ❌ Запуск с функцией работает некорректно")
        КонецЕсли;
    Исключение
        ВывестиСтрокуВКонсоль("  ✗ ОШИБКА при запуске с функцией: " + e)
    КонецПопытки;
