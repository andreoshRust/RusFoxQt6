        ВывестиСтрокуВКонсоль("  ТекущийПоток() = " + (текПоток2 != null ? "объект получен" : "null"))
        
        Если текПоток != null И текПоток2 != null Тогда
            ВывестиСтрокуВКонсоль("  ✓ currentThread() / ТекущийПоток() работают корректно")
            успешноТестов = успешноТестов + 1
        Иначе
            ВывестиСтрокуВКонсоль("  ❌ currentThread() / ТекущийПоток() работают некорректно")
        КонецЕсли;
    Исключение
        ВывестиСтрокуВКонсоль("  ✗ ОШИБКА при получении текущего потока: " + e)
    КонецПопытки;
    ВывестиСтрокуВКонсоль("")
    
    // ========== 12. ТЕСТ waitThreadMs / ОжидатьМс() ==========
    УстановитьЦветКонсоли("yellow")
    ВывестиСтрокуВКонсоль("┌────────────────────────────────────────────────────────────────────────────────┐")
    ВывестиСтрокуВКонсоль("│ 12. ТЕСТ waitThreadMs / ОжидатьМс()                                            │")
    ВывестиСтрокуВКонсоль("└────────────────────────────────────────────────────────────────────────────────┘")
    СброситьЦветКонсоли()
    
    всегоТестов = всегоТестов + 1
    Попытка
        Функция ДолгийЗапуск()
            поток9.msleepThread(200)
        КонецФункции;
        
        поток9 = Новый QtПоток()
        поток9.startWithFunction(ДолгийЗапуск)
        
        Пауза(50)
        запущен9 = поток9.isRunningThread()
        ВывестиСтрокуВКонсоль("  Поток запущен: " + запущен9)
        
        поток9.waitThreadMs(100)
        запущен9_2 = поток9.isRunningThread()
        ВывестиСтрокуВКонсоль("  waitThreadMs(100) -> isRunningThread() = " + запущен9_2)
        
        поток9.waitThread()
        запущен9_3 = поток9.isRunningThread()
        ВывестиСтрокуВКонсоль("  waitThread() -> isRunningThread() = " + запущен9_3 + " (ожидается false)")
        
        Если запущен9 == true Тогда
            ВывестиСтрокуВКонсоль("  ✓ waitThreadMs / ОжидатьМс() работают корректно")
            успешноТестов = успешноТестов + 1
        Иначе
            ВывестиСтрокуВКонсоль("  ❌ waitThreadMs / ОжидатьМс() работают некорректно")
        КонецЕсли;
    Исключение
        ВывестиСтрокуВКонсоль("  ✗ ОШИБКА при ожидании потока: " + e)
    КонецПопытки;
    ВывестиСтрокуВКонсоль("")

    // ========== ИТОГОВЫЙ ОТЧЁТ ==========
    УстановитьЦветКонсоли("cyan")
    ВывестиСтрокуВКонсоль("╔════════════════════════════════════════════════════════════════════════════════╗")
    ВывестиСтрокуВКонсоль("║                         ТЕСТИРОВАНИЕ ЗАВЕРШЕНО                                 ║")
    ВывестиСтрокуВКонсоль("╠════════════════════════════════════════════════════════════════════════════════╣")
    ВывестиСтрокуВКонсоль("║  Всего тестов: " + всегоТестов + "                                                  ║")
    
    Если успешноТестов == всегоТестов Тогда
        УстановитьЦветКонсоли("green")
        ВывестиСтрокуВКонсоль("║  Успешно:       " + успешноТестов + "                                                  ║")
        ВывестиСтрокуВКонсоль("║  СТАТУС:        ВСЕ ТЕСТЫ ПРОЙДЕНЫ УСПЕШНО!                              ║")
    Иначе
        УстановитьЦветКонсоли("yellow")
        ВывестиСтрокуВКонсоль("║  Успешно:       " + успешноТестов + "                                                  ║")
        ВывестиСтрокуВКонсоль("║  Ошибок:        " + (всегоТестов - успешноТестов) + "                                                  ║")
        ВывестиСтрокуВКонсоль("║  СТАТУС:        ЕСТЬ ОШИБКИ (проверьте вывод выше)                        ║")
    КонецЕсли
    
    СброситьЦветКонсоли()
    ВывестиСтрокуВКонсоль("╚════════════════════════════════════════════════════════════════════════════════╝")
    ВывестиСтрокуВКонсоль("")
    
    ВывестиСтрокуВКонсоль("Тестирование завершено. Программа закроется через 10 секунд.")
    
    Пауза(10000)
    
    ЗавершитьПрограмму(0)

КОНЕЦПРОЦЕДУРЫ

