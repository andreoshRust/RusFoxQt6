//11    Текущий поток    currentThread(), ТекущийПоток()
//12    Ожидание с таймаутом    waitThreadMs(), ОжидатьМс()


ПРОЦЕДУРА Старт()
//#ОтладкаПрепроцессора
    Отладка = ИСТИНА
    ПодавитьВыводОкна(ИСТИНА)
    СкрытьГлавноеОкно()
    ОчиститьКонсоль()
    
    УстановитьЦветКонсоли("cyan")
    ВывестиСтрокуВКонсоль("╔════════════════════════════════════════════════════════════════════════════════╗")
    ВывестиСтрокуВКонсоль("║                         ТЕСТИРОВАНИЕ QtПоток (QtThread)                         ║")
    ВывестиСтрокуВКонсоль("╚════════════════════════════════════════════════════════════════════════════════╝")
    СброситьЦветКонсоли()
    ВывестиСтрокуВКонсоль("")

    // ========== ИНИЦИАЛИЗАЦИЯ СЧЁТЧИКОВ ==========
    всегоТестов = 0
    успешноТестов = 0

    // ========== 1. СОЗДАНИЕ ОБЪЕКТА ==========
    УстановитьЦветКонсоли("yellow")
    ВывестиСтрокуВКонсоль("┌────────────────────────────────────────────────────────────────────────────────┐")
    ВывестиСтрокуВКонсоль("│ 1. СОЗДАНИЕ ОБЪЕКТА QtПоток                                                   │")
    ВывестиСтрокуВКонсоль("└────────────────────────────────────────────────────────────────────────────────┘")
    СброситьЦветКонсоли()
    
    всегоТестов = всегоТестов + 1
    Попытка
        поток = Новый QtПоток()
        ВывестиСтрокуВКонсоль("  ✓ Объект QtПоток создан успешно")
        успешноТестов = успешноТестов + 1
    Исключение
        ВывестиСтрокуВКонсоль("  ✗ ОШИБКА при создании объекта: " + e)
    КонецПопытки;
    ВывестиСтрокуВКонсоль("")

    // ========== 2. ТЕСТ СОСТОЯНИЯ НОВОГО ПОТОКА ==========
    УстановитьЦветКонсоли("yellow")
    ВывестиСтрокуВКонсоль("┌────────────────────────────────────────────────────────────────────────────────┐")
    ВывестиСтрокуВКонсоль("│ 2. ТЕСТ СОСТОЯНИЯ НОВОГО ПОТОКА (не запущен)                                  │")
    ВывестиСтрокуВКонсоль("└────────────────────────────────────────────────────────────────────────────────┘")
    СброситьЦветКонсоли()
    
    всегоТестов = всегоТестов + 1
    Попытка
        запущен = поток.isRunningThread()
        завершён = поток.isFinishedThread()
        
        ВывестиСтрокуВКонсоль("  isRunningThread() = " + запущен + " (ожидается false)")
        ВывестиСтрокуВКонсоль("  isFinishedThread() = " + завершён + " (ожидается false)")
        
        Если запущен == false И завершён == false Тогда
            ВывестиСтрокуВКонсоль("  ✓ Состояние нового потока корректно")
            успешноТестов = успешноТестов + 1
        Иначе
            ВывестиСтрокуВКонсоль("  ❌ Состояние нового потока некорректно")
        КонецЕсли;
    Исключение
        ВывестиСтрокуВКонсоль("  ✗ ОШИБКА при проверке состояния: " + e)
    КонецПопытки;
    ВывестиСтрокуВКонсоль("")

    // ========== 3. ТЕСТ ЗАПУСКА ПОТОКА И ОСТАНОВКИ ==========
    УстановитьЦветКонсоли("yellow")
    ВывестиСтрокуВКонсоль("┌────────────────────────────────────────────────────────────────────────────────┐")
    ВывестиСтрокуВКонсоль("│ 3. ТЕСТ ЗАПУСКА ПОТОКА И ОСТАНОВКИ                                            │")
    ВывестиСтрокуВКонсоль("└────────────────────────────────────────────────────────────────────────────────┘")
    СброситьЦветКонсоли()
    
    всегоТестов = всегоТестов + 1
    Попытка
        поток2 = Новый QtПоток()
        поток2.startThread()
        
        Пауза(50)
        запущен1 = поток2.isRunningThread()
        ВывестиСтрокуВКонсоль("  startThread() -> isRunningThread() = " + запущен1 + " (ожидается true)")
        
        поток2.quitThread()
        поток2.waitThread()
        
        запущен2 = поток2.isRunningThread()
        завершён2 = поток2.isFinishedThread()
        ВывестиСтрокуВКонсоль("  quitThread() -> isRunningThread() = " + запущен2 + " (ожидается false)")
        ВывестиСтрокуВКонсоль("  isFinishedThread() = " + завершён2 + " (ожидается true)")
        
        Если запущен1 == true И запущен2 == false Тогда
            ВывестиСтрокуВКонсоль("  ✓ Запуск и остановка потока работают корректно")
            успешноТестов = успешноТестов + 1
        Иначе
            ВывестиСтрокуВКонсоль("  ❌ Запуск и остановка потока работают некорректно")
        КонецЕсли;
    Исключение
        ВывестиСтрокуВКонсоль("  ✗ ОШИБКА при запуске/остановке потока: " + e)
    КонецПопытки;
    ВывестиСтрокуВКонсоль("")

    // ========== 4. ТЕСТ ЗАПУСКА С КОЛБЭКОМ ==========
    УстановитьЦветКонсоли("yellow")
