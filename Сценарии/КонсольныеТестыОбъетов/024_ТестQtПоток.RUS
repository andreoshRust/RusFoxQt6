        поток6.waitThread()
        
        ВывестиСтрокуВКонсоль("  задержкаВыполнена = " + задержкаВыполнена + " (ожидается true)")
        
        Если запущен6 == true И задержкаВыполнена == true Тогда
            ВывестиСтрокуВКонсоль("  ✓ Задержки в потоке работают корректно")
            успешноТестов = успешноТестов + 1
