    Исключение
        ВывестиСтрокуВКонсоль("  ✗ ОШИБКА при извлечении значений: " + e)
    КонецПопытки;
    ВывестиСтрокуВКонсоль("")

    // ========== 10. ТЕСТ clear() / Очистить() ==========
    УстановитьЦветКонсоли("yellow")
    ВывестиСтрокуВКонсоль("┌────────────────────────────────────────────────────────────────────────────────┐")
    ВывестиСтрокуВКонсоль("│ 10. ТЕСТ clear() / Очистить()                                                   │")
    ВывестиСтрокуВКонсоль("└────────────────────────────────────────────────────────────────────────────────┘")
    СброситьЦветКонсоли()
    
    всегоТестов = всегоТестов + 1
    Попытка
        х8 = Новый QtХешТаблица()
        х8.insert("a", 1)
        х8.insert("b", 2)
        х8.insert("c", 3)
        
        х8.clear()
        размер1 = х8.size
        пусто1 = х8.isEmpty
        
        х8.insert("d", 4)
        х8.insert("e", 5)
        х8.Очистить()
        размер2 = х8.size
        пусто2 = х8.isEmpty
        
        ВывестиСтрокуВКонсоль("  clear() -> size = " + размер1 + " (ожидается 0), isEmpty = " + пусто1 + " (ожидается true)")
        ВывестиСтрокуВКонсоль("  Очистить() -> size = " + размер2 + " (ожидается 0), isEmpty = " + пусто2 + " (ожидается true)")
        
        Если размер1 == 0 И пусто1 == true И размер2 == 0 И пусто2 == true Тогда
            ВывестиСтрокуВКонсоль("  ✓ clear() / Очистить() работают корректно")
            успешноТестов = успешноТестов + 1
        Иначе
            ВывестиСтрокуВКонсоль("  ❌ clear() / Очистить() работают некорректно")
        КонецЕсли;
    Исключение
        ВывестиСтрокуВКонсоль("  ✗ ОШИБКА при очистке хеш-таблицы: " + e)
    КонецПопытки;
    ВывестиСтрокуВКонсоль("")

    // ========== 11. ТЕСТ РАБОТЫ С РАЗНЫМИ ТИПАМИ ЗНАЧЕНИЙ ==========
    УстановитьЦветКонсоли("yellow")
    ВывестиСтрокуВКонсоль("┌────────────────────────────────────────────────────────────────────────────────┐")
    ВывестиСтрокуВКонсоль("│ 11. ТЕСТ РАБОТЫ С РАЗНЫМИ ТИПАМИ ЗНАЧЕНИЙ                                      │")
    ВывестиСтрокуВКонсоль("└────────────────────────────────────────────────────────────────────────────────┘")
    СброситьЦветКонсоли()
    
    всегоТестов = всегоТестов + 1
    Попытка
        х9 = Новый QtХешТаблица()
        х9.insert("число", 42)
        х9.insert("строка", "Привет")
        х9.insert("булево", true)
        х9.insert("дробь", 3.14)
        
        знач1 = х9.value("число")
        знач2 = х9.value("строка")
        знач3 = х9.value("булево")
        знач4 = х9.value("дробь")
        размер = х9.size
        
        ВывестиСтрокуВКонсоль("  value('число') = " + знач1.toString() + " (ожидается 42)")
        ВывестиСтрокуВКонсоль("  value('строка') = " + знач2.toString() + " (ожидается Привет)")
        ВывестиСтрокуВКонсоль("  value('булево') = " + знач3.toString() + " (ожидается true)")
        ВывестиСтрокуВКонсоль("  value('дробь') = " + знач4.toString() + " (ожидается 3.14)")
        ВывестиСтрокуВКонсоль("  size = " + размер + " (ожидается 4)")
        
        Если знач1.toString() == "42" И знач2.toString() == "Привет" И знач3.toString() == "true" И знач4.toString() == "3.14" И размер == 4 Тогда
            ВывестиСтрокуВКонсоль("  ✓ Работа с разными типами значений корректна")
            успешноТестов = успешноТестов + 1
        Иначе
            ВывестиСтрокуВКонсоль("  ❌ Работа с разными типами значений некорректна")
        КонецЕсли;
    Исключение
        ВывестиСтрокуВКонсоль("  ✗ ОШИБКА при работе с разными типами: " + e)
    КонецПопытки;
    ВывестиСтрокуВКонсоль("")

    // ========== 12. ТЕСТ ЗАМЕНА ЗНАЧЕНИЯ ПО КЛЮЧУ ==========
    УстановитьЦветКонсоли("yellow")
    ВывестиСтрокуВКонсоль("┌────────────────────────────────────────────────────────────────────────────────┐")
    ВывестиСтрокуВКонсоль("│ 12. ТЕСТ ЗАМЕНА ЗНАЧЕНИЯ ПО КЛЮЧУ (перезапись)                                 │")
    ВывестиСтрокуВКонсоль("└────────────────────────────────────────────────────────────────────────────────┘")
    СброситьЦветКонсоли()
    
    всегоТестов = всегоТестов + 1
    Попытка
        х10 = Новый QtХешТаблица()
        х10.insert("ключ", "старое значение")
        х10.insert("ключ", "новое значение")
        
        знач = х10.value("ключ")
        размер = х10.size
        
        ВывестиСтрокуВКонсоль("  insert('ключ', 'старое значение')")
        ВывестиСтрокуВКонсоль("  insert('ключ', 'новое значение')")
        ВывестиСтрокуВКонсоль("  value('ключ') = " + знач.toString() + " (ожидается новое значение)")
        ВывестиСтрокуВКонсоль("  size = " + размер + " (ожидается 1)")
        
        Если знач.toString() == "новое значение" И размер == 1 Тогда
            ВывестиСтрокуВКонсоль("  ✓ Замена значения по ключу работает корректно")
            успешноТестов = успешноТестов + 1
        Иначе
            ВывестиСтрокуВКонсоль("  ❌ Замена значения по ключу работает некорректно")
        КонецЕсли;
    Исключение
        ВывестиСтрокуВКонсоль("  ✗ ОШИБКА при замене значения: " + e)
    КонецПопытки;
    ВывестиСтрокуВКонсоль("")

    // ========== ИТОГОВЫЙ ОТЧЁТ ==========
    УстановитьЦветКонсоли("cyan")
    ВывестиСтрокуВКонсоль("╔════════════════════════════════════════════════════════════════════════════════╗")
    ВывестиСтрокуВКонсоль("║                         ТЕСТИРОВАНИЕ ЗАВЕРШЕНО                                 ║")
    ВывестиСтрокуВКонсоль("╠════════════════════════════════════════════════════════════════════════════════╣")
    ВывестиСтрокуВКонсоль("║  Всего тестов: " + всегоТестов + "                                                  ║")
    
    Если успешноТестов == всегоТестов Тогда
        УстановитьЦветКонсоли("green")
        ВывестиСтрокуВКонсоль("║  Успешно:       " + успешноТестов + "                                                  ║")
        ВывестиСтрокуВКонсоль("║  СТАТУС:        ВСЕ ТЕСТЫ ПРОЙДЕНЫ УСПЕШНО!                              ║")
    Иначе
        УстановитьЦветКонсоли("yellow")
        ВывестиСтрокуВКонсоль("║  Успешно:       " + успешноТестов + "                                                  ║")
        ВывестиСтрокуВКонсоль("║  Ошибок:        " + (всегоТестов - успешноТестов) + "                                                  ║")
        ВывестиСтрокуВКонсоль("║  СТАТУС:        ЕСТЬ ОШИБКИ (проверьте вывод выше)                        ║")
    КонецЕсли
    
    СброситьЦветКонсоли()
    ВывестиСтрокуВКонсоль("╚════════════════════════════════════════════════════════════════════════════════╝")
    ВывестиСтрокуВКонсоль("")
    
    ВывестиСтрокуВКонсоль("Тестирование завершено. Программа закроется через 10 секунд.")
    
    Пауза(10000)
    
    ЗавершитьПрограмму(0)

КОНЕЦПРОЦЕДУРЫ
